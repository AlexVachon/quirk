*.log
*.ll
.vscode/settings.json

# Quirk venv / package-manager artifacts (project-local installs, lockfile
# generated by `quirk pkg install`, and test fixtures written by tests/sys_test.qk).
quirk-compiler/.venv/
quirk-compiler/quirk.lock
quirk-compiler/test_output.txt

# Stdlib bootstrap output (since 2.0.2). `quirk-compiler/packages/` is no
# longer tracked in git — its content is pulled fresh from the 21 canonical
# stdlib repos by `make bootstrap-stdlib`. Fresh contributors run that
# target once after clone; the release workflow runs it before packaging.
quirk-compiler/packages/

# Build outputs
quirk-compiler/bin/quirk
quirk-compiler/bin/runtime.so
quirk-compiler/obj

# Editor / extension
quirk-vscode/node_modules
quirk-vscode/out