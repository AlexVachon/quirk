# Compiler settings
#
# `llvm-config-14` is the apt naming used on Debian/Ubuntu. Homebrew's
# `llvm@14` formula installs it under `/opt/homebrew/opt/llvm@14/bin`
# (Apple Silicon) or `/usr/local/opt/llvm@14/bin` (Intel) — pre-seed
# LLVM_CONFIG=/opt/homebrew/opt/llvm@14/bin/llvm-config when building
# on macOS. The compiler/runtime themselves are POSIX-clean; nothing
# else in the Makefile needs an OS branch.
LLVM_CONFIG ?= llvm-config-14

# -O2 on the host C++ build: this is the Quirk compiler itself, not the
# LLVM passes it runs over user IR. Default-O0 means parser/sema/codegen
# walk the AST unoptimized, which added ~30-40% to every invocation.
CXX      ?= g++
CXXFLAGS = -std=c++17 -Wall -O2 -Iinclude $(shell $(LLVM_CONFIG) --cppflags) -MMD -MP
LDFLAGS  = $(shell $(LLVM_CONFIG) --ldflags --libs all --system-libs) -lpthread

# Same story for runtime.so — the .c files implementing String, List, Map,
# etc. were unoptimized at runtime. -O2 here makes every string/list/map
# operation faster.
CC     ?= gcc
# `-shared -fPIC` is the same incantation on Linux and macOS. Apple's
# clang accepts `-shared` and produces a `.dylib`-compatible Mach-O
# object; keeping the `.so` filename is fine because `dlopen` ignores
# the extension on macOS. (Renaming to `.dylib` would also work but
# would ripple into 7+ install-script and resolver sites for no
# practical benefit.)
CFLAGS = -shared -fPIC -O2

# Directories
SRC_DIR = src
OBJ_DIR = obj
BIN_DIR = bin

# --- 1. COMPILER SOURCES ---
SRCS = src/Compiler.cpp src/Core/Lexer.cpp src/Core/Parser.cpp src/Core/Sema.cpp
OBJS = $(patsubst $(SRC_DIR)/%.cpp, $(OBJ_DIR)/%.o, $(SRCS))
DEPS = $(OBJS:.o=.d)

# linenoise — vendored single-file readline alternative for the REPL.
# BSD-2-clause (see src/third_party/linenoise/LICENSE). Built as a C
# translation unit and linked in alongside the C++ compiler objects.
LINENOISE_SRC = src/third_party/linenoise/linenoise.c
LINENOISE_OBJ = $(OBJ_DIR)/third_party/linenoise/linenoise.o

# --- v5.0.0 cutover note ---
# `$(TARGET)` is the C++ compiler — kept as `bin/quirk-cpp` so the
# user-facing `bin/quirk` can be the new selfhost-driven wrapper.
# The C++ binary stays the source-of-truth for the bootstrap chain
# (selfhost is compiled from selfhost/ source via this binary), and
# remains the fallback for package manager subcommands until those
# move into selfhost.
TARGET = $(BIN_DIR)/quirk-cpp
DRIVER = $(BIN_DIR)/quirk

# --- 2. RUNTIME LIBRARY ---
# Entry point (unity build — includes all .c files below)
RUNTIME_ENTRY = src/Runtime/runtime.c

# All C files pulled in via #include; any change here rebuilds runtime.so
RUNTIME_DEPS  = \
	src/Runtime/types.h \
	src/Runtime/core/string.c \
	src/Runtime/core/primitives.c \
	src/Runtime/core/list.c \
	src/Runtime/core/map.c \
	src/Runtime/core/any.c \
	src/Runtime/core/exceptions.c \
	src/Runtime/core/queue.c \
	src/Runtime/core/set.c \
	src/Runtime/core/tuple.c \
	src/Runtime/libs/file.c \
	src/Runtime/libs/sys.c \
	src/Runtime/libs/net.c \
	src/Runtime/libs/math.c \
	src/Runtime/libs/fs.c \
	src/Runtime/libs/time.c \
	src/Runtime/libs/regex.c \
	src/Runtime/libs/crypto.c \
	src/Runtime/libs/random.c \
	src/Runtime/libs/debug.c \
	src/Runtime/libs/encoding/json.c \
	src/Runtime/libs/encoding/base64.c \
	src/Runtime/libs/encoding/hex.c

RUNTIME_LIB = $(BIN_DIR)/runtime.so

# --- RULES ---

all: $(TARGET) $(RUNTIME_LIB) $(SELFHOST_BIN) $(DRIVER)

$(TARGET): $(OBJS) $(LINENOISE_OBJ)
	@mkdir -p $(BIN_DIR)
	$(CXX) $(OBJS) $(LINENOISE_OBJ) -o $@ $(LDFLAGS)

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(LINENOISE_OBJ): $(LINENOISE_SRC) src/third_party/linenoise/linenoise.h
	@mkdir -p $(dir $@)
	$(CC) -O2 -fPIC -c $< -o $@

$(RUNTIME_LIB): $(RUNTIME_ENTRY) $(RUNTIME_DEPS)
	@mkdir -p $(BIN_DIR)
	@echo "Compiling Runtime Library..."
	$(CC) $(CFLAGS) $(RUNTIME_ENTRY) -o $@ -lgc -lssl -lcrypto

# Include compiler dependency files (auto-generated by -MMD)
-include $(DEPS)

clean:
	rm -rf $(OBJ_DIR)
	rm -f $(TARGET) $(RUNTIME_LIB)

# Quick smoke: compile and run a test file
test: all
	./$(TARGET) tests/encoding_test.quirk

# --- SELFHOST BINARY -------------------------------------------------------
# Build a standalone Quirk compiler binary from the self-hosted source.
# Pipeline: bin/quirk (C++ compiler) → selfhost/quirk_main.quirk → IR text
# → llc-14 → x86_64 assembly → clang-14 -no-pie → bin/quirk-selfhost ELF.
#
# The resulting binary is a fully usable CLI compiler:
#   ./bin/quirk-selfhost source.quirk           # IR to stdout
#   ./bin/quirk-selfhost source.quirk out.ll    # IR to file
#
# Note: requires llc-14 and clang-14 on PATH. The intermediate .ll is
# kept under build/ for inspection. To reproduce the byte-identical
# fixed point, run `make selfhost-fixedpoint` (alpha.43+).
SELFHOST_LL  = build/quirk_selfhost.ll
SELFHOST_S   = build/quirk_selfhost.s
SELFHOST_BIN = $(BIN_DIR)/quirk-selfhost

$(SELFHOST_LL): $(TARGET) selfhost/quirk_main.quirk selfhost/build.quirk \
                selfhost/codegen.quirk selfhost/sema.quirk \
                selfhost/parser.quirk selfhost/lexer.quirk \
                selfhost/ast.quirk selfhost/tokens.quirk selfhost/types.quirk
	@mkdir -p build
	# stdout-redirect rather than the driver's argv[2] file-write
	# path: the C++ compiler has a known wrapping bug where a
	# String returned by `arg_get` reaches `write_file` as a
	# String-of-String (its `_buffer` points at a struct, not a
	# c-string). The selfhost-compiled binary doesn't have this
	# bug — once the standalone binary is built, file-output via
	# argv[2] works correctly there.
	./$(TARGET) --no-aot --no-cache selfhost/quirk_main.quirk \
		selfhost/quirk_main.quirk > $@ \
		|| (rm -f $@ && echo "selfhost IR emission failed" && exit 1)

$(SELFHOST_S): $(SELFHOST_LL)
	llc-14 $< -o $@

$(SELFHOST_BIN): $(SELFHOST_S)
	@mkdir -p $(BIN_DIR)
	clang-14 -no-pie $< -o $@

selfhost-binary: $(SELFHOST_BIN)
	@echo ""
	@echo "  built: $(SELFHOST_BIN)"
	@echo "  size:  $$(stat -c%s $(SELFHOST_BIN)) bytes"
	@echo ""
	@echo "  usage: $(SELFHOST_BIN) <source.quirk> [out.ll]"

# --- DRIVER WRAPPER (the user-facing bin/quirk for v5.0.0) ------------------
# Installs the selfhost-driven compile + JIT-execute wrapper at
# $(DRIVER). Falls back to bin/quirk-cpp for package manager
# subcommands. Depends on the selfhost binary + runtime + C++
# binary (for the fallback) being present.
$(DRIVER): selfhost/quirk-driver.sh $(SELFHOST_BIN) $(RUNTIME_LIB) $(TARGET)
	@mkdir -p $(BIN_DIR)
	cp selfhost/quirk-driver.sh $@
	chmod +x $@
	@echo "  installed: $@ (selfhost-driven; fallback to $(TARGET))"

# --- SELFHOST FIXED-POINT VERIFICATION -------------------------------------
# The canonical bootstrap proof: the self-hosted compiler is a stable
# fixed point under itself. Pipeline:
#
#   bin/quirk-selfhost compiles selfhost/quirk_main.quirk  → ir1.ll
#   ir1.ll + llc-14 + clang-14                              → quirk-selfhost-v2
#   quirk-selfhost-v2 compiles selfhost/quirk_main.quirk    → ir2.ll
#   diff ir1.ll ir2.ll  → must be byte-identical (zero diff)
#
# Why not compare against `bin/quirk` (the C++ compiler) output: the two
# compilers use intentionally different IR shapes (GC_malloc vs malloc,
# Core_Primitives_* vs inline structs) — they're both correct, just not
# byte-identical. The real fixed-point criterion is selfhost-vs-selfhost.
SELFHOST_FP_IR1 = build/quirk_selfhost_fp1.ll
SELFHOST_FP_IR2 = build/quirk_selfhost_fp2.ll
SELFHOST_FP_BIN = build/quirk-selfhost-v2

$(SELFHOST_FP_IR1): $(SELFHOST_BIN)
	@mkdir -p build
	./$(SELFHOST_BIN) selfhost/quirk_main.quirk $@

$(SELFHOST_FP_BIN): $(SELFHOST_FP_IR1)
	@mkdir -p build
	llc-14 $< -o build/quirk_selfhost_fp1.s
	clang-14 -no-pie build/quirk_selfhost_fp1.s -o $@

$(SELFHOST_FP_IR2): $(SELFHOST_FP_BIN)
	./$(SELFHOST_FP_BIN) selfhost/quirk_main.quirk $@

selfhost-fixedpoint: $(SELFHOST_FP_IR1) $(SELFHOST_FP_IR2)
	@if diff -q $(SELFHOST_FP_IR1) $(SELFHOST_FP_IR2) > /dev/null; then       \
	    echo "";                                                                \
	    echo "  byte-identical fixed point achieved";                           \
	    echo "  ir1 = $$(wc -c < $(SELFHOST_FP_IR1)) bytes";                    \
	    echo "  ir2 = $$(wc -c < $(SELFHOST_FP_IR2)) bytes";                    \
	    echo "";                                                                \
	    echo "  bin/quirk-selfhost compiled itself, the resulting binary";      \
	    echo "  recompiled the same source, output is identical.";              \
	    echo "  this is the canonical bootstrap milestone.";                    \
	else                                                                        \
	    echo "FAIL: fixed-point verification";                                  \
	    diff -u $(SELFHOST_FP_IR1) $(SELFHOST_FP_IR2) | head -50;               \
	    exit 1;                                                                 \
	fi

# Self-host smoke — runs the in-Quirk lexer (Phase 1), parser
# (Phase 2), and sema (Phase 3) against a small corpus. Doesn't
# yet assert byte-for-byte equality with the C++ tokenizer /
# parser / sema (Phase 5 does); this is here so regressions in
# selfhost/*.quirk surface in CI before they bitrot silently.
test-selfhost: all
	@echo "--- Phase 1: lexer ---"
	QUIRK_HOME=$(shell pwd) ./$(TARGET) --no-aot --no-cache selfhost/lexer_test.quirk
	@echo ""
	@echo "--- Phase 2: parser ---"
	QUIRK_HOME=$(shell pwd) ./$(TARGET) --no-aot --no-cache selfhost/parser_test.quirk
	@echo ""
	@echo "--- Phase 3: sema ---"
	QUIRK_HOME=$(shell pwd) ./$(TARGET) --no-aot --no-cache selfhost/sema_test.quirk
	@echo ""
	@echo "--- Phase 4: codegen + lli ---"
	bash selfhost/codegen_e2e.sh

# --- STDLIB BOOTSTRAP -------------------------------------------------------
# Fetch the 21 canonical stdlib repos into ./packages/. Required for:
#   - fresh contributor checkouts (the source tree no longer ships bundled
#     stdlib)
#   - the release workflow (the resulting tarball needs a populated
#     packages/ dir so install.sh users get a working compiler)
#
# Idempotent: skips any package whose subdir already has an `index.quirk`.
# Versioned: each clone pins the package's `v1.0.0` tag (matching the
# stdlib_registry() versions baked into the compiler). To pull newer tags,
# bump the version inline below and re-run.
STDLIB_PACKAGES = \
	argparse console crypto csv datetime debug encoding fs html io itertools \
	math net prompt random regex statistics sys test time toml typing url uuid
STDLIB_OWNER ?= AlexVachon
STDLIB_TAG   ?= v1.0.0

# Per-package tag override. Set when a package has its own version
# that doesn't match the global STDLIB_TAG (e.g. `prompt` was
# renamed from `ask` and ships v1.0.1 with the rename baked in).
STDLIB_TAG_prompt ?= v1.1.0
# typing v1.14.0 adds Map.items() returning a List of [k, v]
# Lists for iteration. Pure Quirk-side helper; no runtime work.
STDLIB_TAG_typing ?= v1.14.0
# html v1.0.0 is the initial release (compiler v3.5.0+). The
# explicit pin keeps a global STDLIB_TAG bump from accidentally
# pulling a v2 with potentially breaking changes.
STDLIB_TAG_html ?= v1.0.1
# net v1.2.0 adds Response.json() convenience method on top of
# v1.1.0's TLS support. Earlier v1.1.0 baseline still requires the
# v3.7.0+ runtime (Net_tls_* C symbols + -lssl); .json() is a
# pure-Quirk one-liner so v1.2.0 has no additional compiler
# requirement beyond what v1.1.0 already needed.
STDLIB_TAG_net ?= v1.2.0

bootstrap-stdlib:
	@mkdir -p packages
	@for pkg in $(STDLIB_PACKAGES); do                                            \
	    if [ -f "packages/$$pkg/index.quirk" ]; then                              \
	        echo "  ✓ $$pkg (already present)";                                   \
	        continue;                                                             \
	    fi;                                                                       \
	    tag="$(STDLIB_TAG)";                                                      \
	    case "$$pkg" in                                                           \
	        prompt) tag="$(STDLIB_TAG_prompt)" ;;                                 \
	        typing) tag="$(STDLIB_TAG_typing)" ;;                                 \
	        html)   tag="$(STDLIB_TAG_html)"   ;;                                 \
	        net)    tag="$(STDLIB_TAG_net)"    ;;                                 \
	    esac;                                                                     \
	    echo "  → cloning quirk-$$pkg@$$tag";                                     \
	    tmp=$$(mktemp -d);                                                        \
	    if ! git clone --quiet --depth 1 --branch "$$tag"                         \
	            "https://github.com/$(STDLIB_OWNER)/quirk-$$pkg.git" "$$tmp";     \
	    then                                                                      \
	        echo "  ✗ $$pkg — clone failed";                                      \
	        rm -rf "$$tmp";                                                       \
	        exit 1;                                                               \
	    fi;                                                                       \
	    rm -rf "packages/$$pkg";                                                  \
	    if [ -d "$$tmp/src" ]; then                                               \
	        mv "$$tmp/src" "packages/$$pkg";                                      \
	    else                                                                      \
	        mv "$$tmp" "packages/$$pkg";                                          \
	    fi;                                                                       \
	    rm -rf "$$tmp";                                                           \
	done
	@echo "Stdlib bootstrap complete: $$(ls packages | wc -l) packages"

# Convenience: wipe + re-fetch the entire stdlib.
bootstrap-stdlib-clean:
	rm -rf packages
	$(MAKE) bootstrap-stdlib

# Regenerate `docs/stdlib/*.md` from the in-source `---` docstrings
# in `packages/*/*.quirk`. Run after touching any stdlib docstring or
# refreshing the bootstrap. Requires Python 3.
docs:
	@python3 tools/gen_stdlib_docs.py

# Mutation-based compiler fuzzer (tools/fuzz.py). Picks random files
# from tests/probes + tests/, mutates them (operator/literal/type
# swaps, line drops/dups/swaps), runs the result, and saves any
# crash (SIGSEGV / ICE / malformed IR) under tools/fuzz_findings/.
# Use after touching Sema or Codegen — surfaces the next class of
# input the compiler can't handle gracefully.
#
#   make fuzz                                  # 500 iters
#   make fuzz FUZZ_ITERS=2000 FUZZ_SEED=42      # reproducible
FUZZ_ITERS ?= 500
FUZZ_SEED  ?=
fuzz:
	@python3 tools/fuzz.py --iters $(FUZZ_ITERS) $(if $(FUZZ_SEED),--seed $(FUZZ_SEED),) --quiet

.PHONY: all clean test selfhost-binary selfhost-fixedpoint bootstrap-stdlib bootstrap-stdlib-clean docs fuzz
