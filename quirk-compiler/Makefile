# Compiler settings
#
# `llvm-config-14` is the apt naming used on Debian/Ubuntu. Homebrew's
# `llvm@14` formula installs it under `/opt/homebrew/opt/llvm@14/bin`
# (Apple Silicon) or `/usr/local/opt/llvm@14/bin` (Intel) — pre-seed
# LLVM_CONFIG=/opt/homebrew/opt/llvm@14/bin/llvm-config when building
# on macOS. The compiler/runtime themselves are POSIX-clean; nothing
# else in the Makefile needs an OS branch.
LLVM_CONFIG ?= llvm-config-14

# -O2 on the host C++ build: this is the Quirk compiler itself, not the
# LLVM passes it runs over user IR. Default-O0 means parser/sema/codegen
# walk the AST unoptimized, which added ~30-40% to every invocation.
CXX      ?= g++
CXXFLAGS = -std=c++17 -Wall -O2 -Iinclude $(shell $(LLVM_CONFIG) --cppflags) -MMD -MP
LDFLAGS  = $(shell $(LLVM_CONFIG) --ldflags --libs all --system-libs)

# Same story for runtime.so — the .c files implementing String, List, Map,
# etc. were unoptimized at runtime. -O2 here makes every string/list/map
# operation faster.
CC     ?= gcc
# `-shared -fPIC` is the same incantation on Linux and macOS. Apple's
# clang accepts `-shared` and produces a `.dylib`-compatible Mach-O
# object; keeping the `.so` filename is fine because `dlopen` ignores
# the extension on macOS. (Renaming to `.dylib` would also work but
# would ripple into 7+ install-script and resolver sites for no
# practical benefit.)
CFLAGS = -shared -fPIC -O2

# Directories
SRC_DIR = src
OBJ_DIR = obj
BIN_DIR = bin

# --- 1. COMPILER SOURCES ---
SRCS = src/Compiler.cpp src/Core/Lexer.cpp src/Core/Parser.cpp src/Core/Sema.cpp
OBJS = $(patsubst $(SRC_DIR)/%.cpp, $(OBJ_DIR)/%.o, $(SRCS))
DEPS = $(OBJS:.o=.d)

# linenoise — vendored single-file readline alternative for the REPL.
# BSD-2-clause (see src/third_party/linenoise/LICENSE). Built as a C
# translation unit and linked in alongside the C++ compiler objects.
LINENOISE_SRC = src/third_party/linenoise/linenoise.c
LINENOISE_OBJ = $(OBJ_DIR)/third_party/linenoise/linenoise.o

TARGET = $(BIN_DIR)/quirk

# --- 2. RUNTIME LIBRARY ---
# Entry point (unity build — includes all .c files below)
RUNTIME_ENTRY = src/Runtime/runtime.c

# All C files pulled in via #include; any change here rebuilds runtime.so
RUNTIME_DEPS  = \
	src/Runtime/types.h \
	src/Runtime/core/string.c \
	src/Runtime/core/primitives.c \
	src/Runtime/core/list.c \
	src/Runtime/core/map.c \
	src/Runtime/core/any.c \
	src/Runtime/core/exceptions.c \
	src/Runtime/core/queue.c \
	src/Runtime/core/set.c \
	src/Runtime/core/tuple.c \
	src/Runtime/libs/file.c \
	src/Runtime/libs/sys.c \
	src/Runtime/libs/net.c \
	src/Runtime/libs/math.c \
	src/Runtime/libs/fs.c \
	src/Runtime/libs/time.c \
	src/Runtime/libs/regex.c \
	src/Runtime/libs/crypto.c \
	src/Runtime/libs/random.c \
	src/Runtime/libs/debug.c \
	src/Runtime/libs/encoding/json.c \
	src/Runtime/libs/encoding/base64.c \
	src/Runtime/libs/encoding/hex.c

RUNTIME_LIB = $(BIN_DIR)/runtime.so

# --- RULES ---

all: $(TARGET) $(RUNTIME_LIB)

$(TARGET): $(OBJS) $(LINENOISE_OBJ)
	@mkdir -p $(BIN_DIR)
	$(CXX) $(OBJS) $(LINENOISE_OBJ) -o $@ $(LDFLAGS)

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(dir $@)
	$(CXX) $(CXXFLAGS) -c $< -o $@

$(LINENOISE_OBJ): $(LINENOISE_SRC) src/third_party/linenoise/linenoise.h
	@mkdir -p $(dir $@)
	$(CC) -O2 -fPIC -c $< -o $@

$(RUNTIME_LIB): $(RUNTIME_ENTRY) $(RUNTIME_DEPS)
	@mkdir -p $(BIN_DIR)
	@echo "Compiling Runtime Library..."
	$(CC) $(CFLAGS) $(RUNTIME_ENTRY) -o $@ -lgc -lssl -lcrypto

# Include compiler dependency files (auto-generated by -MMD)
-include $(DEPS)

clean:
	rm -rf $(OBJ_DIR)
	rm -f $(TARGET) $(RUNTIME_LIB)

# Quick smoke: compile and run a test file
test: all
	./$(TARGET) tests/encoding_test.quirk

# --- STDLIB BOOTSTRAP -------------------------------------------------------
# Fetch the 21 canonical stdlib repos into ./packages/. Required for:
#   - fresh contributor checkouts (the source tree no longer ships bundled
#     stdlib)
#   - the release workflow (the resulting tarball needs a populated
#     packages/ dir so install.sh users get a working compiler)
#
# Idempotent: skips any package whose subdir already has an `index.quirk`.
# Versioned: each clone pins the package's `v1.0.0` tag (matching the
# stdlib_registry() versions baked into the compiler). To pull newer tags,
# bump the version inline below and re-run.
STDLIB_PACKAGES = \
	argparse console crypto csv datetime debug encoding fs html io itertools \
	math net prompt random regex statistics sys test time toml typing url uuid
STDLIB_OWNER ?= AlexVachon
STDLIB_TAG   ?= v1.0.0

# Per-package tag override. Set when a package has its own version
# that doesn't match the global STDLIB_TAG (e.g. `prompt` was
# renamed from `ask` and ships v1.0.1 with the rename baked in).
STDLIB_TAG_prompt ?= v1.1.0
# typing v1.8.0 adds Set.__add (union) + Set.__sub (difference)
# operator overloads. Requires compiler v3.19.0+ for the Sema
# typing rules, the member-access dispatch fix (triple-underscore
# fallback restricted to dunder member names), and GC_malloc/
# order-iteration corrections in the set runtime.
STDLIB_TAG_typing ?= v1.8.0
# html v1.0.0 is the initial release (compiler v3.5.0+). The
# explicit pin keeps a global STDLIB_TAG bump from accidentally
# pulling a v2 with potentially breaking changes.
STDLIB_TAG_html ?= v1.0.1
# net v1.2.0 adds Response.json() convenience method on top of
# v1.1.0's TLS support. Earlier v1.1.0 baseline still requires the
# v3.7.0+ runtime (Net_tls_* C symbols + -lssl); .json() is a
# pure-Quirk one-liner so v1.2.0 has no additional compiler
# requirement beyond what v1.1.0 already needed.
STDLIB_TAG_net ?= v1.2.0

bootstrap-stdlib:
	@mkdir -p packages
	@for pkg in $(STDLIB_PACKAGES); do                                            \
	    if [ -f "packages/$$pkg/index.quirk" ]; then                              \
	        echo "  ✓ $$pkg (already present)";                                   \
	        continue;                                                             \
	    fi;                                                                       \
	    tag="$(STDLIB_TAG)";                                                      \
	    case "$$pkg" in                                                           \
	        prompt) tag="$(STDLIB_TAG_prompt)" ;;                                 \
	        typing) tag="$(STDLIB_TAG_typing)" ;;                                 \
	        html)   tag="$(STDLIB_TAG_html)"   ;;                                 \
	        net)    tag="$(STDLIB_TAG_net)"    ;;                                 \
	    esac;                                                                     \
	    echo "  → cloning quirk-$$pkg@$$tag";                                     \
	    tmp=$$(mktemp -d);                                                        \
	    if ! git clone --quiet --depth 1 --branch "$$tag"                         \
	            "https://github.com/$(STDLIB_OWNER)/quirk-$$pkg.git" "$$tmp";     \
	    then                                                                      \
	        echo "  ✗ $$pkg — clone failed";                                      \
	        rm -rf "$$tmp";                                                       \
	        exit 1;                                                               \
	    fi;                                                                       \
	    rm -rf "packages/$$pkg";                                                  \
	    if [ -d "$$tmp/src" ]; then                                               \
	        mv "$$tmp/src" "packages/$$pkg";                                      \
	    else                                                                      \
	        mv "$$tmp" "packages/$$pkg";                                          \
	    fi;                                                                       \
	    rm -rf "$$tmp";                                                           \
	done
	@echo "Stdlib bootstrap complete: $$(ls packages | wc -l) packages"

# Convenience: wipe + re-fetch the entire stdlib.
bootstrap-stdlib-clean:
	rm -rf packages
	$(MAKE) bootstrap-stdlib

# Regenerate `docs/stdlib/*.md` from the in-source `---` docstrings
# in `packages/*/*.quirk`. Run after touching any stdlib docstring or
# refreshing the bootstrap. Requires Python 3.
docs:
	@python3 tools/gen_stdlib_docs.py

# Mutation-based compiler fuzzer (tools/fuzz.py). Picks random files
# from tests/probes + tests/, mutates them (operator/literal/type
# swaps, line drops/dups/swaps), runs the result, and saves any
# crash (SIGSEGV / ICE / malformed IR) under tools/fuzz_findings/.
# Use after touching Sema or Codegen — surfaces the next class of
# input the compiler can't handle gracefully.
#
#   make fuzz                                  # 500 iters
#   make fuzz FUZZ_ITERS=2000 FUZZ_SEED=42      # reproducible
FUZZ_ITERS ?= 500
FUZZ_SEED  ?=
fuzz:
	@python3 tools/fuzz.py --iters $(FUZZ_ITERS) $(if $(FUZZ_SEED),--seed $(FUZZ_SEED),) --quiet

.PHONY: all clean test bootstrap-stdlib bootstrap-stdlib-clean docs fuzz
