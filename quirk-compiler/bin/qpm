#!/usr/bin/env python3
import sys
import os
import shutil

# In a real scenario, this would fetch from a central registry or Git
# For now, we simulate installing a local "test-pkg"
REGISTRY_URL = "https://packages.quirk-lang.org/" 

def install(package_name):
    # 1. Detect Environment
    quirk_home = os.environ.get("QUIRK_HOME")
    if not quirk_home:
        # Fallback: Try to find a local .venv folder
        if os.path.exists(".venv"):
            quirk_home = os.path.abspath(".venv")
        else:
            print("Error: No virtual environment active.")
            print("Run 'source .venv/bin/activate' or create one with 'quirk -m venv'")
            sys.exit(1)

    # Convert "math.vectors" -> "math/vectors" logic if packages are structured that way
    # Or just install top-level packages: "requests" -> ".venv/lib/quirk/packages/requests"
    target_dir = os.path.join(quirk_home, "lib", "quirk", "packages", package_name)
    
    if os.path.exists(target_dir):
        print(f"Package '{package_name}' is already installed.")
        return

    print(f"Installing {package_name} into {target_dir}...")

    try:
        # 2. Simulate Download (Create dummy package for testing)
        os.makedirs(target_dir, exist_ok=True)
        
        # Create a dummy __init.qk file to prove it works
        with open(os.path.join(target_dir, "__init.qk"), "w") as f:
            f.write(f"// Package: {package_name}\n")
            f.write(f"define info() {{ print(\"Package {package_name} is working!\") }}\n")
            
        print("Successfully installed.")
        
    except Exception as e:
        print(f"Installation failed: {e}")

if __name__ == "__main__":
    if len(sys.argv) < 3 or sys.argv[1] != "install":
        print("Usage: qpm install <package_name>")
        sys.exit(1)
        
    install(sys.argv[2])