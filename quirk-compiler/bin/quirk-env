#!/bin/bash

# Usage: ./bin/quirk-env .venv
VENV_NAME=${1:-.venv}
VENV_DIR="$PWD/$VENV_NAME"

# Ensure we are running from the project root
if [ ! -f "Makefile" ]; then
    echo "Error: Please run this script from the project root (where Makefile is)."
    exit 1
fi

if [ -d "$VENV_NAME" ]; then
    echo "Note: Directory '$VENV_NAME' already exists. Updating..."
else
    echo "Creating virtual environment in $VENV_NAME..."
    mkdir -p "$VENV_NAME/bin"
    # We create the parent 'quirk' folder to hold all libraries
    mkdir -p "$VENV_NAME/lib/quirk/packages"
fi

# ---------------------------------------------------------
# 1. Symlink the Compiler
# ---------------------------------------------------------
COMPILER_SRC="$PWD/bin/quirk"

if [ -f "$COMPILER_SRC" ]; then
    echo "  -> Linking compiler binary..."
    ln -sf "$COMPILER_SRC" "$VENV_NAME/bin/quirk"
else
    echo "Warning: '$COMPILER_SRC' not found."
    echo "         Run 'make' to build the compiler, then re-run this script."
fi

# ---------------------------------------------------------
# 2. Copy ALL Standard Libraries (Core, Math, IO, etc.)
# ---------------------------------------------------------
# CHANGE: Point to the parent 'libs' folder, not 'libs/core'
LIBS_SRC="./libs" 

if [ -d "$LIBS_SRC" ]; then
    echo "  -> Installing standard libraries..."
    # Copy everything inside libs/ (core, math, io) into .venv/lib/quirk/
    cp -r "$LIBS_SRC"/* "$VENV_NAME/lib/quirk/"
else
    echo "Warning: '$LIBS_SRC' not found. Standard libraries will be missing."
fi

# ---------------------------------------------------------
# 3. Generate Activation Script
# ---------------------------------------------------------
echo "  -> Generating activation script..."

cat <<EOF > "$VENV_NAME/bin/activate"
# This script must be sourced, not run!

# 1. Save old state
if [ -z "\$_OLD_QUIRK_PATH" ]; then
    export _OLD_QUIRK_PATH="\$PATH"
fi

if [ -z "\$_OLD_QUIRK_PS1" ]; then
    export _OLD_QUIRK_PS1="\$PS1"
fi

# 2. Set Environment Variables
export QUIRK_HOME="$VENV_DIR"
export PATH="\$QUIRK_HOME/bin:\$PATH"

# 3. Update Prompt to (.venv)
VENV_PROMPT="($VENV_NAME) "
if [ -n "\$PS1" ]; then
    export PS1="\$VENV_PROMPT\$PS1"
fi

# 4. Define 'deactivate' function
deactivate() {
    # Restore PATH
    if [ -n "\$_OLD_QUIRK_PATH" ]; then
        export PATH="\$_OLD_QUIRK_PATH"
        unset _OLD_QUIRK_PATH
    fi

    # Restore Prompt
    if [ -n "\$_OLD_QUIRK_PS1" ]; then
        export PS1="\$_OLD_QUIRK_PS1"
        unset _OLD_QUIRK_PS1
    fi

    unset QUIRK_HOME
    unset -f deactivate

    echo "Quirk environment deactivated."
}

# Feedback
# echo "Quirk environment ($VENV_NAME) activated."
EOF

echo "Done! Run 'source $VENV_NAME/bin/activate' to start."