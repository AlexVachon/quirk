from .base use { Exception }

struct TypeError : Exception {
    define __init(self, message: String) -> void {
        super().__init(message)
        self.type = "TypeError"
    }
}

struct SocketError : Exception {
    define __init(self, message: String) -> void {
        super().__init(message)
        self.type = "SocketError"
    }
}