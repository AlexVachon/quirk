                        }
                    }
                    case _ => {}
                }
            }
            if is_method {
                return _gen_method_call(cg, c)
            }
            name := ""
            if rewritten_name != "" {
                name = rewritten_name
            } else {
                match c.callee {
                    case Ident as id => name = id.name
                    case _ => name = "<bad-callee>"
