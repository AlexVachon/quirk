---
Quirk codegen in Quirk — Phase 4 of self-hosting.

Walks the typed AST (parser output + sema validation upstream)
and emits LLVM IR as text. The result is a `.ll` string that
`lli-14` can execute directly, or `llc-14 → clang` can lower to
a native binary.

Why text IR instead of FFI'ing to LLVM's C API:

  - The C API has hundreds of entry points and a brittle ownership
    model. Binding all of it from Quirk would be larger than the
    codegen itself.
  - Text IR is human-readable, so diffing the Quirk-emitted output
    against the C++ compiler's `--emit-ir` output is the natural
    bootstrap check.
  - Rust + Swift both started here. We can graduate to JIT/FFI
    later when there's a real perf reason.

Phase 4 coverage:

  - `define name(p1: Int, p2: Int, ...) -> Int { ... }`
  - Integer literals, identifiers, function calls
  - `+`, `-`, `*`, `/` on Int (signed)
  - `:=` and `=` for Int-typed locals (SSA-style — no allocas yet)
  - `return <expr>`

Deferred:

  - String type (needs global constants + i8* threading)
  - Bool / Double / null
  - Control flow (if/while/for → basic-block emission + φ nodes)
  - Struct / Tuple / List / Map types
---

from .ast use { Expr, Stmt, Param, FunctionDecl, TopLevel }
from .ast use { IntLit, FloatLit, StringLit, BoolLit, NullLit, Ident, UnaryOp, BinOp, Call, FieldGet, ListLit, Index, Lambda }
from .ast use { Return, ExprStmt, VarDecl, Assign, FieldSet, If, While, Continue, Break, Match, ForIn, Throw, TryCatch, IndexSet, Func, StructTL, EnumTL, UnionTL }
from .ast use { StructField, StructDecl, EnumDecl, MatchArm, Variant, UnionDecl }

---
Module-level codegen state. Right now its only job is the
string-literal pool: each unique literal becomes a private
constant global with a fresh `.str.N` name, and the module-
header emit walks the pool to declare them all up front. As we
add more cross-function global needs (e.g. external decls for
runtime helpers), they accumulate here too.

`globals` collects fully-emitted lines verbatim — each entry
is a complete `@name = ... constant ...` declaration ready to
splice into the module header. `decls` collects helper
`declare` lines (printf / puts / etc.) — kept separate so we
can dedup by helper name.
---
// Re-encode a string's raw bytes for LLVM IR's `c"..."`
// constant form. Bytes that need escaping become `\HH` (two
// hex digits); everything else passes through literally. The
// lexer already decoded source escapes into their byte
// values, so this only handles the small set of bytes that
// can't appear inside a `c"..."` verbatim — newline, tab,
// CR, the double-quote and backslash themselves.
define _llvm_encode_string(text: String) -> String {
    out := ""
    i := 0
    while i < text.length() {
        ch := text.substring(i, i + 1)
        if ch == "\n" {
            out = out + "\\0A"
        } elif ch == "\t" {
            out = out + "\\09"
        } elif ch == "\r" {
            out = out + "\\0D"
        } elif ch == "\"" {
            out = out + "\\22"
        } elif ch == "\\" {
            out = out + "\\5C"
        } else {
            out = out + ch
        }
        i = i + 1
    }
    return out
}

// Source-level Quirk type name → LLVM type, **for primitives
// only**. User-defined struct types must go through
// `_resolve_ty(mod, qty)` because the lookup requires the
// module's struct registry. This helper stays primitive-only
// so callers that don't have a ModuleCG handy (e.g.
// `_expr_static_ty` short-circuiting on literals) can still
// use it.
define _q_ty_to_llvm(qty: String) -> String {
    if qty == "Int"    { return "i32" }
    if qty == "Bool"   { return "i1" }
    if qty == "Double" { return "double" }
    if qty == "String" { return "i8*" }
    // `Any` is an opaque heap pointer — used for `_handle: Any`
    // FFI fields, Map values, List<Any> elements. All flow as
    // i8* at the LLVM level; downcasts happen at use sites
    // through VarDecl annotation honoring.
    if qty == "Any"    { return "i8*" }
    // Bare `List` defaults to the pointer-element layout
    // `%QListP* = { i32 length, i32 capacity, i8** data }`.
    // For Int-element storage, use the explicit `List<Int>`
    // annotation which routes to `%QList*`.
    if qty == "List"   { return "%QListP*" }
    // `Map` value is a `%QMap*` — header `{ length, capacity,
    // %QMapKV* entries }` with the entry array separately
    // malloc'd so .put can realloc on growth. Keys are i8*
    // (String); values are i8* (Any heap pointer, downcast
    // by VarDecl annotation honoring).
    if qty == "Map"    { return "%QMap*" }
    // Generic list annotation `List<T>`. `List<Int>` is the
    // i32-element list (%QList*); any other parameter is
    // pointer-element (%QListP*).
    if qty.startswith("List<") and qty.endswith(">") {
        inner := qty.substring(5, qty.length() - 1)
        if inner == "Int" { return "%QList*" }
        return "%QListP*"
    }
    // Single-letter uppercase type names — `T`, `E`, `A`,
    // `B`, `K`, `V` — are almost always erased generic params.
    // Treat as i8* so generic-typed fields/params/locals lay
    // out as heap pointers rather than i32 ordinals. Multi-
    // letter unknowns still fall through to the i32 default
    // (which is wrong for stdlib heap types like Exception
    // but matches what selfhost code expects elsewhere).
    if qty.length() == 1 {
        c := qty.substring(0, 1)
        if c >= "A" and c <= "Z" {
            return "i8*"
        }
    }
    return "i32"
}

// Resolve any source-level type name to an LLVM type using
// the module's struct + enum + union registries. A registered
// struct or union name `Foo` maps to `%struct.Foo*` (heap
// pointer with the tag at offset 0 for unions); a registered
// enum `K` maps to `i32` (the variant ordinal IS the value).
// Union takes priority over struct because the pre-pass also
// registers a struct named after the union for the shared
// `{ tag }` prefix layout.
define _resolve_ty(mod: ModuleCG, qty: String) -> String {
    if mod.unions.has(qty)  { return "%struct." + qty + "*" }
    if mod.structs.has(qty) { return "%struct." + qty + "*" }
    if mod.enums.has(qty)   { return "i32" }
    // Variant name used as a type annotation: resolves to the
    // synthetic `T__V` struct pointer (same shape match-arm
    // binders use).
    if mod.variants.has(qty) {
        vci: _VarCgInfo := mod.variants.get(qty)
        return "%struct." + vci.union_name + "__" + qty + "*"
    }
    return _q_ty_to_llvm(qty)
}

// Variant codegen metadata. `tag` is the discriminator
// ordinal (variant's position in the union's variant list);
// the synthetic `T__V` struct that holds the variant's
// fields lives in `mod.structs` under that name.
struct _VarCgInfo {
    union_name: String
    tag: Int
    define __init(self, union_name: String, tag: Int) -> void {
        self.union_name = union_name
        self.tag = tag
    }
}

// Function signature record kept in ModuleCG.sigs. `param_tys`
// is a List of LLVM type strings; `ret_ty` is the LLVM return
// type. Populated by emit_module's pre-pass so call-site
// codegen can render the right param + return types without
// having to know each function's body order.
struct _Sig {
    param_tys: List
    ret_ty: String
    define __init(self, param_tys: List, ret_ty: String) -> void {
        self.param_tys = param_tys
        self.ret_ty = ret_ty
    }
}

// Per-struct codegen metadata. `field_names` / `field_llvm_tys`
// are aligned by index — the positional constructor stores
// each arg into the GEP at its index. Stored in ModuleCG.structs
// so call-site codegen and field-access codegen share a single
// source of truth.
struct _StructDef {
    name: String
    field_names: List
    field_llvm_tys: List
    define __init(self, name: String, field_names: List, field_llvm_tys: List) -> void {
        self.name = name
        self.field_names = field_names
        self.field_llvm_tys = field_llvm_tys
    }
}

struct ModuleCG {
    globals: List
    decls: Map
    next_str: Int
    sigs: Map
    // name → _StructDef. Populated by emit_module's pre-pass
    // before any function body codegen runs so constructor and
    // field-access lowering can reach forward.
    structs: Map
    // name → EnumDecl. Variant access `Name.Variant` lowers to
    // an i32 ordinal looked up by walking the variants list;
    // the enum-typed value at runtime is just the ordinal.
    enums: Map
    // name → UnionDecl. Tagged unions: each variant becomes a
    // synthetic struct `T__V` in `structs`; the union value is
    // a `%struct.T*` heap pointer with the tag at offset 0.
    unions: Map
    // variantName → _VarCgInfo. Lets `_gen_call` recognise
    // `V(args)` and route to the variant-ctor lowering.
    variants: Map
    // Lifted lambda bodies — top-level functions emitted at
    // the END of emit_module so they don't interrupt the
    // currently-being-emitted enclosing function.
    lambda_bodies: List
    next_lambda: Int

    define __init(self) -> void {
        self.globals = List()
        self.decls = Map()
        self.next_str = 0
        self.sigs = Map()
        self.structs = Map()
        self.enums = Map()
        self.unions = Map()
        self.variants = Map()
        self.lambda_bodies = List()
        self.next_lambda = 0
    }

    // Register a struct's layout. The `%struct.Name = type {...}`
    // declaration is rendered by render_header in registration
    // order so dependent code (constructor + field GEPs) can
    // reference the type by name.
    define register_struct(self, sd: _StructDef) -> void {
        self.structs.put(sd.name, sd)
    }

    // Register a user-defined function's signature so call-site
    // codegen can render typed args and a typed call. Called
    // by emit_module's pre-pass before any body codegen runs.
    // First-wins: skip if name already registered. Matches the
    // emit_module dedup behaviour — same function declaration
    // both registers a sig and gets emitted, so call sites
    // can't see a signature that doesn't match the IR symbol.
    define register_sig(self, name: String, sig: _Sig) -> void {
        if self.sigs.has(name) { return }
        self.sigs.put(name, sig)
    }

    // Allocate a private string constant. `text` holds the
    // decoded byte sequence (lexer has already folded `\n` /
    // `\t` / `\\` / `\"` into their literal bytes). Returns
    // the LLVM name `@.str.N` so callers can refer to it via
    // a getelementptr. The byte count for the `[N x i8]`
    // type uses the decoded length — IR's `\HH` escapes each
    // represent a single byte regardless of source width.
    define alloc_string(self, text: String) -> String {
        name := "@.str." + self.next_str.str()
        self.next_str = self.next_str + 1
        n := text.length() + 1
        encoded := _llvm_encode_string(text)
        line := name + " = private unnamed_addr constant [" + n.str() +
                " x i8] c\"" + encoded + "\\00\""
        self.globals.append(line)
        return name
    }

    define ensure_decl(self, key: String, line: String) -> void {
        if self.decls.has(key) { return }
        self.decls.put(key, line)
    }

    define render_header(self) -> String {
        // List-accumulator + `_str_join` at the end. Was a
        // classic `out = out + line` loop with N×decls + N×
        // structs + N×globals iterations, which became
        // O(total_chars × N) when the bundled stdlib pushed
        // each list into the dozens-of-entries range.
        parts := List()
        // Internal list-header type. `{ length, capacity,
        // i32* data }` — the data array lives in its own
        // allocation so `.append` can `realloc` the buffer
        // without invalidating the header pointer that callers
        // hold. Always emitted (cheap, and avoids a "used a
        // list?" tracking flag); LLVM's verifier accepts unused
        // type defs.
        parts.append("%QList = type { i32, i32, i32* }\n")
        // Pointer-element list. Same shape as %QList but the
        // data buffer holds i8* slots. `List<T>` where T is
        // anything other than `Int` resolves to this type;
        // bare `List` annotation defaults to %QList (i32).
        parts.append("%QListP = type { i32, i32, i8** }\n")
        // Internal map types. `%QMapKV` is a single key/value
        // pair (both i8*); `%QMap` is the header — length,
        // capacity, and a pointer to the entry array. Linear
        // scan on lookup; fine for the small per-scope tables
        // selfhost uses.
        parts.append("%QMapKV = type { i8*, i8* }\n")
        parts.append("%QMap = type { i32, i32, %QMapKV* }\n\n")
        // %struct.Name type defs first so subsequent globals /
        // function signatures can reference them by name.
        snames := self.structs.keys()
        si := 0
        while si < snames.length() {
            sname: String := snames.__get(si)
            sd: _StructDef := self.structs.get(sname)
            line_parts := List()
            line_parts.append("%struct.")
            line_parts.append(sd.name)
            line_parts.append(" = type { ")
            fi := 0
            while fi < sd.field_llvm_tys.length() {
                if fi > 0 { line_parts.append(", ") }
                ft: String := sd.field_llvm_tys.__get(fi)
                line_parts.append(ft)
                fi = fi + 1
            }
            line_parts.append(" }\n")
            parts.append(_str_join(line_parts))
            si = si + 1
        }
        if snames.length() > 0 { parts.append("\n") }
        i := 0
        while i < self.globals.length() {
            line: String := self.globals.__get(i)
            parts.append(line)
            parts.append("\n")
            i = i + 1
        }
        if self.globals.length() > 0 { parts.append("\n") }
        keys := self.decls.keys()
        j := 0
        while j < keys.length() {
            k: String := keys.__get(j)
            line: String := self.decls.get(k)
            parts.append(line)
            parts.append("\n")
            j = j + 1
        }
        if keys.length() > 0 { parts.append("\n") }
        return _str_join(parts)
    }
}

---
Codegen state per-function. Two output buffers — `entry_out`
holds the allocas at function entry, `out` holds the body
instructions and labels. We concatenate the two at the end so
allocas always sit before their first use (LLVM domination
rule). `next_reg` is the monotonic SSA counter; `next_label` is
the monotonic basic-block label counter for branches. `locals`
maps Quirk variable names to their alloca slot's SSA pointer
name (e.g. `x` → `%x.addr`). `mod` points back at the
module-level state for string-literal interning + runtime
helper declarations.
---
struct FnCG {
    entry_out: List
    // out / entry_out are List<String> (each element is one
    // line of IR, including its trailing "\n") to avoid the
    // O(N²) string-accumulation pattern. Final flatten happens
    // via the `_str_join` builtin in `_gen_function`. Before
    // this refactor the standalone selfhost binary used ~4 GB
    // of RAM when compiling its own ~50K-line IR output;
    // afterward it's bounded by total IR size (~5-10 MB).
    out: List
    next_reg: Int
    next_label: Int
    locals: Map
    block_terminated: Bool
    mod: ModuleCG
    // LLVM return type of the function currently being lowered.
    // Set by _gen_function before the body runs so `Return`
    // statements and the synthetic fall-through terminator can
    // emit the matching `ret <ty>` instruction.
    ret_ty: String
    // Loop-label stacks (parallel `List<String>`). `loop_head`
    // is the target of `continue` (the cond-check block);
    // `loop_end` is the target of `break` (the post-loop join).
    // While codegen pushes on entry and pops on exit so nested
    // loops route through the innermost.
    loop_head: List
    loop_end: List

    define __init(self, m: ModuleCG) -> void {
        self.entry_out = List()
        self.out = List()
        self.next_reg = 0
        self.next_label = 0
        self.locals = Map()
        self.block_terminated = false
        self.mod = m
        self.ret_ty = "i32"
        self.loop_head = List()
        self.loop_end = List()
    }

    define fresh(self) -> String {
        r := "%" + self.next_reg.str()
        self.next_reg = self.next_reg + 1
        return r
    }

    define fresh_label(self, prefix: String) -> String {
        n := self.next_label
        self.next_label = n + 1
        return prefix + "." + n.str()
    }

    define emit(self, line: String) -> void {
        // Suppress dead code after a terminator. Without this,
        // a `return` followed by anything else (or the
        // unconditional `ret i32 0` fall-through after every
        // block) emits unreachable IR that fails strict
        // verification.
        if self.block_terminated { return }
        self.out.append("  " + line + "\n")
        // `ret` / `br` / `unreachable` mark the block as
        // terminated. We check for the first token of the
        // line — anything else is a normal instruction.
        if line.startswith("ret ") or line.startswith("br ") or line == "unreachable" {
            self.block_terminated = true
        }
    }

    // Raw — no leading indent. Used for basic-block labels and
    // explicit `br` lines that should align flush-left in IR.
    // Labels reopen the block, so emitting one clears the
    // terminated flag.
    define emit_raw(self, line: String) -> void {
        self.out.append(line + "\n")
        // A label line (`some.label.0:`) opens a fresh block,
        // so prior terminator status no longer applies.
        if line.endswith(":") {
            self.block_terminated = false
        }
    }

    define emit_entry(self, line: String) -> void {
        self.entry_out.append("  " + line + "\n")
    }
}

// -----------------------------------------------------------------
// Expression codegen — returns the SSA reg/literal holding the value.
// -----------------------------------------------------------------

define _gen_expr(cg: FnCG, e: Expr) -> String {
    match e {
        case IntLit as lit => {
            // Literal flows inline as `i32 N` at the use site.
            return lit.value.str()
        }
        case BoolLit as bl => {
            if bl.value { return "1" }
            return "0"
        }
        case FloatLit as fl => {
            // Pass the textual literal through to LLVM. The IR
            // parser accepts decimal forms (`3.14`, `1.0`, `0.5`)
            // and converts them to IEEE-754 internally. Hex
            // form (`0x4009...`) would be needed for values
            // that don't round-trip, but the corpus today is
            // small exact-decimal values only.
            return fl.value
        }
        case StringLit as sl => {
            // Intern the literal as a `[N x i8]*` global, then
            // GEP it to an `i8*` value that flows like any
            // other scalar. The resulting i8* can be stored in
            // an alloca slot (for `s := "hello"`), passed as a
            // call argument (`print(s)`, user-defined String
            // params), or returned from a String-returning
            // function. Phase 4.3 only handled the inlined
            // `print(StringLit)` form; this case generalises it.
            str_name := cg.mod.alloc_string(sl.value)
            str_len := sl.value.length() + 1
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds [" + str_len.str() +
                    " x i8], [" + str_len.str() + " x i8]* " +
                    str_name + ", i64 0, i64 0")
            return gep
        }
        case Ident as id => {
            if cg.locals.has(id.name) {
                holder: _Slot := cg.locals.get(id.name)
                // Locals live in alloca slots. Read = `load`
                // through the slot pointer; LLVM's mem2reg
                // pass collapses these to SSA + phi at -O1.
                // The slot's stored type (`i1` for Bool, `i32`
                // for Int) must match the load instruction.
                reg := cg.fresh()
                cg.emit(reg + " = load " + holder.ty + ", " + holder.ty + "* " + holder.name)
                return reg
            }
            // Unknown identifier (not a local, not a function
            // name, not a module). Stdlib bundling can pull in
            // code that references identifiers selfhost's sema
            // resolves to TAny but codegen can't actually look
            // up. Emit `0` rather than placeholder text — the
            // IR validates and the program reaches the link
            // stage. Runtime behaviour is meaningless if the
            // reference is actually live, but most occurrences
            // are dead code or guarded.
            return "0"
        }
        case ListLit as ll => {
            // Extracted helper — keeps the inner recursive
            // _gen_expr (per element) in its own function so
            // the same self-compiler gap as _gen_struct_ctor
            // doesn't fire from coexisting with the other
            // recursive arms here.
            return _gen_list_lit(cg, ll.elems)
        }
        case Index as ix => {
            // Load the data pointer from the list's field 2,
            // GEP by the i32 index, then load. The header and
            // data buffer are separate allocations (Phase 4.15+)
            // so we can't reach the element via a single GEP.
            // Dispatch on receiver type: %QList* uses i32
            // storage, %QListP* uses i8* storage; %QMap* gets
            // a method-style `.get` call; %struct.String*
            // unwraps to the buffer + byte-load (single-char
            // indexing).
            base_ty := _expr_static_ty(cg, ix.obj)
            base_reg := _gen_expr(cg, ix.obj)
            // Map indexing `m[key]` → equivalent of `m.get(key)`.
            // Route through the existing inline Map.get codegen
            // rather than calling the runtime stdlib helper —
            // selfhost's %QMap struct layout differs from the
            // runtime's %struct.Map and the two ABIs are not
            // interchangeable. Skip pre-evaluating ix.idx;
            // _gen_map_method does its own arg gen.
            if base_ty == "%QMap*" {
                map_args := List()
                map_args.append(ix.idx)
                return _gen_map_method(cg, "get", base_reg, map_args)
            }
            idx_reg := _gen_expr(cg, ix.idx)
            // String indexing `s[i]` → byte-load.
            if base_ty == "i8*" or base_ty == "%struct.String*" {
                buf := base_reg
                if base_ty == "%struct.String*" {
                    gep := cg.fresh()
                    cg.emit(gep + " = getelementptr inbounds %struct.String, %struct.String* " + base_reg + ", i32 0, i32 0")
                    bufreg := cg.fresh()
                    cg.emit(bufreg + " = load i8*, i8** " + gep)
                    buf = bufreg
                }
                idx_ty2 := _expr_static_ty(cg, ix.idx)
                idx64 := idx_reg
                if idx_ty2 == "i32" {
                    s64 := cg.fresh()
                    cg.emit(s64 + " = sext i32 " + idx_reg + " to i64")
                    idx64 = s64
                }
                ch_gep := cg.fresh()
                cg.emit(ch_gep + " = getelementptr inbounds i8, i8* " + buf + ", i64 " + idx64)
                ch := cg.fresh()
                cg.emit(ch + " = load i8, i8* " + ch_gep)
                ext := cg.fresh()
                cg.emit(ext + " = zext i8 " + ch + " to i32")
                return ext
            }
            if base_ty == "%QListP*" {
                data_gep := cg.fresh()
                cg.emit(data_gep + " = getelementptr inbounds %QListP, %QListP* " + base_reg +
                        ", i32 0, i32 2")
                data_ptr := cg.fresh()
                cg.emit(data_ptr + " = load i8**, i8*** " + data_gep)
                elem_gep := cg.fresh()
                cg.emit(elem_gep + " = getelementptr inbounds i8*, i8** " + data_ptr +
                        ", i32 " + idx_reg)
                reg := cg.fresh()
                cg.emit(reg + " = load i8*, i8** " + elem_gep)
                return reg
            }
            data_gep := cg.fresh()
            cg.emit(data_gep + " = getelementptr inbounds %QList, %QList* " + base_reg +
                    ", i32 0, i32 2")
            data_ptr := cg.fresh()
            cg.emit(data_ptr + " = load i32*, i32** " + data_gep)
            elem_gep := cg.fresh()
            cg.emit(elem_gep + " = getelementptr inbounds i32, i32* " + data_ptr +
                    ", i32 " + idx_reg)
            reg := cg.fresh()
            cg.emit(reg + " = load i32, i32* " + elem_gep)
            return reg
        }
        case FieldGet as fg => {
            // Enum-variant access: `TokenKind.Identifier`. The
            // receiver is an Ident matching a registered enum;
            // the result is the variant's ordinal as a literal
            // i32 — no GEP, no load.
            match fg.obj {
                case Ident as enum_id => {
                    if cg.mod.enums.has(enum_id.name) {
                        ed: EnumDecl := cg.mod.enums.get(enum_id.name)
                        vi := 0
                        while vi < ed.variants.length() {
                            vn: String := ed.variants.__get(vi)
                            if vn == fg.name { return vi.str() }
                            vi = vi + 1
                        }
                        return "0"
                    }
                }
                case _ => {}
            }
            // Struct field access: GEP + load.
            obj_ty := _expr_static_ty(cg, fg.obj)
            obj_reg := _gen_expr(cg, fg.obj)
            sname := _strip_struct_ptr(obj_ty)
            // Permissive: unknown struct names (stdlib's
            // `Exception`, `AssertionError`, etc., or generic
            // `Any`-typed receivers) — return `null` i8*. The
            // resulting IR is wrong if the value is actually
            // used, but parses + lowers without the SIGSEGV
            // that the previous .get() + null-deref produced.
            if cg.mod.structs.has(sname) == false {
                return "null"
            }
            sd: _StructDef := cg.mod.structs.get(sname)
            // Empty struct or unknown field — mirror the
            // _gen_field_set guard. Return null/0 rather than
            // emit a bogus GEP at index 0.
            if sd.field_names.length() == 0 {
                return "null"
            }
            idx := 0
            fg_found := false
            field_ty := "i32"
            fi := 0
            while fi < sd.field_names.length() {
                fname: String := sd.field_names.__get(fi)
                if fname == fg.name {
                    idx = fi
                    field_ty = sd.field_llvm_tys.__get(fi)
                    fg_found = true
                }
                fi = fi + 1
            }
            // Unknown field on a known non-empty struct — same
            // permissive case as the empty-struct branch above.
            // Return null so callers don't deref a bogus GEP.
            if fg_found == false { return "null" }
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds %struct." + sname +
                    ", %struct." + sname + "* " + obj_reg +
                    ", i32 0, i32 " + idx.str())
            reg := cg.fresh()
            cg.emit(reg + " = load " + field_ty + ", " + field_ty + "* " + gep)
            return reg
        }
        case UnaryOp as u => {
            opd_ty := _expr_static_ty(cg, u.operand)
            v := _gen_expr(cg, u.operand)
            if u.op == "-" {
                // Integer: `sub nsw i32 0, x` is the standard
                // negation idiom (LLVM has no dedicated `neg`).
                // Double: LLVM 14 has a real `fneg double`.
                reg := cg.fresh()
                if opd_ty == "double" {
                    cg.emit(reg + " = fneg double " + v)
                } else {
                    cg.emit(reg + " = sub nsw i32 0, " + v)
                }
                return reg
            }
            if u.op == "not" {
                // `not` operates on i1. The operand came from
                // a comparison or another `not`, so it's
                // already i1. `xor i1 b, 1` is the idiom for
                // logical negation.
                reg := cg.fresh()
                cg.emit(reg + " = xor i1 " + v + ", 1")
                return reg
            }
            return "0"
        }
        case BinOp as b => {
            // Arithmetic vs comparison split on operator: the
            // former returns the operand type (i32 / double /
            // i8*), the latter returns i1. Operand type is taken
            // from the left side — sema has already required
            // both sides to agree.
            opd_ty := _expr_static_ty(cg, b.left)
            is_dbl := opd_ty == "double"
            // %struct.String* operand from stdlib calls (e.g.
            // `prefix()` returning the typed String pointer):
            // treat as i8* for concat purposes. The actual
            // c-string lives at field 0 of the struct, but
            // existing stdlib calls happen to return values
            // that, when passed through strlen-on-i8*, would
            // crash — for now we extract the buffer field.
            rt_check := _expr_static_ty(cg, b.right)
            if b.op == "+" and (opd_ty == "%struct.String*" or rt_check == "%struct.String*") {
                opd_ty = "i8*"
            }
            // String concat: `+` on two i8* operands. Lower to
            // malloc(strlen(a) + strlen(b) + 1) + strcpy + strcat,
            // and return the malloc'd buffer. The result leaks
            // — the self-hosted compiler is short-lived enough
            // that explicit free / a GC layer can wait.
            if b.op == "+" and opd_ty == "i8*" {
                l_ty := _expr_static_ty(cg, b.left)
                r_ty := _expr_static_ty(cg, b.right)
                l := _gen_expr(cg, b.left)
                r := _gen_expr(cg, b.right)
                // %struct.String* → i8* by extracting buffer (field 0).
                if l_ty == "%struct.String*" {
                    gepl := cg.fresh()
                    cg.emit(gepl + " = getelementptr inbounds %struct.String, %struct.String* " + l + ", i32 0, i32 0")
                    lbuf := cg.fresh()
                    cg.emit(lbuf + " = load i8*, i8** " + gepl)
                    l = lbuf
                }
                if r_ty == "%struct.String*" {
                    gepr := cg.fresh()
                    cg.emit(gepr + " = getelementptr inbounds %struct.String, %struct.String* " + r + ", i32 0, i32 0")
                    rbuf := cg.fresh()
                    cg.emit(rbuf + " = load i8*, i8** " + gepr)
                    r = rbuf
                }
                // Coerce literal-zero operands to `null` — the
                // bad-method codegen fallback emits `0` (typed
                // as the slot expects) but downstream string
                // concat assumes i8* pointers. Without this swap
                // we get `strlen(i8* 0)` which llc rejects.
                if l == "0" { l = "null" }
                if r == "0" { r = "null" }
                // Non-string scalar operands (Int / Double / Bool)
                // get stringified through `_gen_to_string` —
                // libc snprintf into a fresh 32-byte buffer.
                // Without this, `s + 100` (where 100 is i32) or
                // `s + vec.x` (Double) emits `strlen(i8* 100)` /
                // `strlen(i8* %dbl)` which llc rejects.
                if l_ty == "i32" or l_ty == "double" or l_ty == "i1" {
                    l = _gen_to_string(cg, l, l_ty)
                }
                if r_ty == "i32" or r_ty == "double" or r_ty == "i1" {
                    r = _gen_to_string(cg, r, r_ty)
                }
                cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
                cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
                cg.mod.ensure_decl("strcpy", "declare i8* @strcpy(i8*, i8*)")
                cg.mod.ensure_decl("strcat", "declare i8* @strcat(i8*, i8*)")
                la := cg.fresh()
                cg.emit(la + " = call i64 @strlen(i8* " + l + ")")
                lb := cg.fresh()
                cg.emit(lb + " = call i64 @strlen(i8* " + r + ")")
                sum := cg.fresh()
                cg.emit(sum + " = add i64 " + la + ", " + lb)
                total := cg.fresh()
                cg.emit(total + " = add i64 " + sum + ", 1")
                buf := cg.fresh()
                cg.emit(buf + " = call i8* @malloc(i64 " + total + ")")
                cpy := cg.fresh()
                cg.emit(cpy + " = call i8* @strcpy(i8* " + buf + ", i8* " + l + ")")
                cat := cg.fresh()
                cg.emit(cat + " = call i8* @strcat(i8* " + buf + ", i8* " + r + ")")
                return buf
            }
            l := _gen_expr(cg, b.left)
            r := _gen_expr(cg, b.right)
            op := b.op
            // Comparison.
            int_pred := ""
            dbl_pred := ""
            if op == "==" { int_pred = "eq"  dbl_pred = "oeq" }
            if op == "!=" { int_pred = "ne"  dbl_pred = "one" }
            if op == "<"  { int_pred = "slt" dbl_pred = "olt" }
            if op == "<=" { int_pred = "sle" dbl_pred = "ole" }
            if op == ">"  { int_pred = "sgt" dbl_pred = "ogt" }
            if op == ">=" { int_pred = "sge" dbl_pred = "oge" }
            if int_pred.length() > 0 {
                // %struct.String* operand on either side — unwrap
                // to the `_buffer` field so the comparison routes
                // through the strcmp/i8* path below. Symmetric
                // to the `+` concat handling above.
                rt_cmp := _expr_static_ty(cg, b.right)
                if opd_ty == "%struct.String*" or rt_cmp == "%struct.String*" {
                    opd_ty = "i8*"
                    if _expr_static_ty(cg, b.left) == "%struct.String*" {
                        gepl_c := cg.fresh()
                        cg.emit(gepl_c + " = getelementptr inbounds %struct.String, %struct.String* " + l + ", i32 0, i32 0")
                        lbuf_c := cg.fresh()
                        cg.emit(lbuf_c + " = load i8*, i8** " + gepl_c)
                        l = lbuf_c
                    }
                    if rt_cmp == "%struct.String*" {
                        gepr_c := cg.fresh()
                        cg.emit(gepr_c + " = getelementptr inbounds %struct.String, %struct.String* " + r + ", i32 0, i32 0")
                        rbuf_c := cg.fresh()
                        cg.emit(rbuf_c + " = load i8*, i8** " + gepr_c)
                        r = rbuf_c
                    }
                }
                // String comparisons — all six predicates
                // route through strcmp. Equality (`==` / `!=`)
                // compares the strcmp result against zero;
                // ordering (`<` / `<=` / `>` / `>=`) uses the
                // signed icmp form against zero too (strcmp's
                // return is sign-bearing). Handled first so
                // the strcmp result reg gets the earlier SSA
                // number — cg.fresh() assigns in call order
                // and emit order must match.
                if opd_ty == "i8*" {
                    // Null-check shortcut: `ptr == 0` / `ptr != 0`
                    // — emit `icmp <pred> i8* %x, null` directly
                    // rather than strcmp. Stdlib idiom for
                    // `option.value == 0` / `if x != 0` guards.
                    if (op == "==" or op == "!=") and (r == "0" or l == "0") {
                        reg := cg.fresh()
                        pred_n := "eq"
                        if op == "!=" { pred_n = "ne" }
                        if l == "0" {
                            cg.emit(reg + " = icmp " + pred_n + " i8* null, " + r)
                        } else {
                            cg.emit(reg + " = icmp " + pred_n + " i8* " + l + ", null")
                        }
                        return reg
                    }
                    // Mixed-kind compare: i8* operand vs a non-
                    // pointer integer literal (e.g. `g == 1`
                    // where g is a backed-enum pointer and 1 is
                    // the ordinal). Inttoptr-promote the literal
                    // so strcmp doesn't crash on a tiny integer
                    // "pointer". The cast is bit-preserving;
                    // strcmp would still misbehave at runtime
                    // but the IR validates.
                    lt_lit := _expr_static_ty(cg, b.left)
                    rt_lit := _expr_static_ty(cg, b.right)
                    if rt_lit == "i32" {
                        promo := cg.fresh()
                        cg.emit(promo + " = inttoptr i32 " + r + " to i8*")
                        r = promo
                    }
                    if lt_lit == "i32" {
                        promo := cg.fresh()
                        cg.emit(promo + " = inttoptr i32 " + l + " to i8*")
                        l = promo
                    }
                    cg.mod.ensure_decl("strcmp", "declare i32 @strcmp(i8*, i8*)")
                    cmp := cg.fresh()
                    cg.emit(cmp + " = call i32 @strcmp(i8* " + l + ", i8* " + r + ")")
                    reg := cg.fresh()
                    pred := "eq"
                    if op == "!=" { pred = "ne" }
                    if op == "<"  { pred = "slt" }
                    if op == "<=" { pred = "sle" }
                    if op == ">"  { pred = "sgt" }
                    if op == ">=" { pred = "sge" }
                    cg.emit(reg + " = icmp " + pred + " i32 " + cmp + ", 0")
                    return reg
                }
                // Bool ==/!= Bool — operate on i1 directly.
                // Ordering ops on Bool stay rejected by sema.
                if opd_ty == "i1" {
                    reg := cg.fresh()
                    pred := "eq"
                    if op == "!=" { pred = "ne" }
                    cg.emit(reg + " = icmp " + pred + " i1 " + l + ", " + r)
                    return reg
                }
                // Pointer null-check `ptr == 0` / `ptr != 0`:
                // stdlib code uses this pervasively (`if x == 0`
                // as a null guard). Lower as `icmp <pred> <ptr-ty>
                // %x, null`. Detected when either operand has a
                // pointer static type and the other is the
                // literal `0`.
                lt2 := _expr_static_ty(cg, b.left)
                rt2 := _expr_static_ty(cg, b.right)
                if (op == "==" or op == "!=") {
                    if _is_ptr_ty(lt2) and r == "0" {
                        reg := cg.fresh()
                        pred_ne := int_pred
                        cg.emit(reg + " = icmp " + pred_ne + " " + lt2 + " " + l + ", null")
                        return reg
                    }
                    if _is_ptr_ty(rt2) and l == "0" {
                        reg := cg.fresh()
                        cg.emit(reg + " = icmp " + int_pred + " " + rt2 + " null, " + r)
                        return reg
                    }
                }
                reg := cg.fresh()
                if is_dbl {
                    cg.emit(reg + " = fcmp " + dbl_pred + " double " + l + ", " + r)
                } else {
                    cg.emit(reg + " = icmp " + int_pred + " i32 " + l + ", " + r)
                }
                return reg
            }
            // Logical and / or — Bool/Bool → Bool, lowered as
            // bitwise `and i1` / `or i1`. Non-short-circuit
            // semantics: both sides eagerly evaluated, fine for
            // selfhost's usage (logical guards on already-computed
            // boolean state). True short-circuit would route
            // through basic blocks + phi.
            if op == "and" or op == "or" {
                reg := cg.fresh()
                cg.emit(reg + " = " + op + " i1 " + l + ", " + r)
                return reg
            }
            // Arithmetic.
            int_instr := "add"
            dbl_instr := "fadd"
            if op == "-" { int_instr = "sub"  dbl_instr = "fsub" }
            if op == "*" { int_instr = "mul"  dbl_instr = "fmul" }
            if op == "/" { int_instr = "sdiv" dbl_instr = "fdiv" }
            if op == "%" { int_instr = "srem" dbl_instr = "frem" }
            // `nsw` (no-signed-wrap) is only valid on add/sub/
            // mul; sdiv/srem/frem reject it.
            int_flag := " nsw"
            if op == "/" or op == "%" { int_flag = "" }
            reg := cg.fresh()
            if is_dbl {
                cg.emit(reg + " = " + dbl_instr + " double " + l + ", " + r)
            } else {
                cg.emit(reg + " = " + int_instr + int_flag + " i32 " + l + ", " + r)
            }
            return reg
        }
        case Call as c => {
            // Method call form: `obj.method(args)` parsed as
            // Call(FieldGet(obj, method), args). Dispatched
            // before the identifier-callee path so the bare
            // `name = "<bad-callee>"` fallthrough never fires
            // for valid method calls.
            is_method := false
            match c.callee { case FieldGet as _ => is_method = true case _ => {} }
            // Module-qualified call `module.fn(args)`: when the
            // FieldGet's object is a free identifier (not a
            // local) and the field name matches a known
            // top-level function, treat this as a direct call
            // to that function. Quirk's module-aliased imports
            // (`from .mod as m`) reach codegen as plain Ident
            // chains since selfhost has no first-class module
            // representation; this rewrite recovers them.
            rewritten_name := ""
            if is_method {
                fg_cb: FieldGet := c.callee
                match fg_cb.obj {
                    case Ident as oid => {
                        if cg.locals.has(oid.name) == false {
                            cb_llvm := _llvm_fn_name(fg_cb.name)
                            if cg.mod.sigs.has(cb_llvm) {
                                rewritten_name = fg_cb.name
                                is_method = false
