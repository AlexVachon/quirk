---
Quirk codegen in Quirk — Phase 4 of self-hosting.

Walks the typed AST (parser output + sema validation upstream)
and emits LLVM IR as text. The result is a `.ll` string that
`lli-14` can execute directly, or `llc-14 → clang` can lower to
a native binary.

Why text IR instead of FFI'ing to LLVM's C API:

  - The C API has hundreds of entry points and a brittle ownership
    model. Binding all of it from Quirk would be larger than the
    codegen itself.
  - Text IR is human-readable, so diffing the Quirk-emitted output
    against the C++ compiler's `--emit-ir` output is the natural
    bootstrap check.
  - Rust + Swift both started here. We can graduate to JIT/FFI
    later when there's a real perf reason.

Phase 4 coverage:

  - `define name(p1: Int, p2: Int, ...) -> Int { ... }`
  - Integer literals, identifiers, function calls
  - `+`, `-`, `*`, `/` on Int (signed)
  - `:=` and `=` for Int-typed locals (SSA-style — no allocas yet)
  - `return <expr>`

Deferred:

  - String type (needs global constants + i8* threading)
  - Bool / Double / null
  - Control flow (if/while/for → basic-block emission + φ nodes)
  - Struct / Tuple / List / Map types
---

from .ast use { Expr, Stmt, Param, FunctionDecl, TopLevel }
from .ast use { IntLit, FloatLit, StringLit, BoolLit, NullLit, Ident, UnaryOp, BinOp, Call, FieldGet, ListLit, Index }
from .ast use { Return, ExprStmt, VarDecl, Assign, FieldSet, If, While, Continue, Break, Match, Func, StructTL, EnumTL, UnionTL }
from .ast use { StructField, StructDecl, EnumDecl, MatchArm, Variant, UnionDecl }

---
Module-level codegen state. Right now its only job is the
string-literal pool: each unique literal becomes a private
constant global with a fresh `.str.N` name, and the module-
header emit walks the pool to declare them all up front. As we
add more cross-function global needs (e.g. external decls for
runtime helpers), they accumulate here too.

`globals` collects fully-emitted lines verbatim — each entry
is a complete `@name = ... constant ...` declaration ready to
splice into the module header. `decls` collects helper
`declare` lines (printf / puts / etc.) — kept separate so we
can dedup by helper name.
---
// Re-encode a string's raw bytes for LLVM IR's `c"..."`
// constant form. Bytes that need escaping become `\HH` (two
// hex digits); everything else passes through literally. The
// lexer already decoded source escapes into their byte
// values, so this only handles the small set of bytes that
// can't appear inside a `c"..."` verbatim — newline, tab,
// CR, the double-quote and backslash themselves.
define _llvm_encode_string(text: String) -> String {
    out := ""
    i := 0
    while i < text.length() {
        ch := text.substring(i, i + 1)
        if ch == "\n" {
            out = out + "\\0A"
        } elif ch == "\t" {
            out = out + "\\09"
        } elif ch == "\r" {
            out = out + "\\0D"
        } elif ch == "\"" {
            out = out + "\\22"
        } elif ch == "\\" {
            out = out + "\\5C"
        } else {
            out = out + ch
        }
        i = i + 1
    }
    return out
}

// Source-level Quirk type name → LLVM type, **for primitives
// only**. User-defined struct types must go through
// `_resolve_ty(mod, qty)` because the lookup requires the
// module's struct registry. This helper stays primitive-only
// so callers that don't have a ModuleCG handy (e.g.
// `_expr_static_ty` short-circuiting on literals) can still
// use it.
define _q_ty_to_llvm(qty: String) -> String {
    if qty == "Bool"   { return "i1" }
    if qty == "Double" { return "double" }
    if qty == "String" { return "i8*" }
    // `Any` is an opaque heap pointer — used for `_handle: Any`
    // FFI fields, Map values, List<Any> elements. All flow as
    // i8* at the LLVM level; downcasts happen at use sites
    // through VarDecl annotation honoring.
    if qty == "Any"    { return "i8*" }
    // Bare `List` defaults to the pointer-element layout
    // `%QListP* = { i32 length, i32 capacity, i8** data }`.
    // For Int-element storage, use the explicit `List<Int>`
    // annotation which routes to `%QList*`.
    if qty == "List"   { return "%QListP*" }
    // `Map` value is a `%QMap*` — header `{ length, capacity,
    // %QMapKV* entries }` with the entry array separately
    // malloc'd so .put can realloc on growth. Keys are i8*
    // (String); values are i8* (Any heap pointer, downcast
    // by VarDecl annotation honoring).
    if qty == "Map"    { return "%QMap*" }
    // Generic list annotation `List<T>`. `List<Int>` is the
    // i32-element list (%QList*); any other parameter is
    // pointer-element (%QListP*).
    if qty.startswith("List<") and qty.endswith(">") {
        inner := qty.substring(5, qty.length() - 1)
        if inner == "Int" { return "%QList*" }
        return "%QListP*"
    }
    return "i32"
}

// Resolve any source-level type name to an LLVM type using
// the module's struct + enum + union registries. A registered
// struct or union name `Foo` maps to `%struct.Foo*` (heap
// pointer with the tag at offset 0 for unions); a registered
// enum `K` maps to `i32` (the variant ordinal IS the value).
// Union takes priority over struct because the pre-pass also
// registers a struct named after the union for the shared
// `{ tag }` prefix layout.
define _resolve_ty(mod: ModuleCG, qty: String) -> String {
    if mod.unions.has(qty)  { return "%struct." + qty + "*" }
    if mod.structs.has(qty) { return "%struct." + qty + "*" }
    if mod.enums.has(qty)   { return "i32" }
    // Variant name used as a type annotation: resolves to the
    // synthetic `T__V` struct pointer (same shape match-arm
    // binders use).
    if mod.variants.has(qty) {
        vci: _VarCgInfo := mod.variants.get(qty)
        return "%struct." + vci.union_name + "__" + qty + "*"
    }
    return _q_ty_to_llvm(qty)
}

// Variant codegen metadata. `tag` is the discriminator
// ordinal (variant's position in the union's variant list);
// the synthetic `T__V` struct that holds the variant's
// fields lives in `mod.structs` under that name.
struct _VarCgInfo {
    union_name: String
    tag: Int
    define __init(self, union_name: String, tag: Int) -> void {
        self.union_name = union_name
        self.tag = tag
    }
}

// Function signature record kept in ModuleCG.sigs. `param_tys`
// is a List of LLVM type strings; `ret_ty` is the LLVM return
// type. Populated by emit_module's pre-pass so call-site
// codegen can render the right param + return types without
// having to know each function's body order.
struct _Sig {
    param_tys: List
    ret_ty: String
    define __init(self, param_tys: List, ret_ty: String) -> void {
        self.param_tys = param_tys
        self.ret_ty = ret_ty
    }
}

// Per-struct codegen metadata. `field_names` / `field_llvm_tys`
// are aligned by index — the positional constructor stores
// each arg into the GEP at its index. Stored in ModuleCG.structs
// so call-site codegen and field-access codegen share a single
// source of truth.
struct _StructDef {
    name: String
    field_names: List
    field_llvm_tys: List
    define __init(self, name: String, field_names: List, field_llvm_tys: List) -> void {
        self.name = name
        self.field_names = field_names
        self.field_llvm_tys = field_llvm_tys
    }
}

struct ModuleCG {
    globals: List
    decls: Map
    next_str: Int
    sigs: Map
    // name → _StructDef. Populated by emit_module's pre-pass
    // before any function body codegen runs so constructor and
    // field-access lowering can reach forward.
    structs: Map
    // name → EnumDecl. Variant access `Name.Variant` lowers to
    // an i32 ordinal looked up by walking the variants list;
    // the enum-typed value at runtime is just the ordinal.
    enums: Map
    // name → UnionDecl. Tagged unions: each variant becomes a
    // synthetic struct `T__V` in `structs`; the union value is
    // a `%struct.T*` heap pointer with the tag at offset 0.
    unions: Map
    // variantName → _VarCgInfo. Lets `_gen_call` recognise
    // `V(args)` and route to the variant-ctor lowering.
    variants: Map

    define __init(self) -> void {
        self.globals = List()
        self.decls = Map()
        self.next_str = 0
        self.sigs = Map()
        self.structs = Map()
        self.enums = Map()
        self.unions = Map()
        self.variants = Map()
    }

    // Register a struct's layout. The `%struct.Name = type {...}`
    // declaration is rendered by render_header in registration
    // order so dependent code (constructor + field GEPs) can
    // reference the type by name.
    define register_struct(self, sd: _StructDef) -> void {
        self.structs.put(sd.name, sd)
    }

    // Register a user-defined function's signature so call-site
    // codegen can render typed args and a typed call. Called
    // by emit_module's pre-pass before any body codegen runs.
    define register_sig(self, name: String, sig: _Sig) -> void {
        self.sigs.put(name, sig)
    }

    // Allocate a private string constant. `text` holds the
    // decoded byte sequence (lexer has already folded `\n` /
    // `\t` / `\\` / `\"` into their literal bytes). Returns
    // the LLVM name `@.str.N` so callers can refer to it via
    // a getelementptr. The byte count for the `[N x i8]`
    // type uses the decoded length — IR's `\HH` escapes each
    // represent a single byte regardless of source width.
    define alloc_string(self, text: String) -> String {
        name := "@.str." + self.next_str.str()
        self.next_str = self.next_str + 1
        n := text.length() + 1
        encoded := _llvm_encode_string(text)
        line := name + " = private unnamed_addr constant [" + n.str() +
                " x i8] c\"" + encoded + "\\00\""
        self.globals.append(line)
        return name
    }

    define ensure_decl(self, key: String, line: String) -> void {
        if self.decls.has(key) { return }
        self.decls.put(key, line)
    }

    define render_header(self) -> String {
        out := ""
        // Internal list-header type. `{ length, capacity,
        // i32* data }` — the data array lives in its own
        // allocation so `.append` can `realloc` the buffer
        // without invalidating the header pointer that callers
        // hold. Always emitted (cheap, and avoids a "used a
        // list?" tracking flag); LLVM's verifier accepts unused
        // type defs.
        out = out + "%QList = type { i32, i32, i32* }\n"
        // Pointer-element list. Same shape as %QList but the
        // data buffer holds i8* slots. `List<T>` where T is
        // anything other than `Int` resolves to this type;
        // bare `List` annotation defaults to %QList (i32).
        out = out + "%QListP = type { i32, i32, i8** }\n"
        // Internal map types. `%QMapKV` is a single key/value
        // pair (both i8*); `%QMap` is the header — length,
        // capacity, and a pointer to the entry array. Linear
        // scan on lookup; fine for the small per-scope tables
        // selfhost uses.
        out = out + "%QMapKV = type { i8*, i8* }\n"
        out = out + "%QMap = type { i32, i32, %QMapKV* }\n\n"
        // %struct.Name type defs first so subsequent globals /
        // function signatures can reference them by name.
        snames := self.structs.keys()
        si := 0
        while si < snames.length() {
            sname: String := snames.__get(si)
            sd: _StructDef := self.structs.get(sname)
            line := "%struct." + sd.name + " = type { "
            fi := 0
            while fi < sd.field_llvm_tys.length() {
                if fi > 0 { line = line + ", " }
                ft: String := sd.field_llvm_tys.__get(fi)
                line = line + ft
                fi = fi + 1
            }
            line = line + " }"
            out = out + line + "\n"
            si = si + 1
        }
        if snames.length() > 0 { out = out + "\n" }
        i := 0
        while i < self.globals.length() {
            line: String := self.globals.__get(i)
            out = out + line + "\n"
            i = i + 1
        }
        if self.globals.length() > 0 { out = out + "\n" }
        keys := self.decls.keys()
        j := 0
        while j < keys.length() {
            k: String := keys.__get(j)
            line: String := self.decls.get(k)
            out = out + line + "\n"
            j = j + 1
        }
        if keys.length() > 0 { out = out + "\n" }
        return out
    }
}

---
Codegen state per-function. Two output buffers — `entry_out`
holds the allocas at function entry, `out` holds the body
instructions and labels. We concatenate the two at the end so
allocas always sit before their first use (LLVM domination
rule). `next_reg` is the monotonic SSA counter; `next_label` is
the monotonic basic-block label counter for branches. `locals`
maps Quirk variable names to their alloca slot's SSA pointer
name (e.g. `x` → `%x.addr`). `mod` points back at the
module-level state for string-literal interning + runtime
helper declarations.
---
struct FnCG {
    entry_out: String
    out: String
    next_reg: Int
    next_label: Int
    locals: Map
    block_terminated: Bool
    mod: ModuleCG
    // LLVM return type of the function currently being lowered.
    // Set by _gen_function before the body runs so `Return`
    // statements and the synthetic fall-through terminator can
    // emit the matching `ret <ty>` instruction.
    ret_ty: String
    // Loop-label stacks (parallel `List<String>`). `loop_head`
    // is the target of `continue` (the cond-check block);
    // `loop_end` is the target of `break` (the post-loop join).
    // While codegen pushes on entry and pops on exit so nested
    // loops route through the innermost.
    loop_head: List
    loop_end: List

    define __init(self, m: ModuleCG) -> void {
        self.entry_out = ""
        self.out = ""
        self.next_reg = 0
        self.next_label = 0
        self.locals = Map()
        self.block_terminated = false
        self.mod = m
        self.ret_ty = "i32"
        self.loop_head = List()
        self.loop_end = List()
    }

    define fresh(self) -> String {
        r := "%" + self.next_reg.str()
        self.next_reg = self.next_reg + 1
        return r
    }

    define fresh_label(self, prefix: String) -> String {
        n := self.next_label
        self.next_label = n + 1
        return prefix + "." + n.str()
    }

    define emit(self, line: String) -> void {
        // Suppress dead code after a terminator. Without this,
        // a `return` followed by anything else (or the
        // unconditional `ret i32 0` fall-through after every
        // block) emits unreachable IR that fails strict
        // verification.
        if self.block_terminated { return }
        self.out = self.out + "  " + line + "\n"
        // `ret` / `br` / `unreachable` mark the block as
        // terminated. We check for the first token of the
        // line — anything else is a normal instruction.
        if line.startswith("ret ") or line.startswith("br ") or line == "unreachable" {
            self.block_terminated = true
        }
    }

    // Raw — no leading indent. Used for basic-block labels and
    // explicit `br` lines that should align flush-left in IR.
    // Labels reopen the block, so emitting one clears the
    // terminated flag.
    define emit_raw(self, line: String) -> void {
        self.out = self.out + line + "\n"
        // A label line (`some.label.0:`) opens a fresh block,
        // so prior terminator status no longer applies.
        if line.endswith(":") {
            self.block_terminated = false
        }
    }

    define emit_entry(self, line: String) -> void {
        self.entry_out = self.entry_out + "  " + line + "\n"
    }
}

// -----------------------------------------------------------------
// Expression codegen — returns the SSA reg/literal holding the value.
// -----------------------------------------------------------------

define _gen_expr(cg: FnCG, e: Expr) -> String {
    match e {
        case IntLit as lit => {
            // Literal flows inline as `i32 N` at the use site.
            return lit.value.str()
        }
        case BoolLit as bl => {
            if bl.value { return "1" }
            return "0"
        }
        case FloatLit as fl => {
            // Pass the textual literal through to LLVM. The IR
            // parser accepts decimal forms (`3.14`, `1.0`, `0.5`)
            // and converts them to IEEE-754 internally. Hex
            // form (`0x4009...`) would be needed for values
            // that don't round-trip, but the corpus today is
            // small exact-decimal values only.
            return fl.value
        }
        case StringLit as sl => {
            // Intern the literal as a `[N x i8]*` global, then
            // GEP it to an `i8*` value that flows like any
            // other scalar. The resulting i8* can be stored in
            // an alloca slot (for `s := "hello"`), passed as a
            // call argument (`print(s)`, user-defined String
            // params), or returned from a String-returning
            // function. Phase 4.3 only handled the inlined
            // `print(StringLit)` form; this case generalises it.
            str_name := cg.mod.alloc_string(sl.value)
            str_len := sl.value.length() + 1
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds [" + str_len.str() +
                    " x i8], [" + str_len.str() + " x i8]* " +
                    str_name + ", i64 0, i64 0")
            return gep
        }
        case Ident as id => {
            if cg.locals.has(id.name) {
                holder: _Slot := cg.locals.get(id.name)
                // Locals live in alloca slots. Read = `load`
                // through the slot pointer; LLVM's mem2reg
                // pass collapses these to SSA + phi at -O1.
                // The slot's stored type (`i1` for Bool, `i32`
                // for Int) must match the load instruction.
                reg := cg.fresh()
                cg.emit(reg + " = load " + holder.ty + ", " + holder.ty + "* " + holder.name)
                return reg
            }
            return "<undef:" + id.name + ">"
        }
        case ListLit as ll => {
            // Extracted helper — keeps the inner recursive
            // _gen_expr (per element) in its own function so
            // the same self-compiler gap as _gen_struct_ctor
            // doesn't fire from coexisting with the other
            // recursive arms here.
            return _gen_list_lit(cg, ll.elems)
        }
        case Index as ix => {
            // Load the data pointer from the list's field 2,
            // GEP by the i32 index, then load. The header and
            // data buffer are separate allocations (Phase 4.15+)
            // so we can't reach the element via a single GEP.
            // Dispatch on receiver type: %QList* uses i32
            // storage, %QListP* uses i8* storage.
            base_ty := _expr_static_ty(cg, ix.obj)
            base_reg := _gen_expr(cg, ix.obj)
            idx_reg := _gen_expr(cg, ix.idx)
            if base_ty == "%QListP*" {
                data_gep := cg.fresh()
                cg.emit(data_gep + " = getelementptr inbounds %QListP, %QListP* " + base_reg +
                        ", i32 0, i32 2")
                data_ptr := cg.fresh()
                cg.emit(data_ptr + " = load i8**, i8*** " + data_gep)
                elem_gep := cg.fresh()
                cg.emit(elem_gep + " = getelementptr inbounds i8*, i8** " + data_ptr +
                        ", i32 " + idx_reg)
                reg := cg.fresh()
                cg.emit(reg + " = load i8*, i8** " + elem_gep)
                return reg
            }
            data_gep := cg.fresh()
            cg.emit(data_gep + " = getelementptr inbounds %QList, %QList* " + base_reg +
                    ", i32 0, i32 2")
            data_ptr := cg.fresh()
            cg.emit(data_ptr + " = load i32*, i32** " + data_gep)
            elem_gep := cg.fresh()
            cg.emit(elem_gep + " = getelementptr inbounds i32, i32* " + data_ptr +
                    ", i32 " + idx_reg)
            reg := cg.fresh()
            cg.emit(reg + " = load i32, i32* " + elem_gep)
            return reg
        }
        case FieldGet as fg => {
            // Enum-variant access: `TokenKind.Identifier`. The
            // receiver is an Ident matching a registered enum;
            // the result is the variant's ordinal as a literal
            // i32 — no GEP, no load.
            match fg.obj {
                case Ident as enum_id => {
                    if cg.mod.enums.has(enum_id.name) {
                        ed: EnumDecl := cg.mod.enums.get(enum_id.name)
                        vi := 0
                        while vi < ed.variants.length() {
                            vn: String := ed.variants.__get(vi)
                            if vn == fg.name { return vi.str() }
                            vi = vi + 1
                        }
                        return "0"
                    }
                }
                case _ => {}
            }
            // Struct field access: GEP + load.
            obj_ty := _expr_static_ty(cg, fg.obj)
            obj_reg := _gen_expr(cg, fg.obj)
            sname := _strip_struct_ptr(obj_ty)
            sd: _StructDef := cg.mod.structs.get(sname)
            idx := 0
            field_ty := "i32"
            fi := 0
            while fi < sd.field_names.length() {
                fname: String := sd.field_names.__get(fi)
                if fname == fg.name {
                    idx = fi
                    field_ty = sd.field_llvm_tys.__get(fi)
                }
                fi = fi + 1
            }
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds %struct." + sname +
                    ", %struct." + sname + "* " + obj_reg +
                    ", i32 0, i32 " + idx.str())
            reg := cg.fresh()
            cg.emit(reg + " = load " + field_ty + ", " + field_ty + "* " + gep)
            return reg
        }
        case UnaryOp as u => {
            opd_ty := _expr_static_ty(cg, u.operand)
            v := _gen_expr(cg, u.operand)
            if u.op == "-" {
                // Integer: `sub nsw i32 0, x` is the standard
                // negation idiom (LLVM has no dedicated `neg`).
                // Double: LLVM 14 has a real `fneg double`.
                reg := cg.fresh()
                if opd_ty == "double" {
                    cg.emit(reg + " = fneg double " + v)
                } else {
                    cg.emit(reg + " = sub nsw i32 0, " + v)
                }
                return reg
            }
            if u.op == "not" {
                // `not` operates on i1. The operand came from
                // a comparison or another `not`, so it's
                // already i1. `xor i1 b, 1` is the idiom for
                // logical negation.
                reg := cg.fresh()
                cg.emit(reg + " = xor i1 " + v + ", 1")
                return reg
            }
            return "0"
        }
        case BinOp as b => {
            // Arithmetic vs comparison split on operator: the
            // former returns the operand type (i32 / double /
            // i8*), the latter returns i1. Operand type is taken
            // from the left side — sema has already required
            // both sides to agree.
            opd_ty := _expr_static_ty(cg, b.left)
            is_dbl := opd_ty == "double"
            // String concat: `+` on two i8* operands. Lower to
            // malloc(strlen(a) + strlen(b) + 1) + strcpy + strcat,
            // and return the malloc'd buffer. The result leaks
            // — the self-hosted compiler is short-lived enough
            // that explicit free / a GC layer can wait.
            if b.op == "+" and opd_ty == "i8*" {
                l := _gen_expr(cg, b.left)
                r := _gen_expr(cg, b.right)
                cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
                cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
                cg.mod.ensure_decl("strcpy", "declare i8* @strcpy(i8*, i8*)")
                cg.mod.ensure_decl("strcat", "declare i8* @strcat(i8*, i8*)")
                la := cg.fresh()
                cg.emit(la + " = call i64 @strlen(i8* " + l + ")")
                lb := cg.fresh()
                cg.emit(lb + " = call i64 @strlen(i8* " + r + ")")
                sum := cg.fresh()
                cg.emit(sum + " = add i64 " + la + ", " + lb)
                total := cg.fresh()
                cg.emit(total + " = add i64 " + sum + ", 1")
                buf := cg.fresh()
                cg.emit(buf + " = call i8* @malloc(i64 " + total + ")")
                cpy := cg.fresh()
                cg.emit(cpy + " = call i8* @strcpy(i8* " + buf + ", i8* " + l + ")")
                cat := cg.fresh()
                cg.emit(cat + " = call i8* @strcat(i8* " + buf + ", i8* " + r + ")")
                return buf
            }
            l := _gen_expr(cg, b.left)
            r := _gen_expr(cg, b.right)
            op := b.op
            // Comparison.
            int_pred := ""
            dbl_pred := ""
            if op == "==" { int_pred = "eq"  dbl_pred = "oeq" }
            if op == "!=" { int_pred = "ne"  dbl_pred = "one" }
            if op == "<"  { int_pred = "slt" dbl_pred = "olt" }
            if op == "<=" { int_pred = "sle" dbl_pred = "ole" }
            if op == ">"  { int_pred = "sgt" dbl_pred = "ogt" }
            if op == ">=" { int_pred = "sge" dbl_pred = "oge" }
            if int_pred.length() > 0 {
                // String comparisons — all six predicates
                // route through strcmp. Equality (`==` / `!=`)
                // compares the strcmp result against zero;
                // ordering (`<` / `<=` / `>` / `>=`) uses the
                // signed icmp form against zero too (strcmp's
                // return is sign-bearing). Handled first so
                // the strcmp result reg gets the earlier SSA
                // number — cg.fresh() assigns in call order
                // and emit order must match.
                if opd_ty == "i8*" {
                    cg.mod.ensure_decl("strcmp", "declare i32 @strcmp(i8*, i8*)")
                    cmp := cg.fresh()
                    cg.emit(cmp + " = call i32 @strcmp(i8* " + l + ", i8* " + r + ")")
                    reg := cg.fresh()
                    pred := "eq"
                    if op == "!=" { pred = "ne" }
                    if op == "<"  { pred = "slt" }
                    if op == "<=" { pred = "sle" }
                    if op == ">"  { pred = "sgt" }
                    if op == ">=" { pred = "sge" }
                    cg.emit(reg + " = icmp " + pred + " i32 " + cmp + ", 0")
                    return reg
                }
                // Bool ==/!= Bool — operate on i1 directly.
                // Ordering ops on Bool stay rejected by sema.
                if opd_ty == "i1" {
                    reg := cg.fresh()
                    pred := "eq"
                    if op == "!=" { pred = "ne" }
                    cg.emit(reg + " = icmp " + pred + " i1 " + l + ", " + r)
                    return reg
                }
                reg := cg.fresh()
                if is_dbl {
                    cg.emit(reg + " = fcmp " + dbl_pred + " double " + l + ", " + r)
                } else {
                    cg.emit(reg + " = icmp " + int_pred + " i32 " + l + ", " + r)
                }
                return reg
            }
            // Logical and / or — Bool/Bool → Bool, lowered as
            // bitwise `and i1` / `or i1`. Non-short-circuit
            // semantics: both sides eagerly evaluated, fine for
            // selfhost's usage (logical guards on already-computed
            // boolean state). True short-circuit would route
            // through basic blocks + phi.
            if op == "and" or op == "or" {
                reg := cg.fresh()
                cg.emit(reg + " = " + op + " i1 " + l + ", " + r)
                return reg
            }
            // Arithmetic.
            int_instr := "add"
            dbl_instr := "fadd"
            if op == "-" { int_instr = "sub"  dbl_instr = "fsub" }
            if op == "*" { int_instr = "mul"  dbl_instr = "fmul" }
            if op == "/" { int_instr = "sdiv" dbl_instr = "fdiv" }
            reg := cg.fresh()
            if is_dbl {
                cg.emit(reg + " = " + dbl_instr + " double " + l + ", " + r)
            } else {
                cg.emit(reg + " = " + int_instr + " nsw i32 " + l + ", " + r)
            }
            return reg
        }
        case Call as c => {
            // Method call form: `obj.method(args)` parsed as
            // Call(FieldGet(obj, method), args). Dispatched
            // before the identifier-callee path so the bare
            // `name = "<bad-callee>"` fallthrough never fires
            // for valid method calls.
            is_method := false
            match c.callee { case FieldGet as _ => is_method = true case _ => {} }
            if is_method {
                return _gen_method_call(cg, c)
            }
            name := ""
            match c.callee {
                case Ident as id => name = id.name
                case _ => name = "<bad-callee>"
            }
            // print(<String expr>) lowers to `call i32 @puts(i8* %arg)`.
            // The argument codegen path already produces an i8*
            // for any String-typed expression (StringLit GEP,
            // load from a String slot, return from a String
            // function), so this case just consumes whatever
            // _gen_expr returned without caring about the shape.
            if name == "print" and c.args.length() == 1 {
                arg0: Expr := c.args.__get(0)
                arg_reg := _gen_expr(cg, arg0)
                cg.mod.ensure_decl("puts", "declare i32 @puts(i8*)")
                reg := cg.fresh()
                cg.emit(reg + " = call i32 @puts(i8* " + arg_reg + ")")
                // print returns void Quirk-side; our Stmt path
                // discards the value at ExprStmt, but to keep
                // _gen_expr's contract uniform we still return
                // the i32 reg from puts.
                return reg
            }
            // Builtin: `eprint(s)` — like print, but to stderr
            // (fd 2). Lowers to `write(2, s, strlen(s))` then a
            // single-byte `write(2, "\n", 1)`. Extracted to a
            // helper because the inner `_gen_expr` recursion
            // pairs badly with other recursion sites in this
            // outer fn (same self-compiler gap that bit
            // arg_get / read_file / write_file).
            if name == "eprint" and c.args.length() == 1 {
                return _gen_eprint(cg, c.args)
            }
            // Builtin file I/O. Extracted into helpers because
            // both lowerings emit a multi-call sequence — the
            // recursion-pairing dodge applies.
            if name == "read_file" and c.args.length() == 1 {
                return _gen_read_file(cg, c.args)
            }
            if name == "write_file" and c.args.length() == 2 {
                return _gen_write_file(cg, c.args)
            }
            // Builtin: `arg_count()` → loads i32 from
            // @quirk_argc global; the wrapper main(argc, argv)
            // stashes it at program start.
            if name == "arg_count" and c.args.length() == 0 {
                cg.mod.ensure_decl("quirk_argc", "@quirk_argc = global i32 0")
                reg := cg.fresh()
                cg.emit(reg + " = load i32, i32* @quirk_argc")
                return reg
            }
            // Builtin: `arg_get(i)` → loads i8* from
            // @quirk_argv[i]. Both globals are populated by the
            // synthetic main wrapper emitted by emit_module.
            // Extracted into a helper (`_gen_arg_get`) because
            // the inner `_gen_expr` recursion next to the
            // outer-function recursion sites trips a known
            // self-compiler corruption pattern.
            if name == "arg_get" and c.args.length() == 1 {
                return _gen_arg_get(cg, c.args)
            }
            // Builtin: `len(xs)` reads the i32 length field
            // out of the %QList header. GEP `i32 0, i32 0` is
            // the length slot.
            if name == "len" and c.args.length() == 1 {
                la0: Expr := c.args.__get(0)
                la_reg := _gen_expr(cg, la0)
                gep := cg.fresh()
                cg.emit(gep + " = getelementptr inbounds %QList, %QList* " + la_reg +
                        ", i32 0, i32 0")
                reg := cg.fresh()
                cg.emit(reg + " = load i32, i32* " + gep)
                return reg
            }
            // Builtin collection constructors. `Map()` and
            // `List()` produce empty containers; sema has
            // already validated arity == 0.
            if name == "Map" {
                return _gen_map_new(cg)
            }
            // Both `List()` and `ListP()` build an empty
            // pointer-element list — the int-element variant
            // doesn't have a no-arg constructor; use a literal
            // `[1, 2, 3]` seed instead.
            if name == "List" or name == "ListP" {
                return _gen_listp_new(cg)
            }
            // Variant constructor: `V(args)` where V is a
            // registered tagged-union variant. malloc the
            // synthetic `T__V` struct, store tag at field 0
            // and user args at fields 1..N, then bitcast back
            // to `%struct.T*` so the caller sees a value of
            // the union's base pointer type.
            if cg.mod.variants.has(name) {
                return _gen_variant_ctor(cg, name, c.args)
            }
            // Struct constructor: `Foo(a, b, ...)`. malloc a
            // %struct.Foo, then GEP + store each arg into its
            // field slot. Sizing uses the GEP-of-null trick —
            // a typed nullptr offset by 1 yields the byte size
            // of the struct without compile-time layout math.
            if cg.mod.structs.has(name) {
                return _gen_struct_ctor(cg, name, c.args)
            }
            // Emit each arg first, then the call. Look up the
            // callee's typed signature so each arg + the return
            // is rendered with the matching LLVM type.
            args := List()
            i := 0
            while i < c.args.length() {
                ai: Expr := c.args.__get(i)
                args.append(_gen_expr(cg, ai))
                i = i + 1
            }
            ret_llvm := "i32"
            param_llvm := List()
            llvm_name := _llvm_fn_name(name)
            if cg.mod.sigs.has(llvm_name) {
                msig: _Sig := cg.mod.sigs.get(llvm_name)
                ret_llvm = msig.ret_ty
                param_llvm = msig.param_tys
            }
            sig := "("
            j := 0
            while j < args.length() {
                if j > 0 { sig = sig + ", " }
                av: String := args.__get(j)
                pty := "i32"
                if j < param_llvm.length() {
                    pty = param_llvm.__get(j)
                }
                sig = sig + pty + " " + av
                j = j + 1
            }
            sig = sig + ")"
            reg := cg.fresh()
            cg.emit(reg + " = call " + ret_llvm + " @" + _llvm_fn_name(name) + sig)
            return reg
        }
        case _ => return "0"
    }
}

// User's `define main()` becomes `@__quirk_user_main` in LLVM
// IR so we can synthesize a wrapper `@main(i32 %argc, i8** %argv)`
// that stashes argv into module globals before delegating.
// Call sites + sig table both route through this helper so
// the rename is invisible to callers.
define _llvm_fn_name(name: String) -> String {
    if name == "main" { return "__quirk_user_main" }
    return name
}

// Per-local alloca metadata. `name` is the SSA pointer (e.g.
// `%x.addr`); `ty` is the LLVM type the slot holds — `i32` for
// Int locals (and all params today), `i1` for Bool locals.
// Stored in `cg.locals`; the Map can't yet carry tagged-union
// values directly so we wrap in a struct.
struct _Slot {
    name: String
    ty: String
    define __init(self, name: String, ty: String) -> void {
        self.name = name
        self.ty = ty
    }
}

// Static type of an expression for slot-typing purposes. Returns
// `"i1"` when the expression is statically Bool (BoolLit, an
// `i1` slot read, a comparison BinOp, or `not` over an `i1`);
// `"i32"` otherwise. Sema has already rejected obvious type
// mismatches by the time we get here, so this only needs to be
// right on the well-typed subset.
define _expr_static_ty(cg: FnCG, e: Expr) -> String {
    match e {
        case BoolLit as _ => return "i1"
        case FloatLit as _ => return "double"
        case StringLit as _ => return "i8*"
        case ListLit as _ => return "%QList*"
        case Index as ix => {
            obj_ty := _expr_static_ty(cg, ix.obj)
            if obj_ty == "%QListP*" { return "i8*" }
            return "i32"
        }
        case Ident as id => {
            if cg.locals.has(id.name) {
                s: _Slot := cg.locals.get(id.name)
                return s.ty
            }
            return "i32"
        }
        case UnaryOp as u => {
            if u.op == "not" { return "i1" }
            // `-x` follows the operand's type — `i32` for Int,
            // `double` for Double. Anything else is a sema bug.
            return _expr_static_ty(cg, u.operand)
        }
        case BinOp as b => {
            op := b.op
            if op == "==" or op == "!=" or op == "<" or op == "<=" or op == ">" or op == ">=" {
                return "i1"
            }
            if op == "and" or op == "or" { return "i1" }
            // Arithmetic / concat: result type follows operand
            // type. Sema rejects mixed-kind operations, so the
            // left operand's static type is enough to decide.
            //   `+` on String → i8*  (allocated via malloc in
            //   _gen_expr; see the BinOp case there)
            //   either side is `double` → double
            //   otherwise → i32
            lt := _expr_static_ty(cg, b.left)
            if lt == "i8*" and op == "+" { return "i8*" }
            if lt == "double" { return "double" }
            rt := _expr_static_ty(cg, b.right)
            if rt == "double" { return "double" }
            return "i32"
        }
        case Call as c => {
            // User-defined call: signature was pre-registered by
            // emit_module, so the return type is known here.
            // A struct constructor call (`Foo(...)`) returns the
            // struct's heap-pointer type `%struct.Foo*`. `print`
            // and other special-cased builtins fall through to
            // the default `i32` — `print(...)` lowers to `puts`
            // which returns i32 and isn't a useful binding shape.
            // Method calls (`obj.m(args)`) route to _method_ret_ty
            // so `s := ln.str()` gets the right slot type.
            is_method := false
            match c.callee { case FieldGet as _ => is_method = true case _ => {} }
            if is_method {
                fg: FieldGet := c.callee
                rcv := _expr_static_ty(cg, fg.obj)
                return _method_ret_ty(cg, rcv, fg.name)
            }
            cname := ""
            match c.callee {
                case Ident as id => cname = id.name
                case _ => {}
            }
            // Builtin `len()` returns Int regardless of arg type.
            if cname == "len" { return "i32" }
            // Builtin file I/O. read_file returns the malloc'd
            // buffer (i8*); write_file returns i32 0.
            if cname == "read_file"  { return "i8*" }
            if cname == "write_file" { return "i32" }
            // arg_count() → Int; arg_get(i) → String pointer.
            if cname == "arg_count" { return "i32" }
            if cname == "arg_get"   { return "i8*" }
            // eprint(s) → Int (0); the actual return is never used.
            if cname == "eprint"    { return "i32" }
            // Builtin collection constructors.
            if cname == "Map"  { return "%QMap*" }
            // Both `List()` and `ListP()` produce
            // pointer-element lists. Phase 5c flipped the
            // default to match selfhost source's usage.
            if cname == "List" or cname == "ListP" { return "%QListP*" }
            // Variant constructor returns the union's base
            // pointer type, not the synthetic per-variant struct.
            if cg.mod.variants.has(cname) {
                vci: _VarCgInfo := cg.mod.variants.get(cname)
                return "%struct." + vci.union_name + "*"
            }
            if cg.mod.structs.has(cname) {
                return "%struct." + cname + "*"
            }
            cn_llvm := _llvm_fn_name(cname)
            if cg.mod.sigs.has(cn_llvm) {
                sig: _Sig := cg.mod.sigs.get(cn_llvm)
                return sig.ret_ty
            }
            return "i32"
        }
        case FieldGet as fg => {
            // Enum-variant access: receiver Ident matches a
            // registered enum → result is i32.
            match fg.obj {
                case Ident as enum_id => {
                    if cg.mod.enums.has(enum_id.name) { return "i32" }
                }
                case _ => {}
            }
            // Struct field access: look up the field's LLVM
            // type in the parallel field_names / field_llvm_tys
            // lists.
            ot := _expr_static_ty(cg, fg.obj)
            sname := _strip_struct_ptr(ot)
            if cg.mod.structs.has(sname) {
                sd: _StructDef := cg.mod.structs.get(sname)
                fi := 0
                while fi < sd.field_names.length() {
                    fname: String := sd.field_names.__get(fi)
                    if fname == fg.name {
                        return sd.field_llvm_tys.__get(fi)
                    }
                    fi = fi + 1
                }
            }
            return "i32"
        }
        case _ => return "i32"
    }
}

// Lower a struct constructor call `Foo(a, b, ...)` to a heap
// allocation. Extracted from `_gen_expr` so the recursive
// `_gen_expr(cg, aexpr)` for each arg sits in its own
// function — keeping the inner-vs-outer recursion sites apart
// works around a self-compiler gap that surfaced when two
// recursive `_gen_expr` calls coexisted in different positions
// within the same outer function.
define _gen_struct_ctor(cg: FnCG, name: String, ctor_args: List) -> String {
    sd: _StructDef := cg.mod.structs.get(name)
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    // Sizing via GEP-of-null: `getelementptr T, T* null, i64 1`
    // is a typed nullptr offset by one element, whose
    // ptrtoint gives the byte size without any compile-time
    // layout knowledge.
    size_gep := cg.fresh()
    cg.emit(size_gep + " = getelementptr %struct." + name +
            ", %struct." + name + "* null, i64 1")
    size_i := cg.fresh()
    cg.emit(size_i + " = ptrtoint %struct." + name +
            "* " + size_gep + " to i64")
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 " + size_i + ")")
    obj := cg.fresh()
    cg.emit(obj + " = bitcast i8* " + raw + " to %struct." + name + "*")
    // If the struct has an `__init` method, dispatch ctor
    // through it: pass `self` (just-allocated obj) + the
    // user's args, ignore the return value. Otherwise fall
    // back to direct positional field stores.
    init_name := name + "__" + "__init"
    if cg.mod.sigs.has(init_name) {
        msig: _Sig := cg.mod.sigs.get(init_name)
        sig := "(%struct." + name + "* " + obj
        ai := 0
        while ai < ctor_args.length() {
            aexpr: Expr := ctor_args.__get(ai)
            aval := _gen_expr(cg, aexpr)
            // param_tys[0] is `%struct.Foo*` (the implicit
            // self); user-visible args start at index 1.
            pty := "i32"
            sigi := ai + 1
            if sigi < msig.param_tys.length() {
                pty = msig.param_tys.__get(sigi)
            }
            sig = sig + ", " + pty + " " + aval
            ai = ai + 1
        }
        sig = sig + ")"
        ret := cg.fresh()
        cg.emit(ret + " = call " + msig.ret_ty + " @" + init_name + sig)
        return obj
    }
    // No __init — direct positional field stores.
    ai := 0
    while ai < ctor_args.length() {
        aexpr: Expr := ctor_args.__get(ai)
        aval := _gen_expr(cg, aexpr)
        fty: String := sd.field_llvm_tys.__get(ai)
        fgep := cg.fresh()
        cg.emit(fgep + " = getelementptr inbounds %struct." + name +
                ", %struct." + name + "* " + obj +
                ", i32 0, i32 " + ai.str())
        cg.emit("store " + fty + " " + aval + ", " + fty + "* " + fgep)
        ai = ai + 1
    }
    return obj
}

// Lower a method call `obj.method(args)`. Phase 4.13 wires
// a fixed receiver-keyed set:
//   List.length()    →  GEP %QList field 0 + load i32
//   String.length()  →  call i64 @strlen + trunc to i32
// Extracted into its own helper to keep the recursive
// `_gen_expr(cg, fg.obj)` separate from the other recursion
// sites in `_gen_expr`'s arms — the same self-compiler
// workaround pattern as `_gen_struct_ctor` and `_gen_list_lit`.
define _gen_method_call(cg: FnCG, c: Call) -> String {
    fg: FieldGet := c.callee
    recv_ty := _expr_static_ty(cg, fg.obj)
    recv_reg := _gen_expr(cg, fg.obj)
    // User struct method dispatch: receiver type is
    // `%struct.Foo*`; look up the mangled `Foo__method`
    // signature in mod.sigs. Found → render a typed call
    // threading the receiver as %arg0.
    sname := _strip_struct_ptr(recv_ty)
    if cg.mod.structs.has(sname) {
        full := sname + "__" + fg.name
        if cg.mod.sigs.has(full) {
            mtsig: _Sig := cg.mod.sigs.get(full)
            // Build "(self_ty %recv, pty %arg, ...)" using the
            // pre-registered param tys (which already include
            // the self param at index 0).
            arg_vals := List()
            ai := 0
            while ai < c.args.length() {
                aexpr: Expr := c.args.__get(ai)
                arg_vals.append(_gen_expr(cg, aexpr))
                ai = ai + 1
            }
            sig := "(" + recv_ty + " " + recv_reg
            j := 0
            while j < arg_vals.length() {
                sig = sig + ", "
                pty := "i32"
                pi := j + 1
                if pi < mtsig.param_tys.length() {
                    pty = mtsig.param_tys.__get(pi)
                }
                av: String := arg_vals.__get(j)
                sig = sig + pty + " " + av
                j = j + 1
            }
            sig = sig + ")"
            reg := cg.fresh()
            cg.emit(reg + " = call " + mtsig.ret_ty + " @" + full + sig)
            return reg
        }
    }
    if fg.name == "length" {
        if recv_ty == "%QList*" {
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds %QList, %QList* " + recv_reg +
                    ", i32 0, i32 0")
            reg := cg.fresh()
            cg.emit(reg + " = load i32, i32* " + gep)
            return reg
        }
        if recv_ty == "%QListP*" {
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds %QListP, %QListP* " + recv_reg +
                    ", i32 0, i32 0")
            reg := cg.fresh()
            cg.emit(reg + " = load i32, i32* " + gep)
            return reg
        }
        if recv_ty == "i8*" {
            cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
            len64 := cg.fresh()
            cg.emit(len64 + " = call i64 @strlen(i8* " + recv_reg + ")")
            // Int is i32 in this codegen — truncate. Strings
            // longer than INT_MAX bytes would wrap; not a
            // realistic concern for self-host source files.
            reg := cg.fresh()
            cg.emit(reg + " = trunc i64 " + len64 + " to i32")
            return reg
        }
    }
    if fg.name == "append" and recv_ty == "%QList*" {
        // Recursive `_gen_expr` for the arg lives inside the
        // helper to keep this function's recursion shape simple
        // (same dodge as _gen_struct_ctor, _gen_list_lit,
        // _gen_field_set).
        return _gen_list_append(cg, recv_reg, c.args)
    }
    if fg.name == "append" and recv_ty == "%QListP*" {
        return _gen_listp_append(cg, recv_reg, c.args)
    }
    // `.pop()` — decrement the list's length, then load +
    // return the element that was at (new) length. No
    // resize, no zeroing of the slot — same trade-off as
    // append's leak-the-old-buffer behaviour.
    if fg.name == "pop" and (recv_ty == "%QList*" or recv_ty == "%QListP*") {
        is_p := recv_ty == "%QListP*"
        list_ty := "%QList"
        if is_p { list_ty = "%QListP" }
        elem_llvm := "i32"
        elem_ptr := "i32*"
        elem_ptrptr := "i32**"
        if is_p { elem_llvm = "i8*"  elem_ptr = "i8**"  elem_ptrptr = "i8***" }
        len_gep := cg.fresh()
        cg.emit(len_gep + " = getelementptr inbounds " + list_ty + ", " + list_ty + "* " + recv_reg +
                ", i32 0, i32 0")
        cur_len := cg.fresh()
        cg.emit(cur_len + " = load i32, i32* " + len_gep)
        new_len := cg.fresh()
        cg.emit(new_len + " = sub nsw i32 " + cur_len + ", 1")
        cg.emit("store i32 " + new_len + ", i32* " + len_gep)
        data_gep := cg.fresh()
        cg.emit(data_gep + " = getelementptr inbounds " + list_ty + ", " + list_ty + "* " + recv_reg +
                ", i32 0, i32 2")
        data_ptr := cg.fresh()
        cg.emit(data_ptr + " = load " + elem_ptr + ", " + elem_ptrptr + " " + data_gep)
        elem_gep := cg.fresh()
        cg.emit(elem_gep + " = getelementptr inbounds " + elem_llvm + ", " + elem_ptr + " " + data_ptr +
                ", i32 " + new_len)
        reg := cg.fresh()
        cg.emit(reg + " = load " + elem_llvm + ", " + elem_ptr + " " + elem_gep)
        return reg
    }
    // `.__get(i)` — method form of subscript. Mirrors the
    // Index expr's lowering exactly; selfhost source uses
    // this shape in many iteration loops.
    if fg.name == "__get" and (recv_ty == "%QList*" or recv_ty == "%QListP*") {
        idx_expr: Expr := c.args.__get(0)
        idx_reg := _gen_expr(cg, idx_expr)
        if recv_ty == "%QListP*" {
            data_gep := cg.fresh()
            cg.emit(data_gep + " = getelementptr inbounds %QListP, %QListP* " + recv_reg +
                    ", i32 0, i32 2")
            data_ptr := cg.fresh()
            cg.emit(data_ptr + " = load i8**, i8*** " + data_gep)
            elem_gep := cg.fresh()
            cg.emit(elem_gep + " = getelementptr inbounds i8*, i8** " + data_ptr +
                    ", i32 " + idx_reg)
            reg := cg.fresh()
            cg.emit(reg + " = load i8*, i8** " + elem_gep)
            return reg
        }
        data_gep := cg.fresh()
        cg.emit(data_gep + " = getelementptr inbounds %QList, %QList* " + recv_reg +
                ", i32 0, i32 2")
        data_ptr := cg.fresh()
        cg.emit(data_ptr + " = load i32*, i32** " + data_gep)
        elem_gep := cg.fresh()
        cg.emit(elem_gep + " = getelementptr inbounds i32, i32* " + data_ptr +
                ", i32 " + idx_reg)
        reg := cg.fresh()
        cg.emit(reg + " = load i32, i32* " + elem_gep)
        return reg
    }
    // Map methods. Each routes into _gen_map_method for the
    // recursion-pairing dodge.
    if recv_ty == "%QMap*" {
        if fg.name == "put" or fg.name == "get" or fg.name == "has" {
            return _gen_map_method(cg, fg.name, recv_reg, c.args)
        }
        if fg.name == "length" {
            gep := cg.fresh()
            cg.emit(gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
                    ", i32 0, i32 0")
            reg := cg.fresh()
            cg.emit(reg + " = load i32, i32* " + gep)
            return reg
        }
        if fg.name == "keys" {
            return _gen_map_keys(cg, recv_reg)
        }
    }
    // String methods. Each lowers to a libc helper call;
    // extracted into _gen_string_method so the recursive
    // _gen_expr calls live in a separate function — the same
    // recursion-pairing dodge used by _gen_struct_ctor /
    // _gen_list_lit / _gen_list_append.
    if recv_ty == "i8*" {
        if fg.name == "substring" or fg.name == "startswith" or
           fg.name == "endswith" or fg.name == "to_int" {
            return _gen_string_method(cg, fg.name, recv_reg, c.args)
        }
    }
    if fg.name == "str" {
        // Int.str(): snprintf("%d", x) into a 12-byte buffer
        // (max i32 in decimal is 11 chars + null).
        if recv_ty == "i32" {
            cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
            cg.mod.ensure_decl("snprintf",
                "declare i32 @snprintf(i8*, i64, i8*, ...)")
            fmt := cg.mod.alloc_string("%d")
            buf := cg.fresh()
            cg.emit(buf + " = call i8* @malloc(i64 12)")
            fmt_gep := cg.fresh()
            cg.emit(fmt_gep + " = getelementptr inbounds [3 x i8], [3 x i8]* " +
                    fmt + ", i64 0, i64 0")
            ret := cg.fresh()
            cg.emit(ret + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + buf +
                    ", i64 12, i8* " + fmt_gep + ", i32 " + recv_reg + ")")
            return buf
        }
        // Double.str(): snprintf("%g", x) into a 32-byte buffer.
        // %g picks a compact representation (no trailing zeros).
        if recv_ty == "double" {
            cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
            cg.mod.ensure_decl("snprintf",
                "declare i32 @snprintf(i8*, i64, i8*, ...)")
            fmt := cg.mod.alloc_string("%g")
            buf := cg.fresh()
            cg.emit(buf + " = call i8* @malloc(i64 32)")
            fmt_gep := cg.fresh()
            cg.emit(fmt_gep + " = getelementptr inbounds [3 x i8], [3 x i8]* " +
                    fmt + ", i64 0, i64 0")
            ret := cg.fresh()
            cg.emit(ret + " = call i32 (i8*, i64, i8*, ...) @snprintf(i8* " + buf +
                    ", i64 32, i8* " + fmt_gep + ", double " + recv_reg + ")")
            return buf
        }
        // Bool.str(): branch-free `select i1 b, "true"*, "false"*`.
        // The two literals are interned via the same `alloc_string`
        // path string literals use, so they get folded into the
        // module's global table cleanly.
        if recv_ty == "i1" {
            t_name := cg.mod.alloc_string("true")
            f_name := cg.mod.alloc_string("false")
            // `true` is 4 chars + null = 5; `false` is 5 + null = 6.
            // GEP both to their first byte so they share an i8* type.
            t_gep := cg.fresh()
            cg.emit(t_gep + " = getelementptr inbounds [5 x i8], [5 x i8]* " +
                    t_name + ", i64 0, i64 0")
            f_gep := cg.fresh()
            cg.emit(f_gep + " = getelementptr inbounds [6 x i8], [6 x i8]* " +
                    f_name + ", i64 0, i64 0")
            sel := cg.fresh()
            cg.emit(sel + " = select i1 " + recv_reg + ", i8* " + t_gep +
                    ", i8* " + f_gep)
            return sel
        }
    }
    return "<bad-method:" + fg.name + ">"
}

// Lower `xs.append(v)`. Reads the header's length + capacity;
// if they're equal, doubles capacity, reallocs the data
// buffer, and stores the new pointer back. Then writes `v`
// at data[length] and bumps length.
// Pointer-list append. Same shape as `_gen_list_append` but
// the data slot is `i8**` (8-byte elements) and we coerce
// any pointer-typed input to `i8*` via bitcast before
// storing. Sema has already accepted the value as a pointer
// shape for `%QListP*` receivers.
define _gen_listp_append(cg: FnCG, recv_reg: String, args: List) -> String {
    cg.mod.ensure_decl("realloc", "declare i8* @realloc(i8*, i64)")
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    aexpr: Expr := args.__get(0)
    a_ty := _expr_static_ty(cg, aexpr)
    a_val := _gen_expr(cg, aexpr)
    // Coerce to i8* if the static type is some other pointer.
    val_i8 := a_val
    if a_ty != "i8*" {
        if _is_ptr_ty(a_ty) {
            cast := cg.fresh()
            cg.emit(cast + " = bitcast " + a_ty + " " + a_val + " to i8*")
            val_i8 = cast
        }
    }
    // GEPs into the %QListP header.
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QListP, %QListP* " + recv_reg +
            ", i32 0, i32 0")
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QListP, %QListP* " + recv_reg +
            ", i32 0, i32 1")
    data_gep := cg.fresh()
    cg.emit(data_gep + " = getelementptr inbounds %QListP, %QListP* " + recv_reg +
            ", i32 0, i32 2")
    len0 := cg.fresh()
    cg.emit(len0 + " = load i32, i32* " + len_gep)
    cap0 := cg.fresh()
    cg.emit(cap0 + " = load i32, i32* " + cap_gep)
    full := cg.fresh()
    cg.emit(full + " = icmp eq i32 " + len0 + ", " + cap0)
    grow_lbl := cg.fresh_label("appendp.grow")
    write_lbl := cg.fresh_label("appendp.write")
    cg.emit("br i1 " + full + ", label %" + grow_lbl + ", label %" + write_lbl)
    cg.emit_raw(grow_lbl + ":")
    new_cap := cg.fresh()
    cg.emit(new_cap + " = mul nsw i32 " + cap0 + ", 2")
    new_cap64 := cg.fresh()
    cg.emit(new_cap64 + " = sext i32 " + new_cap + " to i64")
    // 8 bytes per i8* (pointer-sized on the test target).
    new_bytes := cg.fresh()
    cg.emit(new_bytes + " = mul nsw i64 " + new_cap64 + ", 8")
    old_data := cg.fresh()
    cg.emit(old_data + " = load i8**, i8*** " + data_gep)
    old_i8 := cg.fresh()
    cg.emit(old_i8 + " = bitcast i8** " + old_data + " to i8*")
    new_raw := cg.fresh()
    cg.emit(new_raw + " = call i8* @realloc(i8* " + old_i8 + ", i64 " + new_bytes + ")")
    new_data := cg.fresh()
    cg.emit(new_data + " = bitcast i8* " + new_raw + " to i8**")
    cg.emit("store i8** " + new_data + ", i8*** " + data_gep)
    cg.emit("store i32 " + new_cap + ", i32* " + cap_gep)
    cg.emit("br label %" + write_lbl)
    cg.emit_raw(write_lbl + ":")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = load i8**, i8*** " + data_gep)
    slot := cg.fresh()
    cg.emit(slot + " = getelementptr inbounds i8*, i8** " + data_ptr + ", i32 " + len0)
    cg.emit("store i8* " + val_i8 + ", i8** " + slot)
    new_len := cg.fresh()
    cg.emit(new_len + " = add nsw i32 " + len0 + ", 1")
    cg.emit("store i32 " + new_len + ", i32* " + len_gep)
    return "0"
}

define _gen_list_append(cg: FnCG, recv_reg: String, args: List) -> String {
    cg.mod.ensure_decl("realloc", "declare i8* @realloc(i8*, i64)")
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    aexpr: Expr := args.__get(0)
    aval := _gen_expr(cg, aexpr)
    // GEPs into header fields.
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QList, %QList* " + recv_reg +
            ", i32 0, i32 0")
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QList, %QList* " + recv_reg +
            ", i32 0, i32 1")
    data_gep := cg.fresh()
    cg.emit(data_gep + " = getelementptr inbounds %QList, %QList* " + recv_reg +
            ", i32 0, i32 2")
    len0 := cg.fresh()
    cg.emit(len0 + " = load i32, i32* " + len_gep)
    cap0 := cg.fresh()
    cg.emit(cap0 + " = load i32, i32* " + cap_gep)
    full := cg.fresh()
    cg.emit(full + " = icmp eq i32 " + len0 + ", " + cap0)
    grow_lbl := cg.fresh_label("append.grow")
    write_lbl := cg.fresh_label("append.write")
    cg.emit("br i1 " + full + ", label %" + grow_lbl + ", label %" + write_lbl)
    // Growth block: new_cap = cap0 * 2, realloc data, store.
    cg.emit_raw(grow_lbl + ":")
    new_cap := cg.fresh()
    cg.emit(new_cap + " = mul nsw i32 " + cap0 + ", 2")
    // sext i32 → i64, then multiply by 4 (bytes per element).
    // `cg.fresh()` assigns SSA numbers in call order, so the
    // sext must be freshed *before* the multiply.
    new_cap64 := cg.fresh()
    cg.emit(new_cap64 + " = sext i32 " + new_cap + " to i64")
    new_bytes64 := cg.fresh()
    cg.emit(new_bytes64 + " = mul nsw i64 " + new_cap64 + ", 4")
    old_data := cg.fresh()
    cg.emit(old_data + " = load i32*, i32** " + data_gep)
    old_i8 := cg.fresh()
    cg.emit(old_i8 + " = bitcast i32* " + old_data + " to i8*")
    new_raw := cg.fresh()
    cg.emit(new_raw + " = call i8* @realloc(i8* " + old_i8 + ", i64 " + new_bytes64 + ")")
    new_data := cg.fresh()
    cg.emit(new_data + " = bitcast i8* " + new_raw + " to i32*")
    cg.emit("store i32* " + new_data + ", i32** " + data_gep)
    cg.emit("store i32 " + new_cap + ", i32* " + cap_gep)
    cg.emit("br label %" + write_lbl)
    // Write block: store at data[len], len++.
    cg.emit_raw(write_lbl + ":")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = load i32*, i32** " + data_gep)
    slot := cg.fresh()
    cg.emit(slot + " = getelementptr inbounds i32, i32* " + data_ptr + ", i32 " + len0)
    cg.emit("store i32 " + aval + ", i32* " + slot)
    new_len := cg.fresh()
    cg.emit(new_len + " = add nsw i32 " + len0 + ", 1")
    cg.emit("store i32 " + new_len + ", i32* " + len_gep)
    return "0"
}

// String method lowering. All four route through libc:
//   .substring(a, b) — malloc(b-a+1), memcpy, null-terminate
//   .startswith(p)   — strncmp(s, p, strlen(p)) == 0
//   .endswith(p)     — compare last strlen(p) bytes of s
//   .to_int()        — atoi
// Extracted into its own helper for the recursion-pairing
// dodge.
define _gen_string_method(cg: FnCG, name: String, recv_reg: String, args: List) -> String {
    if name == "substring" {
        a0e: Expr := args.__get(0)
        a1e: Expr := args.__get(1)
        a := _gen_expr(cg, a0e)
        b := _gen_expr(cg, a1e)
        cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
        cg.mod.ensure_decl("memcpy",
            "declare i8* @memcpy(i8*, i8*, i64)")
        // len = b - a (i32), as i64 for malloc/memcpy sizes.
        len_i32 := cg.fresh()
        cg.emit(len_i32 + " = sub nsw i32 " + b + ", " + a)
        len_i64 := cg.fresh()
        cg.emit(len_i64 + " = sext i32 " + len_i32 + " to i64")
        // +1 for null terminator.
        bytes_i64 := cg.fresh()
        cg.emit(bytes_i64 + " = add nsw i64 " + len_i64 + ", 1")
        buf := cg.fresh()
        cg.emit(buf + " = call i8* @malloc(i64 " + bytes_i64 + ")")
        // Source pointer = recv + a.
        a_i64 := cg.fresh()
        cg.emit(a_i64 + " = sext i32 " + a + " to i64")
        src := cg.fresh()
        cg.emit(src + " = getelementptr inbounds i8, i8* " + recv_reg +
                ", i64 " + a_i64)
        // memcpy copies len bytes (the null is set separately so
        // we don't depend on the source having one mid-string).
        cpy := cg.fresh()
        cg.emit(cpy + " = call i8* @memcpy(i8* " + buf + ", i8* " + src +
                ", i64 " + len_i64 + ")")
        // Null-terminate at buf[len].
        nul_slot := cg.fresh()
        cg.emit(nul_slot + " = getelementptr inbounds i8, i8* " + buf +
                ", i64 " + len_i64)
        cg.emit("store i8 0, i8* " + nul_slot)
        return buf
    }
    if name == "startswith" {
        ae: Expr := args.__get(0)
        prefix := _gen_expr(cg, ae)
        cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
        cg.mod.ensure_decl("strncmp",
            "declare i32 @strncmp(i8*, i8*, i64)")
        plen := cg.fresh()
        cg.emit(plen + " = call i64 @strlen(i8* " + prefix + ")")
        cmp := cg.fresh()
        cg.emit(cmp + " = call i32 @strncmp(i8* " + recv_reg +
                ", i8* " + prefix + ", i64 " + plen + ")")
        reg := cg.fresh()
        cg.emit(reg + " = icmp eq i32 " + cmp + ", 0")
        return reg
    }
    if name == "endswith" {
        ae: Expr := args.__get(0)
        suffix := _gen_expr(cg, ae)
        cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
        cg.mod.ensure_decl("strncmp",
            "declare i32 @strncmp(i8*, i8*, i64)")
        slen := cg.fresh()
        cg.emit(slen + " = call i64 @strlen(i8* " + recv_reg + ")")
        sufl := cg.fresh()
        cg.emit(sufl + " = call i64 @strlen(i8* " + suffix + ")")
        // suffix longer than s → false. The `select` branchless
        // form would also work, but a real `br i1` clarifies
        // the IR shape.
        too_long := cg.fresh()
        cg.emit(too_long + " = icmp ugt i64 " + sufl + ", " + slen)
        false_lbl := cg.fresh_label("ends.short")
        cmp_lbl   := cg.fresh_label("ends.cmp")
        end_lbl   := cg.fresh_label("ends.done")
        cg.emit("br i1 " + too_long + ", label %" + false_lbl + ", label %" + cmp_lbl)
        cg.emit_raw(cmp_lbl + ":")
        // tail pointer = s + (slen - sufl).
        delta := cg.fresh()
        cg.emit(delta + " = sub nsw i64 " + slen + ", " + sufl)
        tail := cg.fresh()
        cg.emit(tail + " = getelementptr inbounds i8, i8* " + recv_reg +
                ", i64 " + delta)
        cmpres := cg.fresh()
        cg.emit(cmpres + " = call i32 @strncmp(i8* " + tail +
                ", i8* " + suffix + ", i64 " + sufl + ")")
        cmp_ok := cg.fresh()
        cg.emit(cmp_ok + " = icmp eq i32 " + cmpres + ", 0")
        cg.emit("br label %" + end_lbl)
        cg.emit_raw(false_lbl + ":")
        cg.emit("br label %" + end_lbl)
        cg.emit_raw(end_lbl + ":")
        phi := cg.fresh()
        cg.emit(phi + " = phi i1 [ " + cmp_ok + ", %" + cmp_lbl +
                " ], [ false, %" + false_lbl + " ]")
        return phi
    }
    if name == "to_int" {
        cg.mod.ensure_decl("atoi", "declare i32 @atoi(i8*)")
        reg := cg.fresh()
        cg.emit(reg + " = call i32 @atoi(i8* " + recv_reg + ")")
        return reg
    }
    return "0"
}

// Read an entire file into a heap-allocated null-terminated
// buffer. Sequence: fopen("r") → fseek end → ftell size →
// fseek back → malloc(size+1) → fread → null-terminate →
// fclose → return buf. No error handling yet — a missing
// file is undefined behaviour for now.
// eprint(s) — write(2, s, strlen(s)) then write a "\n".
// Extracted helper for the same recursion-pairing reason as
// _gen_arg_get / _gen_read_file. Returns "0" to satisfy
// _gen_expr's String-typed contract; the actual return value
// is never consumed since eprint is used statement-side.
define _gen_eprint(cg: FnCG, args: List) -> String {
    cg.mod.ensure_decl("write",  "declare i64 @write(i32, i8*, i64)")
    cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
    se: Expr := args.__get(0)
    s := _gen_expr(cg, se)
    slen := cg.fresh()
    cg.emit(slen + " = call i64 @strlen(i8* " + s + ")")
    w1 := cg.fresh()
    cg.emit(w1 + " = call i64 @write(i32 2, i8* " + s + ", i64 " + slen + ")")
    // The "\n" lives in a private global; alloc_string interns
    // it the same way print's string literals are interned.
    nl_name := cg.mod.alloc_string("\n")
    nl_gep := cg.fresh()
    cg.emit(nl_gep + " = getelementptr inbounds [2 x i8], [2 x i8]* " +
            nl_name + ", i64 0, i64 0")
    w2 := cg.fresh()
    cg.emit(w2 + " = call i64 @write(i32 2, i8* " + nl_gep + ", i64 1)")
    return "0"
}

// arg_get(i) — GEP into @quirk_argv. Lives in its own
// function so the inline `_gen_expr` call for the index
// expression is isolated from the outer-function recursion
// sites in `_gen_expr` itself.
define _gen_arg_get(cg: FnCG, args: List) -> String {
    cg.mod.ensure_decl("quirk_argv", "@quirk_argv = global i8** null")
    ie: Expr := args.__get(0)
    idx := _gen_expr(cg, ie)
    av := cg.fresh()
    cg.emit(av + " = load i8**, i8*** @quirk_argv")
    slot := cg.fresh()
    cg.emit(slot + " = getelementptr inbounds i8*, i8** " + av +
            ", i32 " + idx)
    reg := cg.fresh()
    cg.emit(reg + " = load i8*, i8** " + slot)
    return reg
}

define _gen_read_file(cg: FnCG, args: List) -> String {
    cg.mod.ensure_decl("fopen",  "declare i8* @fopen(i8*, i8*)")
    cg.mod.ensure_decl("fclose", "declare i32 @fclose(i8*)")
    cg.mod.ensure_decl("fseek",  "declare i32 @fseek(i8*, i64, i32)")
    cg.mod.ensure_decl("ftell",  "declare i64 @ftell(i8*)")
    cg.mod.ensure_decl("fread",  "declare i64 @fread(i8*, i64, i64, i8*)")
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    pexpr: Expr := args.__get(0)
    path := _gen_expr(cg, pexpr)
    // "r" mode string interned as a private global.
    mode_name := cg.mod.alloc_string("r")
    mode_gep := cg.fresh()
    cg.emit(mode_gep + " = getelementptr inbounds [2 x i8], [2 x i8]* " +
            mode_name + ", i64 0, i64 0")
    fp := cg.fresh()
    cg.emit(fp + " = call i8* @fopen(i8* " + path + ", i8* " + mode_gep + ")")
    // Seek to end, ftell for size, seek back.
    seek_end := cg.fresh()
    cg.emit(seek_end + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 2)")
    size := cg.fresh()
    cg.emit(size + " = call i64 @ftell(i8* " + fp + ")")
    seek_start := cg.fresh()
    cg.emit(seek_start + " = call i32 @fseek(i8* " + fp + ", i64 0, i32 0)")
    // Allocate size+1 bytes, fread the content.
    alloc_size := cg.fresh()
    cg.emit(alloc_size + " = add nsw i64 " + size + ", 1")
    buf := cg.fresh()
    cg.emit(buf + " = call i8* @malloc(i64 " + alloc_size + ")")
    read_n := cg.fresh()
    cg.emit(read_n + " = call i64 @fread(i8* " + buf + ", i64 1, i64 " +
            size + ", i8* " + fp + ")")
    // Null-terminate at buf[size].
    nul_slot := cg.fresh()
    cg.emit(nul_slot + " = getelementptr inbounds i8, i8* " + buf +
            ", i64 " + size)
    cg.emit("store i8 0, i8* " + nul_slot)
    closed := cg.fresh()
    cg.emit(closed + " = call i32 @fclose(i8* " + fp + ")")
    return buf
}

// Write a String to a file. Sequence: fopen("w") → strlen
// → fwrite → fclose → return 0.
define _gen_write_file(cg: FnCG, args: List) -> String {
    cg.mod.ensure_decl("fopen",  "declare i8* @fopen(i8*, i8*)")
    cg.mod.ensure_decl("fclose", "declare i32 @fclose(i8*)")
    cg.mod.ensure_decl("fwrite", "declare i64 @fwrite(i8*, i64, i64, i8*)")
    cg.mod.ensure_decl("strlen", "declare i64 @strlen(i8*)")
    p_expr: Expr := args.__get(0)
    c_expr: Expr := args.__get(1)
    path := _gen_expr(cg, p_expr)
    content := _gen_expr(cg, c_expr)
    mode_name := cg.mod.alloc_string("w")
    mode_gep := cg.fresh()
    cg.emit(mode_gep + " = getelementptr inbounds [2 x i8], [2 x i8]* " +
            mode_name + ", i64 0, i64 0")
    fp := cg.fresh()
    cg.emit(fp + " = call i8* @fopen(i8* " + path + ", i8* " + mode_gep + ")")
    len_i := cg.fresh()
    cg.emit(len_i + " = call i64 @strlen(i8* " + content + ")")
    written := cg.fresh()
    cg.emit(written + " = call i64 @fwrite(i8* " + content + ", i64 1, i64 " +
            len_i + ", i8* " + fp + ")")
    closed := cg.fresh()
    cg.emit(closed + " = call i32 @fclose(i8* " + fp + ")")
    return "0"
}

// Map method lowering. `.put`, `.get`, `.has` all linearly
// scan the entries array via strcmp on each key. .put grows
// via realloc when length == capacity. Values flow as i8*
// (Any) — callers' VarDecl annotation honoring inserts the
// bitcast to the binding's type.
//
// Extracted from `_gen_method_call` for the recursion-pairing
// dodge: each helper has its own `_gen_expr(arg)` site so
// the parent function doesn't carry the same nested-call
// shape multiple times.
//
// Update method semantics: .put overwrites an existing key's
// value rather than inserting a duplicate (so map state stays
// internally consistent across re-puts).
define _gen_map_method(cg: FnCG, name: String, recv_reg: String, args: List) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    cg.mod.ensure_decl("realloc", "declare i8* @realloc(i8*, i64)")
    cg.mod.ensure_decl("strcmp", "declare i32 @strcmp(i8*, i8*)")
    // Gen the key arg first. Common to all three.
    key_expr: Expr := args.__get(0)
    key_reg := _gen_expr(cg, key_expr)
    // For .put, also gen the value arg and coerce to i8* via
    // bitcast (it's always a pointer because String/struct/
    // union values lower to pointers in this codegen).
    val_reg := ""
    val_ty := ""
    if name == "put" {
        val_expr: Expr := args.__get(1)
        val_reg = _gen_expr(cg, val_expr)
        val_ty = _expr_static_ty(cg, val_expr)
    }
    // Load the entries pointer + length once.
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
            ", i32 0, i32 0")
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
            ", i32 0, i32 1")
    ent_gep := cg.fresh()
    cg.emit(ent_gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
            ", i32 0, i32 2")
    cur_len := cg.fresh()
    cg.emit(cur_len + " = load i32, i32* " + len_gep)
    ents := cg.fresh()
    cg.emit(ents + " = load %QMapKV*, %QMapKV** " + ent_gep)
    // Coerce value to i8* before any branching so the
    // bitcast register has a stable SSA position.
    val_i8 := ""
    if name == "put" {
        if val_ty == "i8*" {
            val_i8 = val_reg
        } else {
            val_i8 = cg.fresh()
            cg.emit(val_i8 + " = bitcast " + val_ty + " " + val_reg + " to i8*")
        }
    }
    // Linear scan: walk i from 0 to len, compare keys.
    // Allocate stack slots for loop state. NAMED slots
    // (`%map.idx.N`) instead of `cg.fresh()` numbered slots
    // because the numbered counter is shared across entry +
    // body buffers — entry-block allocations issued later than
    // body work would land "out of order" in the final IR
    // and LLVM rejects with "instruction expected to be
    // numbered '%X'". Named slots dodge the issue.
    idx_slot := "%" + cg.fresh_label("map.idx")
    cg.emit_entry(idx_slot + " = alloca i32")
    cg.emit("store i32 0, i32* " + idx_slot)
    // Result slot (used for .get and .has).
    res_slot := ""
    if name == "get" {
        res_slot = "%" + cg.fresh_label("map.res")
        cg.emit_entry(res_slot + " = alloca i8*")
        cg.emit("store i8* null, i8** " + res_slot)
    }
    if name == "has" {
        res_slot = "%" + cg.fresh_label("map.res")
        cg.emit_entry(res_slot + " = alloca i1")
        cg.emit("store i1 0, i1* " + res_slot)
    }
    head := cg.fresh_label("map.scan.head")
    body := cg.fresh_label("map.scan.body")
    hit  := cg.fresh_label("map.scan.hit")
    miss := cg.fresh_label("map.scan.miss")
    cont := cg.fresh_label("map.scan.next")
    done := cg.fresh_label("map.scan.done")
    cg.emit("br label %" + head)
    cg.emit_raw(head + ":")
    i_cur := cg.fresh()
    cg.emit(i_cur + " = load i32, i32* " + idx_slot)
    in_range := cg.fresh()
    cg.emit(in_range + " = icmp slt i32 " + i_cur + ", " + cur_len)
    cg.emit("br i1 " + in_range + ", label %" + body + ", label %" + miss)
    cg.emit_raw(body + ":")
    // Compare entries[i].key to the lookup key.
    kgep := cg.fresh()
    cg.emit(kgep + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents +
            ", i32 " + i_cur + ", i32 0")
    kcur := cg.fresh()
    cg.emit(kcur + " = load i8*, i8** " + kgep)
    cmp := cg.fresh()
    cg.emit(cmp + " = call i32 @strcmp(i8* " + kcur + ", i8* " + key_reg + ")")
    iseq := cg.fresh()
    cg.emit(iseq + " = icmp eq i32 " + cmp + ", 0")
    cg.emit("br i1 " + iseq + ", label %" + hit + ", label %" + cont)
    cg.emit_raw(hit + ":")
    if name == "put" {
        // Overwrite existing entry's value.
        vgep := cg.fresh()
        cg.emit(vgep + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents +
                ", i32 " + i_cur + ", i32 1")
        cg.emit("store i8* " + val_i8 + ", i8** " + vgep)
    }
    if name == "get" {
        // Return the matching value.
        vgep := cg.fresh()
        cg.emit(vgep + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents +
                ", i32 " + i_cur + ", i32 1")
        vval := cg.fresh()
        cg.emit(vval + " = load i8*, i8** " + vgep)
        cg.emit("store i8* " + vval + ", i8** " + res_slot)
    }
    if name == "has" {
        cg.emit("store i1 1, i1* " + res_slot)
    }
    cg.emit("br label %" + done)
    cg.emit_raw(cont + ":")
    next_i := cg.fresh()
    cg.emit(next_i + " = add nsw i32 " + i_cur + ", 1")
    cg.emit("store i32 " + next_i + ", i32* " + idx_slot)
    cg.emit("br label %" + head)
    cg.emit_raw(miss + ":")
    // Key not in map. For .put, append (growing if needed).
    if name == "put" {
        cur_cap := cg.fresh()
        cg.emit(cur_cap + " = load i32, i32* " + cap_gep)
        full := cg.fresh()
        cg.emit(full + " = icmp eq i32 " + cur_len + ", " + cur_cap)
        grow := cg.fresh_label("map.put.grow")
        write := cg.fresh_label("map.put.write")
        cg.emit("br i1 " + full + ", label %" + grow + ", label %" + write)
        cg.emit_raw(grow + ":")
        new_cap := cg.fresh()
        cg.emit(new_cap + " = mul nsw i32 " + cur_cap + ", 2")
        new_cap64 := cg.fresh()
        cg.emit(new_cap64 + " = sext i32 " + new_cap + " to i64")
        // Each entry is 16 bytes (two i8* on x86_64).
        new_bytes := cg.fresh()
        cg.emit(new_bytes + " = mul nsw i64 " + new_cap64 + ", 16")
        old_i8 := cg.fresh()
        cg.emit(old_i8 + " = bitcast %QMapKV* " + ents + " to i8*")
        new_raw := cg.fresh()
        cg.emit(new_raw + " = call i8* @realloc(i8* " + old_i8 +
                ", i64 " + new_bytes + ")")
        new_ents := cg.fresh()
        cg.emit(new_ents + " = bitcast i8* " + new_raw + " to %QMapKV*")
        cg.emit("store %QMapKV* " + new_ents + ", %QMapKV** " + ent_gep)
        cg.emit("store i32 " + new_cap + ", i32* " + cap_gep)
        cg.emit("br label %" + write)
        cg.emit_raw(write + ":")
        // Re-load the (possibly relocated) entries pointer.
        ents2 := cg.fresh()
        cg.emit(ents2 + " = load %QMapKV*, %QMapKV** " + ent_gep)
        // Store key + value at entries[cur_len], bump length.
        kslot := cg.fresh()
        cg.emit(kslot + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents2 +
                ", i32 " + cur_len + ", i32 0")
        cg.emit("store i8* " + key_reg + ", i8** " + kslot)
        vslot := cg.fresh()
        cg.emit(vslot + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents2 +
                ", i32 " + cur_len + ", i32 1")
        cg.emit("store i8* " + val_i8 + ", i8** " + vslot)
        bumped := cg.fresh()
        cg.emit(bumped + " = add nsw i32 " + cur_len + ", 1")
        cg.emit("store i32 " + bumped + ", i32* " + len_gep)
    }
    cg.emit("br label %" + done)
    cg.emit_raw(done + ":")
    if name == "get" {
        result := cg.fresh()
        cg.emit(result + " = load i8*, i8** " + res_slot)
        return result
    }
    if name == "has" {
        result := cg.fresh()
        cg.emit(result + " = load i1, i1* " + res_slot)
        return result
    }
    return "0"
}

// Create an empty `%QList` (length=0, capacity=1, a 4-byte
// data buffer) so .append has somewhere to land before its
// first growth.
define _gen_list_new(cg: FnCG) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 12)")
    base := cg.fresh()
    cg.emit(base + " = bitcast i8* " + raw + " to %QList*")
    data_raw := cg.fresh()
    cg.emit(data_raw + " = call i8* @malloc(i64 4)")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = bitcast i8* " + data_raw + " to i32*")
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 0")
    cg.emit("store i32 0, i32* " + len_gep)
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 1")
    cg.emit("store i32 1, i32* " + cap_gep)
    dat_gep := cg.fresh()
    cg.emit(dat_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 2")
    cg.emit("store i32* " + data_ptr + ", i32** " + dat_gep)
    return base
}

// Create an empty `%QListP` (pointer-element list, length=0,
// capacity=1, an 8-byte initial data buffer for a single
// i8* slot). Symmetric to `_gen_list_new` but with pointer-
// sized element storage so .append can push struct/string
// pointers without boxing.
define _gen_listp_new(cg: FnCG) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 12)")
    base := cg.fresh()
    cg.emit(base + " = bitcast i8* " + raw + " to %QListP*")
    // Initial data: 1 slot × 8 bytes (one i8*).
    data_raw := cg.fresh()
    cg.emit(data_raw + " = call i8* @malloc(i64 8)")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = bitcast i8* " + data_raw + " to i8**")
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 0")
    cg.emit("store i32 0, i32* " + len_gep)
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 1")
    cg.emit("store i32 1, i32* " + cap_gep)
    dat_gep := cg.fresh()
    cg.emit(dat_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 2")
    cg.emit("store i8** " + data_ptr + ", i8*** " + dat_gep)
    return base
}

// Build a fresh `%QListP*` of `i8*` keys from a `%QMap*`.
// Reads the map's length + entries, allocates a list with
// capacity = max(length+1, 1), then walks i ∈ [0, length)
// and copies each entry's key into the list's data buffer.
define _gen_map_keys(cg: FnCG, recv_reg: String) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    // Load map length + entries.
    mlen_gep := cg.fresh()
    cg.emit(mlen_gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
            ", i32 0, i32 0")
    mlen := cg.fresh()
    cg.emit(mlen + " = load i32, i32* " + mlen_gep)
    ment_gep := cg.fresh()
    cg.emit(ment_gep + " = getelementptr inbounds %QMap, %QMap* " + recv_reg +
            ", i32 0, i32 2")
    ents := cg.fresh()
    cg.emit(ents + " = load %QMapKV*, %QMapKV** " + ment_gep)
    // Allocate the %QListP* header (12 bytes).
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 12)")
    base := cg.fresh()
    cg.emit(base + " = bitcast i8* " + raw + " to %QListP*")
    // Allocate the data buffer. cap = mlen + 1 (always >= 1 slot)
    // bytes = cap * 8 (i8* on x86_64).
    cap_plus := cg.fresh()
    cg.emit(cap_plus + " = add nsw i32 " + mlen + ", 1")
    cap64 := cg.fresh()
    cg.emit(cap64 + " = sext i32 " + cap_plus + " to i64")
    bytes := cg.fresh()
    cg.emit(bytes + " = mul nsw i64 " + cap64 + ", 8")
    data_raw := cg.fresh()
    cg.emit(data_raw + " = call i8* @malloc(i64 " + bytes + ")")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = bitcast i8* " + data_raw + " to i8**")
    // Fill header: length, capacity, data.
    lp_len_gep := cg.fresh()
    cg.emit(lp_len_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 0")
    cg.emit("store i32 " + mlen + ", i32* " + lp_len_gep)
    lp_cap_gep := cg.fresh()
    cg.emit(lp_cap_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 1")
    cg.emit("store i32 " + cap_plus + ", i32* " + lp_cap_gep)
    lp_dat_gep := cg.fresh()
    cg.emit(lp_dat_gep + " = getelementptr inbounds %QListP, %QListP* " + base +
            ", i32 0, i32 2")
    cg.emit("store i8** " + data_ptr + ", i8*** " + lp_dat_gep)
    // Loop i from 0 to mlen-1, copy keys into data buffer.
    // Entry-block alloca + named slot to match the map.idx pattern.
    idx_slot := "%" + cg.fresh_label("keys.idx")
    cg.emit_entry(idx_slot + " = alloca i32")
    cg.emit("store i32 0, i32* " + idx_slot)
    head := cg.fresh_label("keys.scan.head")
    body := cg.fresh_label("keys.scan.body")
    done := cg.fresh_label("keys.scan.done")
    cg.emit("br label %" + head)
    cg.emit_raw(head + ":")
    i_cur := cg.fresh()
    cg.emit(i_cur + " = load i32, i32* " + idx_slot)
    in_range := cg.fresh()
    cg.emit(in_range + " = icmp slt i32 " + i_cur + ", " + mlen)
    cg.emit("br i1 " + in_range + ", label %" + body + ", label %" + done)
    cg.emit_raw(body + ":")
    kgep := cg.fresh()
    cg.emit(kgep + " = getelementptr inbounds %QMapKV, %QMapKV* " + ents +
            ", i32 " + i_cur + ", i32 0")
    key := cg.fresh()
    cg.emit(key + " = load i8*, i8** " + kgep)
    slot := cg.fresh()
    cg.emit(slot + " = getelementptr inbounds i8*, i8** " + data_ptr +
            ", i32 " + i_cur)
    cg.emit("store i8* " + key + ", i8** " + slot)
    next_i := cg.fresh()
    cg.emit(next_i + " = add nsw i32 " + i_cur + ", 1")
    cg.emit("store i32 " + next_i + ", i32* " + idx_slot)
    cg.emit("br label %" + head)
    cg.emit_raw(done + ":")
    return base
}

// Create an empty `%QMap` (length=0, capacity=4, an entry
// buffer big enough for 4 KV pairs).
define _gen_map_new(cg: FnCG) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    // Header: i32 length + i32 capacity + %QMapKV* entries = 16 bytes.
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 16)")
    base := cg.fresh()
    cg.emit(base + " = bitcast i8* " + raw + " to %QMap*")
    // Initial entry buffer: 4 entries × 16 bytes (2 i8* per
    // entry) = 64 bytes.
    ent_raw := cg.fresh()
    cg.emit(ent_raw + " = call i8* @malloc(i64 64)")
    ent_ptr := cg.fresh()
    cg.emit(ent_ptr + " = bitcast i8* " + ent_raw + " to %QMapKV*")
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QMap, %QMap* " + base +
            ", i32 0, i32 0")
    cg.emit("store i32 0, i32* " + len_gep)
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QMap, %QMap* " + base +
            ", i32 0, i32 1")
    cg.emit("store i32 4, i32* " + cap_gep)
    ent_gep := cg.fresh()
    cg.emit(ent_gep + " = getelementptr inbounds %QMap, %QMap* " + base +
            ", i32 0, i32 2")
    cg.emit("store %QMapKV* " + ent_ptr + ", %QMapKV** " + ent_gep)
    return base
}

// Lower a list literal `[a, b, c]` to a heap-allocated
// `%QList { length, capacity, data* }` plus a separate
// element-array allocation. Two mallocs: one 12-byte header,
// one N*4-byte data buffer pointed to by `data`. Capacity
// starts at N (or 1 for the empty literal so the first
// append has somewhere to land before growth). Returns the
// `%QList*` header pointer. Both buffers leak (same trade-off
// as the string-concat allocator).
define _gen_list_lit(cg: FnCG, elems: List) -> String {
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    n := elems.length()
    cap := n
    if cap < 1 { cap = 1 }
    // 12-byte header: i32 length + i32 capacity + i32* data.
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 12)")
    base := cg.fresh()
    cg.emit(base + " = bitcast i8* " + raw + " to %QList*")
    // Allocate the data buffer separately so .append can
    // realloc it without invalidating the header pointer.
    data_bytes := cap * 4
    data_raw := cg.fresh()
    cg.emit(data_raw + " = call i8* @malloc(i64 " + data_bytes.str() + ")")
    data_ptr := cg.fresh()
    cg.emit(data_ptr + " = bitcast i8* " + data_raw + " to i32*")
    // Store length, capacity, data into header fields.
    len_gep := cg.fresh()
    cg.emit(len_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 0")
    cg.emit("store i32 " + n.str() + ", i32* " + len_gep)
    cap_gep := cg.fresh()
    cg.emit(cap_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 1")
    cg.emit("store i32 " + cap.str() + ", i32* " + cap_gep)
    data_field_gep := cg.fresh()
    cg.emit(data_field_gep + " = getelementptr inbounds %QList, %QList* " + base +
            ", i32 0, i32 2")
    cg.emit("store i32* " + data_ptr + ", i32** " + data_field_gep)
    // Populate the data buffer.
    i := 0
    while i < elems.length() {
        ei: Expr := elems.__get(i)
        ev := _gen_expr(cg, ei)
        gep := cg.fresh()
        cg.emit(gep + " = getelementptr inbounds i32, i32* " + data_ptr +
                ", i32 " + i.str())
        cg.emit("store i32 " + ev + ", i32* " + gep)
        i = i + 1
    }
    return base
}

// Lower a `match` statement. Strategy:
//   1. Evaluate the scrutinee once (`%struct.T*`).
//   2. Load the tag (field 0) out of the union's base struct.
//   3. For each variant arm: compare tag, conditional branch
//      to an arm-body label or the next-check label.
//   4. Wildcard arm (if present) catches the remaining flow.
//   5. Each arm body bitcasts the scrutinee to the synthetic
//      `%struct.T__V*` and stores it into a fresh local slot
//      so `binder.field` works through normal field-access
//      codegen. After the body, branch to the join label.
// Sema has already validated that pattern names are real
// variants of the scrutinee's union.
define _gen_match(cg: FnCG, m: Match) -> void {
    // Pre-resolve scrutinee type and value. Type is some
    // `%struct.T*`; we only need T's name to look up the
    // union's variant list for tag values.
    scrut_ty := _expr_static_ty(cg, m.scrutinee)
    scrut_reg := _gen_expr(cg, m.scrutinee)
    uname := _strip_struct_ptr(scrut_ty)
    udecl: UnionDecl := cg.mod.unions.get(uname)
    // Load the tag once. All arms compare against this.
    tag_gep := cg.fresh()
    cg.emit(tag_gep + " = getelementptr inbounds %struct." + uname +
            ", %struct." + uname + "* " + scrut_reg + ", i32 0, i32 0")
    tag := cg.fresh()
    cg.emit(tag + " = load i32, i32* " + tag_gep)
    end_lbl := cg.fresh_label("match.end")
    // Walk arms. For each variant arm, emit a tag check and
    // a body block. Wildcard takes the final fall-through.
    i := 0
    while i < m.arms.length() {
        arm: MatchArm := m.arms.__get(i)
        body_lbl := cg.fresh_label("match.arm")
        next_lbl := cg.fresh_label("match.next")
        if arm.pattern == "" {
            // Wildcard: unconditional jump into the body.
            cg.emit("br label %" + body_lbl)
        } else {
            // Find the variant's tag ordinal.
            tag_val := 0
            vi := 0
            while vi < udecl.variants.length() {
                v: Variant := udecl.variants.__get(vi)
                if v.name == arm.pattern { tag_val = vi }
                vi = vi + 1
            }
            cmp := cg.fresh()
            cg.emit(cmp + " = icmp eq i32 " + tag + ", " + tag_val.str())
            cg.emit("br i1 " + cmp + ", label %" + body_lbl + ", label %" + next_lbl)
        }
        cg.emit_raw(body_lbl + ":")
        // Bind the binder (if any): bitcast scrutinee to the
        // synthetic variant struct and store into a slot. The
        // user's `binder.field` codegen reaches it through the
        // normal Ident → load → FieldGet path.
        // Save any prior cg.locals binding for `binder` so
        // nested matches don't permanently shadow the outer
        // scope's slot.
        had_prior := false
        prior_slot := _Slot("", "")
        if arm.pattern != "" and arm.binder != "_" {
            if cg.locals.has(arm.binder) {
                had_prior = true
                prior_slot = cg.locals.get(arm.binder)
            }
            syn := uname + "__" + arm.pattern
            syn_ty := "%struct." + syn + "*"
            cast_reg := cg.fresh()
            cg.emit(cast_reg + " = bitcast %struct." + uname + "* " + scrut_reg +
                    " to " + syn_ty)
            // Each arm needs its OWN alloca — re-using the
            // same `%binder.addr` slot across arms with
            // different variant types produces type-mismatched
            // stores. Derive a unique slot name from the arm's
            // body label so distinct arms get distinct allocas.
            slot_name := "%" + body_lbl + "." + arm.binder + ".addr"
            cg.emit_entry(slot_name + " = alloca " + syn_ty)
            cg.locals.put(arm.binder, _Slot(slot_name, syn_ty))
            cg.emit("store " + syn_ty + " " + cast_reg + ", " + syn_ty + "* " + slot_name)
        }
        // Arm body.
        bi := 0
        while bi < arm.body.length() {
            bs: Stmt := arm.body.__get(bi)
            _gen_stmt(cg, bs)
            bi = bi + 1
        }
        // Restore the binder's prior cg.locals entry if there
        // was one — without this, a nested match arm whose
        // pattern reuses an outer binder name would leave the
        // inner slot in place. We don't actively remove the
        // entry when there was no prior binding because the
        // ambient `_ensure_slot` logic detects type mismatch
        // and allocates a fresh slot anyway.
        if arm.pattern != "" and arm.binder != "_" {
            if had_prior {
                cg.locals.put(arm.binder, prior_slot)
            }
        }
        // Fall through to the join label unless the body
        // already terminated (return / unconditional br).
        cg.emit("br label %" + end_lbl)
        // Open the next-check block. If this was a wildcard,
        // the next block is just unreachable scaffolding —
        // emit a `br label %end_lbl` so LLVM doesn't complain.
        cg.emit_raw(next_lbl + ":")
        if arm.pattern == "" {
            cg.emit("br label %" + end_lbl)
        }
        i = i + 1
    }
    // Default fall-through if no wildcard arm was provided —
    // the last `next_lbl` block has no terminator yet.
    cg.emit("br label %" + end_lbl)
    cg.emit_raw(end_lbl + ":")
}

// Lower a variant constructor `V(args)`. Mallocs the
// synthetic `T__V` struct (sized via GEP-of-null), stores
// the discriminator tag at field 0 and user args at fields
// 1..N, then bitcasts the result to `%struct.T*` so callers
// see the union's base pointer type. Bitcast vs `_gen_struct_ctor`
// is the only structural difference.
define _gen_variant_ctor(cg: FnCG, name: String, ctor_args: List) -> String {
    vci: _VarCgInfo := cg.mod.variants.get(name)
    syn_name := vci.union_name + "__" + name
    sd: _StructDef := cg.mod.structs.get(syn_name)
    cg.mod.ensure_decl("malloc", "declare i8* @malloc(i64)")
    // sizeof(%struct.T__V) via GEP-of-null.
    size_gep := cg.fresh()
    cg.emit(size_gep + " = getelementptr %struct." + syn_name +
            ", %struct." + syn_name + "* null, i64 1")
    size_i := cg.fresh()
    cg.emit(size_i + " = ptrtoint %struct." + syn_name +
            "* " + size_gep + " to i64")
    raw := cg.fresh()
    cg.emit(raw + " = call i8* @malloc(i64 " + size_i + ")")
    obj := cg.fresh()
    cg.emit(obj + " = bitcast i8* " + raw + " to %struct." + syn_name + "*")
    // Tag at field 0.
    tag_gep := cg.fresh()
    cg.emit(tag_gep + " = getelementptr inbounds %struct." + syn_name +
            ", %struct." + syn_name + "* " + obj +
            ", i32 0, i32 0")
    cg.emit("store i32 " + vci.tag.str() + ", i32* " + tag_gep)
    // User fields at 1..N (synthetic struct's field_llvm_tys
    // is [i32 (tag), ...userTys]).
    ai := 0
    while ai < ctor_args.length() {
        aexpr: Expr := ctor_args.__get(ai)
        aval := _gen_expr(cg, aexpr)
        fty: String := sd.field_llvm_tys.__get(ai + 1)
        fgep := cg.fresh()
        cg.emit(fgep + " = getelementptr inbounds %struct." + syn_name +
                ", %struct." + syn_name + "* " + obj +
                ", i32 0, i32 " + (ai + 1).str())
        cg.emit("store " + fty + " " + aval + ", " + fty + "* " + fgep)
        ai = ai + 1
    }
    // Bitcast to the union's base pointer type so external
    // callers see `%struct.T*`.
    upcast := cg.fresh()
    cg.emit(upcast + " = bitcast %struct." + syn_name + "* " + obj +
            " to %struct." + vci.union_name + "*")
    return upcast
}

// Lower a field assignment `obj.name = value`. Symmetric to
// FieldGet's lowering in `_gen_expr` — GEP the field address,
// then `store` the RHS at the field's LLVM type. Extracted from
// `_gen_stmt` so the inner recursive `_gen_expr` calls
// (for `obj` and `value`) sit in a function of their own,
// matching the same self-compiler workaround pattern as
// `_gen_struct_ctor`.
define _gen_field_set(cg: FnCG, obj: Expr, name: String, value: Expr) -> void {
    obj_ty := _expr_static_ty(cg, obj)
    obj_reg := _gen_expr(cg, obj)
    val_reg := _gen_expr(cg, value)
    sname := _strip_struct_ptr(obj_ty)
    sd: _StructDef := cg.mod.structs.get(sname)
    idx := 0
    field_ty := "i32"
    fi := 0
    while fi < sd.field_names.length() {
        fname: String := sd.field_names.__get(fi)
        if fname == name {
            idx = fi
            field_ty = sd.field_llvm_tys.__get(fi)
        }
        fi = fi + 1
    }
    gep := cg.fresh()
    cg.emit(gep + " = getelementptr inbounds %struct." + sname +
            ", %struct." + sname + "* " + obj_reg +
            ", i32 0, i32 " + idx.str())
    cg.emit("store " + field_ty + " " + val_reg + ", " + field_ty + "* " + gep)
}

// Return type of a method call given the receiver's LLVM type
// and the method name. Used by both `_gen_method_call` (the
// lowering side) and `_expr_static_ty` (so a `s := ln.str()`
// binding gets the right slot type). Returns "i32" as a
// conservative default for unknown methods — sema will have
// already rejected them, so this fallthrough should be
// unreachable at compile time of valid programs.
define _method_ret_ty(cg: FnCG, recv_ty: String, method: String) -> String {
    // User-defined struct method: look up the mangled signature.
    sname := _strip_struct_ptr(recv_ty)
    if cg.mod.structs.has(sname) {
        full := sname + "__" + method
        if cg.mod.sigs.has(full) {
            sig: _Sig := cg.mod.sigs.get(full)
            return sig.ret_ty
        }
    }
    if method == "length" { return "i32" }
    if method == "append" { return "i32" }
    if method == "to_int" { return "i32" }
    // `.__get(i)` returns i32 for `%QList*` (Int-element) and
    // i8* for `%QListP*` (pointer-element). The receiver's
    // LLVM type tells us which.
    if method == "__get" {
        if recv_ty == "%QListP*" { return "i8*" }
        return "i32"
    }
    if method == "pop" {
        if recv_ty == "%QListP*" { return "i8*" }
        return "i32"
    }
    if method == "str" { return "i8*" }
    if method == "substring" { return "i8*" }
    if method == "startswith" { return "i1" }
    if method == "endswith" { return "i1" }
    // Map: .get returns i8* (Any), .has returns i1, .put i32,
    // .keys returns a fresh %QListP* of i8* keys.
    if method == "get" { return "i8*" }
    if method == "has" { return "i1" }
    if method == "put" { return "i32" }
    if method == "keys" { return "%QListP*" }
    return "i32"
}

// Quick test for "is this LLVM type a pointer kind?" Used
// by VarDecl annotation honoring to decide when a bitcast
// is a legal coercion. The four pointer-shaped types in this
// codegen are `i8*`, `%struct.X*`, `%QList*`, `%QMap*` —
// detect via trailing `*`.
define _is_ptr_ty(ty: String) -> Bool {
    return ty.endswith("*")
}

// Extract `"Foo"` from `"%struct.Foo*"`. Returns the input
// unchanged when it doesn't look like a struct pointer — the
// callers use the result as a lookup key in mod.structs, which
// safely misses for non-struct types.
define _strip_struct_ptr(ty: String) -> String {
    prefix := "%struct."
    if ty.startswith(prefix) and ty.endswith("*") {
        return ty.substring(prefix.length(), ty.length() - 1)
    }
    return ty
}

// -----------------------------------------------------------------
// Statement codegen
// -----------------------------------------------------------------

// Ensure a local has an alloca slot of the requested type.
// Returns the populated `_Slot`. First call wins: an Assign /
// subsequent read reuses the existing slot's type rather than
// trying to change it (sema has already enforced consistency).
define _ensure_slot(cg: FnCG, name: String, ty: String) -> _Slot {
    if cg.locals.has(name) {
        holder: _Slot := cg.locals.get(name)
        return holder
    }
    slot_name := "%" + name + ".addr"
    cg.emit_entry(slot_name + " = alloca " + ty)
    s := _Slot(slot_name, ty)
    cg.locals.put(name, s)
    return s
}

// VarDecl variant: if a slot for `name` already exists but
// with a different LLVM type than requested, allocate a fresh
// label-disambiguated slot and rebind cg.locals. Used by
// VarDecl so that re-introducing a name with a new type
// (typical after a match arm bound that name with a variant
// struct type) shadows the old slot cleanly. Assign keeps
// using the plain `_ensure_slot` shape since it intends to
// reuse the existing slot regardless of declared type.
define _ensure_fresh_slot(cg: FnCG, name: String, ty: String) -> _Slot {
    if cg.locals.has(name) {
        holder: _Slot := cg.locals.get(name)
        if holder.ty == ty { return holder }
        unique := "%" + name + "." + cg.fresh_label("rebind") + ".addr"
        cg.emit_entry(unique + " = alloca " + ty)
        s := _Slot(unique, ty)
        cg.locals.put(name, s)
        return s
    }
    return _ensure_slot(cg, name, ty)
}

define _gen_stmt(cg: FnCG, st: Stmt) -> void {
    match st {
        case Return as r => {
            // Coerce pointer-typed return values when the
            // expression's static LLVM type doesn't exactly
            // match the function's declared return type
            // (e.g. an i8* loaded out of a `%QListP*` data
            // buffer being returned as `%struct.Token*`).
            // Mirrors the bitcast that VarDecl annotation
            // honoring inserts at the binding site.
            v_ty := _expr_static_ty(cg, r.value)
            v := _gen_expr(cg, r.value)
            if v_ty != cg.ret_ty and _is_ptr_ty(v_ty) and _is_ptr_ty(cg.ret_ty) {
                cast := cg.fresh()
                cg.emit(cast + " = bitcast " + v_ty + " " + v + " to " + cg.ret_ty)
                v = cast
            }
            cg.emit("ret " + cg.ret_ty + " " + v)
        }
        case ExprStmt as es => {
            _gen_expr(cg, es.expr)
        }
        case VarDecl as v => {
            // Slot type follows either the user's annotation
            // (when present + concrete) or the RHS's static
            // type. When the annotation names a pointer type
            // and the RHS is `i8*` (e.g. Map.get returns Any),
            // emit a bitcast so the slot stores the typed
            // pointer. This is what makes `holder: _Slot :=
            // map.get(name)` work end-to-end.
            rhs_ty := _expr_static_ty(cg, v.value)
            rhs := _gen_expr(cg, v.value)
            ty := rhs_ty
            if v.type_annot != "" {
                annot_ty := _resolve_ty(cg.mod, v.type_annot)
                // Skip "Any" / "Void" — codegen has no slot
                // type for those, so we fall back to RHS type.
                if annot_ty != "i32" or v.type_annot == "Int" {
                    // Use the annotation. The `annot != "i32"
                    // or annot == Int` guard distinguishes a
                    // user-written `Int` annotation from a
                    // default fallthrough.
                    ty = annot_ty
                }
            }
            // Insert a bitcast when annotation widens / narrows
            // a pointer relationship. Pointer ↔ pointer
            // conversions can route through bitcast; primitive
            // ↔ primitive needs a different instruction (none
            // expected here, since sema has accepted the
            // assignment).
            store_val := rhs
            if ty != rhs_ty {
                if _is_ptr_ty(ty) and _is_ptr_ty(rhs_ty) {
                    cast := cg.fresh()
                    cg.emit(cast + " = bitcast " + rhs_ty + " " + rhs +
                            " to " + ty)
                    store_val = cast
                }
            }
            slot := _ensure_fresh_slot(cg, v.name, ty)
            cg.emit("store " + slot.ty + " " + store_val + ", " + slot.ty + "* " + slot.name)
        }
        case Assign as a => {
            // Re-bind: slot must already exist; reuse its type.
            // The arg passed to _ensure_slot only matters on
            // first-use and won't be hit here. Pointer-type
            // mismatch between RHS and slot is bridged with a
            // bitcast — same pattern as VarDecl / Return.
            rhs_ty := _expr_static_ty(cg, a.value)
            rhs := _gen_expr(cg, a.value)
            slot := _ensure_slot(cg, a.name, "i32")
            if rhs_ty != slot.ty and _is_ptr_ty(rhs_ty) and _is_ptr_ty(slot.ty) {
                cast := cg.fresh()
                cg.emit(cast + " = bitcast " + rhs_ty + " " + rhs +
                        " to " + slot.ty)
                rhs = cast
            }
            cg.emit("store " + slot.ty + " " + rhs + ", " + slot.ty + "* " + slot.name)
        }
        case FieldSet as fs => {
            // Symmetric to FieldGet (in _gen_expr): GEP the
            // field's address, then `store` instead of `load`.
            // Extracted to a helper to keep _gen_stmt's recursion
            // shape simple — see the same dodge in
            // `_gen_struct_ctor` for why.
            _gen_field_set(cg, fs.obj, fs.name, fs.value)
        }
        case Match as m => {
            _gen_match(cg, m)
        }
        case If as iff => {
            cond := _gen_expr(cg, iff.cond)
            then_lbl := cg.fresh_label("if.then")
            else_lbl := cg.fresh_label("if.else")
            end_lbl  := cg.fresh_label("if.end")
            has_else := iff.else_body.length() > 0
            if has_else {
                cg.emit("br i1 " + cond + ", label %" + then_lbl + ", label %" + else_lbl)
            } else {
                cg.emit("br i1 " + cond + ", label %" + then_lbl + ", label %" + end_lbl)
            }
            // then block
            cg.emit_raw(then_lbl + ":")
            i := 0
            while i < iff.then_body.length() {
                ts: Stmt := iff.then_body.__get(i)
                _gen_stmt(cg, ts)
                i = i + 1
            }
            cg.emit("br label %" + end_lbl)
            // else block (only if present)
            if has_else {
                cg.emit_raw(else_lbl + ":")
                j := 0
                while j < iff.else_body.length() {
                    es: Stmt := iff.else_body.__get(j)
                    _gen_stmt(cg, es)
                    j = j + 1
                }
                cg.emit("br label %" + end_lbl)
            }
            cg.emit_raw(end_lbl + ":")
        }
        case While as w => {
            head_lbl := cg.fresh_label("while.head")
            body_lbl := cg.fresh_label("while.body")
            end_lbl  := cg.fresh_label("while.end")
            cg.emit("br label %" + head_lbl)
            cg.emit_raw(head_lbl + ":")
            cond := _gen_expr(cg, w.cond)
            cg.emit("br i1 " + cond + ", label %" + body_lbl + ", label %" + end_lbl)
            cg.emit_raw(body_lbl + ":")
            // Push loop labels so `continue` / `break` inside
            // the body know where to branch.
            cg.loop_head.append(head_lbl)
            cg.loop_end.append(end_lbl)
            i := 0
            while i < w.body.length() {
                bs: Stmt := w.body.__get(i)
                _gen_stmt(cg, bs)
                i = i + 1
            }
            cg.loop_head.pop()
            cg.loop_end.pop()
            cg.emit("br label %" + head_lbl)
            cg.emit_raw(end_lbl + ":")
        }
        case Continue as _ => {
            n := cg.loop_head.length()
            if n > 0 {
                head: String := cg.loop_head.__get(n - 1)
                cg.emit("br label %" + head)
            }
        }
        case Break as _ => {
            n := cg.loop_end.length()
            if n > 0 {
                tail: String := cg.loop_end.__get(n - 1)
                cg.emit("br label %" + tail)
            }
        }
        case _ => {}
    }
}

// -----------------------------------------------------------------
// Function codegen
// -----------------------------------------------------------------

define _gen_function(fdecl: FunctionDecl, mod: ModuleCG) -> String {
    cg := FnCG(mod)
    ret_llvm := _resolve_ty(mod, fdecl.ret_type)
    cg.ret_ty = ret_llvm
    is_method := fdecl.receiver != ""
    self_ty := ""
    if is_method { self_ty = "%struct." + fdecl.receiver + "*" }

    // Extern: emit an LLVM `declare`, no body. Param signature
    // for `declare` lists types only (no SSA names), and there's
    // no entry block to seed alloca slots into. The sig table
    // is already populated by emit_module's pre-pass so call
    // sites resolve via the same lookup as normal functions.
    // For methods, the `self` param was stripped from
    // `fd.params` by the inside-struct parser — we prepend its
    // type here to match the C ABI the runtime expects.
    if fdecl.is_extern {
        dsig := ""
        first := true
        if is_method {
            dsig = self_ty
            first = false
        }
        di := 0
        while di < fdecl.params.length() {
            if first == false { dsig = dsig + ", " }
            first = false
            dp: Param := fdecl.params.__get(di)
            dty := _resolve_ty(mod, dp.type_annot)
            dsig = dsig + dty
            di = di + 1
        }
        full_name := fdecl.name
        if is_method { full_name = fdecl.receiver + "__" + fdecl.name }
        else { full_name = _llvm_fn_name(fdecl.name) }
        return "declare " + ret_llvm + " @" + full_name + "(" + dsig + ")\n"
    }

    // Build the param signature `<ty> %arg0, <ty> %arg1, ...`
    // (we don't reuse the user's name in the LLVM param slot
    // because every name needs its own alloca; the param
    // identifier itself lives in that alloca after we store
    // the incoming SSA value below). Methods prepend a `self`
    // param of type `%struct.Foo*`.
    sig := ""
    arg_idx := 0
    if is_method {
        sig = sig + self_ty + " %arg0"
        arg_idx = 1
    }
    i := 0
    while i < fdecl.params.length() {
        p: Param := fdecl.params.__get(i)
        if arg_idx > 0 { sig = sig + ", " }
        arg_reg := "%arg" + arg_idx.str()
        pty := _resolve_ty(mod, p.type_annot)
        sig = sig + pty + " " + arg_reg
        arg_idx = arg_idx + 1
        i = i + 1
    }

    // Entry block: alloca each parameter, store the incoming
    // value in. Slot type follows the param's declared type so
    // Bool params live in `i1` slots, Int params in `i32`,
    // struct params in `%struct.Foo*`. Methods seed `self`
    // first so body code can read/write it as a normal local.
    next_arg := 0
    if is_method {
        slot := _ensure_slot(cg, "self", self_ty)
        cg.emit_entry("store " + self_ty + " %arg0, " + self_ty + "* " + slot.name)
        next_arg = 1
    }
    k := 0
    while k < fdecl.params.length() {
        p: Param := fdecl.params.__get(k)
        pty := _resolve_ty(mod, p.type_annot)
        slot := _ensure_slot(cg, p.name, pty)
        cg.emit_entry("store " + pty + " %arg" + next_arg.str() + ", " + pty + "* " + slot.name)
        next_arg = next_arg + 1
        k = k + 1
    }

    // Body.
    j := 0
    while j < fdecl.body.length() {
        st: Stmt := fdecl.body.__get(j)
        _gen_stmt(cg, st)
        j = j + 1
    }
    // Functions without an explicit return at the end need a
    // synthetic terminator so every basic block ends cleanly.
    // emit() skips when the block is already terminated. For
    // pointer return types, LLVM IR requires `null` rather
    // than the integer literal `0`. The same dead-ret no
    // longer slips through real returns thanks to
    // block_terminated tracking.
    if _is_ptr_ty(ret_llvm) {
        cg.emit("ret " + ret_llvm + " null")
    } else {
        cg.emit("ret " + ret_llvm + " 0")
    }

    // Methods get a mangled LLVM name `Foo__method` so the
    // receiver is recoverable from the symbol and free
    // functions can't collide. User-defined `main()` is
    // renamed to `__quirk_user_main` so the wrapper main can
    // own the ELF entry symbol.
    full_name := fdecl.name
    if is_method { full_name = fdecl.receiver + "__" + fdecl.name }
    else { full_name = _llvm_fn_name(fdecl.name) }
    header := "define " + ret_llvm + " @" + full_name + "(" + sig + ") {\nentry:\n"
    return header + cg.entry_out + cg.out + "}\n"
}

---
Emit the full IR module for a list of top-level declarations.
Includes the LLVM module header and any helper declarations the
emitted bodies reference (none today — Phase 4.1 will add
`declare i32 @printf(i8*, ...)` etc. when print/string lands).
---
define emit_module(decls: List) -> String {
    mod := ModuleCG()
    // Pre-pass 1a: register NAMES of all user-defined types
    // (structs, enums, unions, variants) before resolving any
    // field types. Without this, cross-type references like
    // `struct Foo { e: Expr }` where Expr is declared later
    // — or a variant payload referencing another union —
    // would fall back to the i32 default because _resolve_ty
    // wouldn't yet know the name. Each entry is registered
    // with a placeholder empty field list; pass 1b fills in
    // the real types.
    na := 0
    while na < decls.length() {
        dn: TopLevel := decls.__get(na)
        match dn {
            case StructTL as st => {
                sd: StructDecl := st.decl
                mod.register_struct(_StructDef(sd.name, List(), List()))
            }
            case EnumTL as et => {
                ed: EnumDecl := et.decl
                mod.enums.put(ed.name, ed)
            }
            case UnionTL as ut => {
                ud: UnionDecl := ut.decl
                mod.unions.put(ud.name, ud)
                // Base struct for the shared `{ i32 tag }` prefix.
                base_names := List()
                base_names.append("__tag")
                base_tys := List()
                base_tys.append("i32")
                mod.register_struct(_StructDef(ud.name, base_names, base_tys))
                vi := 0
                while vi < ud.variants.length() {
                    v: Variant := ud.variants.__get(vi)
                    mod.variants.put(v.name, _VarCgInfo(ud.name, vi))
                    // Placeholder T__V struct; fields filled in 1b.
                    mod.register_struct(_StructDef(ud.name + "__" + v.name,
                                                   List(), List()))
                    vi = vi + 1
                }
            }
            case _ => {}
        }
        na = na + 1
    }
    // Pre-pass 1b: now that every user-defined type name is
    // registered, fill in struct + variant field types via
    // _resolve_ty (which consults mod.structs / mod.unions /
    // mod.enums for non-primitive names).
    sp := 0
    while sp < decls.length() {
        ds: TopLevel := decls.__get(sp)
        match ds {
            case StructTL as st => {
                sd: StructDecl := st.decl
                fnames := List()
                ftys := List()
                fi := 0
                while fi < sd.fields.length() {
                    f: StructField := sd.fields.__get(fi)
                    fnames.append(f.name)
                    ftys.append(_resolve_ty(mod, f.type_annot))
                    fi = fi + 1
                }
                mod.register_struct(_StructDef(sd.name, fnames, ftys))
            }
            case UnionTL as ut => {
                ud: UnionDecl := ut.decl
                vi := 0
                while vi < ud.variants.length() {
                    v: Variant := ud.variants.__get(vi)
                    fnames := List()
                    fnames.append("__tag")
                    ftys := List()
                    ftys.append("i32")
                    fi := 0
                    while fi < v.fields.length() {
                        f: StructField := v.fields.__get(fi)
                        fnames.append(f.name)
                        ftys.append(_resolve_ty(mod, f.type_annot))
                        fi = fi + 1
                    }
                    mod.register_struct(_StructDef(ud.name + "__" + v.name,
                                                   fnames, ftys))
                    vi = vi + 1
                }
            }
            case _ => {}
        }
        sp = sp + 1
    }
    // Pre-pass 2: register every user-defined function's typed
    // signature so call-site codegen can render argument and
    // return types correctly — including for forward references
    // where the callee's body is emitted after the call site.
    pp := 0
    while pp < decls.length() {
        dp: TopLevel := decls.__get(pp)
        match dp {
            case Func as fp => {
                fdp: FunctionDecl := fp.decl
                ptys := List()
                // Methods prepend `%struct.Foo*` as the self
                // param so call-site rendering threads the
                // receiver into arg0 without special-casing.
                if fdp.receiver != "" {
                    ptys.append("%struct." + fdp.receiver + "*")
                }
                pi := 0
                while pi < fdp.params.length() {
                    pp_param: Param := fdp.params.__get(pi)
                    ptys.append(_resolve_ty(mod, pp_param.type_annot))
                    pi = pi + 1
                }
                rty := _resolve_ty(mod, fdp.ret_type)
                full_name := fdp.name
                if fdp.receiver != "" {
                    full_name = fdp.receiver + "__" + fdp.name
                } else {
                    full_name = _llvm_fn_name(fdp.name)
                }
                mod.register_sig(full_name, _Sig(ptys, rty))
            }
            case _ => {}
        }
        pp = pp + 1
    }
    // Emit functions next so module-level globals / decls
    // (collected into `mod` as a side-effect of codegen) are
    // populated by the time we render the header.
    bodies := ""
    i := 0
    while i < decls.length() {
        d: TopLevel := decls.__get(i)
        match d {
            case Func as f => {
                fd: FunctionDecl := f.decl
                bodies = bodies + _gen_function(fd, mod) + "\n"
            }
            case _ => {}
        }
        i = i + 1
    }
    // If the user defined a `main()` function, emit the
    // ELF-entry wrapper that stashes argc/argv into module
    // globals (so arg_count/arg_get can read them) and
    // delegates to the renamed `@__quirk_user_main`. The two
    // globals are declared on demand by the arg_count /
    // arg_get builtins — emit them here unconditionally too
    // since the wrapper writes to them.
    if mod.sigs.has("__quirk_user_main") {
        mod.ensure_decl("quirk_argc", "@quirk_argc = global i32 0")
        mod.ensure_decl("quirk_argv", "@quirk_argv = global i8** null")
    }
    out := "; ModuleID = 'selfhost'\n"
    out = out + "target triple = \"x86_64-pc-linux-gnu\"\n\n"
    out = out + mod.render_header()
    out = out + bodies
    if mod.sigs.has("__quirk_user_main") {
        out = out + "define i32 @main(i32 %argc, i8** %argv) {\nentry:\n"
        out = out + "  store i32 %argc, i32* @quirk_argc\n"
        out = out + "  store i8** %argv, i8*** @quirk_argv\n"
        out = out + "  %r = call i32 @__quirk_user_main()\n"
        out = out + "  ret i32 %r\n}\n"
    }
    return out
}
