
---
All possible directions from a compass.
---
enum Direction {
    North
    South
    East
    West
}

---
Main function to run `enum_test.qk` script.
---
define main() {
    d := Direction.North

    if d == Direction.North {
        print("Going north!")
    } elif d == Direction.South {
        print("Going south!")
    } elif d == Direction.East {
        print("Going east!")
    } elif d == Direction.West {
        print("Going west!")
    }
}