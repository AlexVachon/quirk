---
Full test suite for the Quirk exception system.
Covers: finally, bare throw, anonymous catch, all built-in types,
        automatic IndexError/KeyError, and inheritance-based catching.
---
// from core.exceptions use {
//     ValueError, IndexError, KeyError,
//     IOError, FileNotFoundError,
//     RuntimeError, NotImplementedError,
//     ZeroDivisionError, AssertionError, NullError
// }

// ============================================================
// Helpers
// ============================================================

define pass(label: String) -> void {
    print("[PASS] " + label)
}

define fail(label: String) -> void {
    print("[FAIL] " + label)
}

// ============================================================
// 1. finally — runs on normal exit
// ============================================================

define test_finally_normal() -> void {
    ran := false
    try {
        ran = true
    } catch (Exception) {
        fail("finally_normal: unexpected catch")
    } finally {
        if ran {
            pass("finally runs after normal try exit")
        } else {
            fail("finally_normal: try body did not run")
        }
    }
}

// ============================================================
// 2. finally — runs after a catch
// ============================================================

define test_finally_after_catch() -> void {
    caught := false
    finally_ran := false
    try {
        throw ValueError("bad value")
    } catch (ValueError) {
        caught = true
    } finally {
        finally_ran = true
    }
    if caught and finally_ran {
        pass("finally runs after catch")
    } else {
        fail("finally_after_catch")
    }
}

// ============================================================
// 3. finally — runs even when exception propagates outward
// ============================================================

define test_finally_on_propagation() -> void {
    finally_ran := false
    try {
        try {
            throw RuntimeError("inner")
        } finally {
            finally_ran = true
        }
    } catch (RuntimeError) {}

    if finally_ran {
        pass("finally runs on outward propagation")
    } else {
        fail("finally_on_propagation")
    }
}

// ============================================================
// 4. Bare throw — re-raises current exception unchanged
// ============================================================

define test_bare_throw() -> void {
    msg := ""
    try {
        try {
            throw AssertionError("original message")
        } catch (e: AssertionError) {
            throw // bare rethrow
        }
    } catch (e: AssertionError) {
        msg = e.message
    }
    if msg == "original message" {
        pass("bare throw preserves exception")
    } else {
        fail("bare_throw: got '" + msg + "'")
    }
}

// ============================================================
// 5. Anonymous catch — no variable binding
// ============================================================

define test_anonymous_catch() -> void {
    try {
        throw ZeroDivisionError("div by zero")
    } catch (ZeroDivisionError) {
        pass("anonymous catch (single type)")
    }

    try {
        throw NullError("null deref")
    } catch (NullError, RuntimeError) {
        pass("anonymous catch (multiple types)")
    }
}

// ============================================================
// 6. Automatic IndexError from list access
// ============================================================

define test_index_error() -> void {
    items := [1, 2, 3]

    try {
        _ := items[10]
    } catch (e: IndexError) {
        pass("IndexError on out-of-bounds read: " + e.message)
    }

    try {
        items[10] = 99
    } catch (e: IndexError) {
        pass("IndexError on out-of-bounds write: " + e.message)
    }

    // Negative index within range — should NOT throw
    ok := false
    try {
        _ := items[-1]
        ok = true
    } catch (IndexError) {
        fail("negative index within range should not throw")
    }
    if ok {
        pass("negative index within range works")
    }
}

// ============================================================
// 7. Automatic KeyError from map access
// ============================================================

define test_key_error() -> void {
    m := { "x": 1, "y": 2}

    try {
        _ := m["missing"]
    } catch (e: KeyError) {
        pass("KeyError on missing key: " + e.message)
    }

    // Existing key — should NOT throw
    ok := false
    try {
        _ := m["x"]
        ok = true
    } catch (KeyError) {
        fail("existing key should not throw")
    }
    if ok {
        pass("existing key access works")
    }
}

// ============================================================
// 8. Inheritance-based catching
// ============================================================

define test_inheritance_catch() -> void {
    // IndexError caught as ValueError
    try {
        items := [1, 2, 3]
        _ := items[99]
    } catch (e: ValueError) {
        pass("IndexError caught as ValueError: " + e.message)
    }

    // KeyError caught as ValueError
    try {
        m := { "a": 1}
        _ := m["b"]
    } catch (e: ValueError) {
        pass("KeyError caught as ValueError: " + e.message)
    }

    // NotImplementedError caught as RuntimeError
    try {
        throw NotImplementedError("abstract method")
    } catch (e: RuntimeError) {
        pass("NotImplementedError caught as RuntimeError: " + e.message)
    }

    // FileNotFoundError caught as IOError
    try {
        throw FileNotFoundError("config.json")
    } catch (e: IOError) {
        pass("FileNotFoundError caught as IOError: " + e.message)
    }

    // Everything caught as Exception
    try {
        throw ZeroDivisionError("div by zero")
    } catch (e: Exception) {
        pass("ZeroDivisionError caught as Exception: " + e.message)
    }
}

// ============================================================
// 9. Exception chaining (from keyword)
// ============================================================

define test_exception_chaining() -> void {
    try {
        try {
            throw ValueError("root cause")
        } catch (e: ValueError) {
            throw RuntimeError("wrapping error") from e
        }
    } catch (e: RuntimeError) {
        if e.message == "wrapping error" {
            pass("exception chaining works")
        } else {
            fail("chaining: unexpected message " + e.message)
        }
    }
}

// ============================================================
// 10. Multiple catch blocks — first match wins
// ============================================================

define test_first_match_wins() -> void {
    matched := ""
    try {
        throw IndexError("oob")
    } catch (IndexError) {
        matched = "IndexError"
    } catch (ValueError) {
        matched = "ValueError"
    } catch (`Exception) {
        matched = "Exception"
    }
    if matched == "IndexError" {
        pass("first matching catch block wins")
    } else {
        fail("first_match_wins: matched '" + matched + "'")
    }
}

// ============================================================
// 11. Nested try/catch
// ============================================================

define test_nested_try() -> void {
    outer := ""
    inner := ""
    try {
        try {
            throw KeyError("inner key")
        } catch (e: KeyError) {
            inner = e.message
            throw RuntimeError("outer error")
        }
    } catch (e: RuntimeError) {
        outer = e.message
    }
    if inner == "inner key" and outer == "outer error" {
        pass("nested try/catch works")
    } else {
        fail("nested_try: inner='" + inner + "' outer='" + outer + "'")
    }
}

// ============================================================
// Main
// ============================================================

define main() -> void {
    print("=== Exception System Tests ===")
    print("")

    test_finally_normal()
    test_finally_after_catch()
    test_finally_on_propagation()
    test_bare_throw()
    test_anonymous_catch()
    test_index_error()
    test_key_error()
    test_inheritance_catch()
    test_exception_chaining()
    test_first_match_wins()
    test_nested_try()

    print("")
    print("=== Done ===")
}
