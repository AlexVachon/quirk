define main() -> void {
    print("Starting GC memory test...")
    print("Open another terminal and run 'htop' to watch your RAM.")

    i := 0

    while (i < 5000000) {
        temp_str := "Garbage " + "Collection " + "Test"
        temp_list := [1, 2, 3, i]

        i := i + 1
    }
    print("Test finished successfully!")
    print("If your computer didn't crash, Boehm GC is working!")
}