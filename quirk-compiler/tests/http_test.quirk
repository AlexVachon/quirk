// Smoke test of the http client against example.com. Gated
// behind QUIRK_NETWORK_TESTS=1 — see http_client_test.quirk for
// rationale (external services flake, CI shouldn't depend on
// them by default).

use net.http
use sys
from typing.exceptions use { SocketError, Exception }

define main() {
    if sys.env("QUIRK_NETWORK_TESTS") != "1" {
        print("http_test: skipped (set QUIRK_NETWORK_TESTS=1 to enable)")
        return
    }

    resp := http.get("http://example.com")

    if resp.ok {
        print("Success: " + resp.status_code.str())
        print("Server: " + resp.headers.get("Server")) // Access headers!
        print("Body: " + resp.text)
    } else {
        print("Failed: ${resp.status_code.str()}")
    }

    resp2 := http.post("http://example.com/api", "name=Quirk")
    print(resp2)
}
