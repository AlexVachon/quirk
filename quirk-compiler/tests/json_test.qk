use encoding.json

define main() -> void {
    raw := "{\"name\": \"Alex\", \"version\": 1.0, \"active\": true, \"skills\": [\"C++\", \"Compilers\"]}"

    print("--- RAW DATA ---")
    print(raw)

    data: Map := json.parse(raw)

    print("--- PARSED JSON ---")
    print('Parsed Name: ${data["name"]}')

    // 2. Numbers are safely returned as strings so precision isn't lost. 
    // We can easily convert them!
    ver_str: String := data["version"]
    ver_math := ver_str.to_float() * 10.0
    print("Calculated Version: ${ver_math}")

    // 3. Tell Quirk we expect the inner "skills" array to be a List
    skills: List := data["skills"]
    print("Number of skills: ${skills.len()}")
    print("First skill: ${skills[0]}")
}