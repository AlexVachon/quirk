define main() -> void {
    square := fn(x: Int) => x * x
    print(square(5))

    nums := [1, 2, 4, 5, 6, 3]

    nums.each(fn(x: Int) {
        if x > 2 {
            print(x)
        }
    })

    factor := 3

    nums.map(fn(x: Int) => x * factor).each(fn(x: Int) => print(x))

    people = {
        "1234": {
            "name": "Alice",
            "age": 30
        },
        "1235": {
            "name": "Bob",
            "age": 25
        },
        "1236": {
            "name": "Charlie",
            "age": 35
        },
        "1237": {
            "name": "Diana",
            "age": 28
        },
        "1238": {
            "name": "Eve",
            "age": 22
        }
    }
    people.each(fn(key: String, value: Map) {
        print("ID: ${key} - ${value["name"]} is ${value["age"]} years old.")
    })
}
