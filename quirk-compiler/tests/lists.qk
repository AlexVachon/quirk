from core.collections.list use {List}

define main() {
    print("--- List Tests ---")

    // 1. Initialization & Appending
    l := List(4) 
    l.append(10)
    l.append(20)
    l.append(30)

    // FIX: Use implicit conversion via '+' (Recommended)
    // The compiler automatically converts (String + Int) and (String + List)
    print("Length (should be 3): " + l.len()) 
    print("Content: " + l) 

    // 2. Access & Setting
    // FIX: l[1] returns 'any', but our '+' operator handles auto-boxing now
    print("Item at index 1: " + l[1])
    
    l[1] := 99
    print("Modified at index 1: " + l[1])
    
    // FIX: explicit __str() is also allowed if you want just the string
    print("New Content: " + l.__str())

    // 3. Popping
    val := l.pop()
    print("Popped value: " + val)
    print("Length after pop: " + l.len())

    // 4. Clearing & Empty Check
    // Bool also auto-converts with '+'
    print("Is empty? " + l.is_empty())
    l.clear()
    print("Cleared. Is empty? " + l.is_empty())
    print("Length after clear: " + l.len())

    // 5. String List & Iteration
    print("\n--- String List Iteration ---")
    names := ["Alice", "Bob", "Charlie"] 
    
    for name in names {
        print("Item: " + name) 
    }
}