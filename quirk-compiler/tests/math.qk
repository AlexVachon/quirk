from math use { Vector2 }

---
This is the main function
---
define main() -> void {
    v := Vector2(1, 3)
    v.add(Vector2(3, 4))

    print(v)
    
    process_link(url: "https://example.com")
}

---
Downloads and processes a target webpage.

@param :
- **url** The web address to scrape.
- **ssl** Set true to activate ssl verfication.
@returns **void**
---
define process_link(url: String, ssl: Bool) -> void {
    print("Processing url - ${url}")
}