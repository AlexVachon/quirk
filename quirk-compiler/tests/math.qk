from math use { Vector2 }

---
Description of the function.

@param :
- **param1** Description.
@returns **void**
---
define main() -> void {
    v := Vector2(1, 3)

    process_link("https://example.com")
    process_link("https://example.com", ssl: true)
    process_link(timeout: 60, url: "https://example.com")
}

---
Downloads and processes a target webpage.

@param :
- **url** The web address to scrape.
- **ssl** Set true to activate ssl verfication.
@returns **void**
---
define process_link(url: String, ssl: Bool = false, timeout: Int = 30) -> void {
    print("Processing url - ${url} (ssl:${ssl})  (timeout:${timeout})")
}