from typing.collections use { Set, Queue }

// === Type aliases ===
type Name = String
type Number = Int

// === Set literal ===
s := {1, 2, 3, 4, 5}
s.add(6)
print("Set size:", s.size())
print("Has 3:", 3 in s)
print("Has 99:", 99 in s)
s.remove(2)
print("After remove 2, has 2:", 2 in s)

// === Set operations ===
a := {1, 2, 3}
b := {2, 3, 4}
u := a.union(b)
print("Union size:", u.size())

// === Queue ===
q := Queue()
q.push_back(10)
q.push_back(20)
q.push_back(30)
print("Queue size:", q.size())
print("Pop front:", q.pop_front())
print("Queue size after pop:", q.size())

// === Match on type ===
define check_type(x) {
    match x {
        case Int => { print("It's an Int!") }
        case String => { print("It's a String!") }
        case _ => { print("Unknown type") }
    }
}

check_type(42)
check_type("hello")

// === Union type in function param ===
define describe(val: Int | String) {
    print("Got value")
}

describe(100)
describe("world")

name := "Alexandre"
print(name[1:3])

// === Range literals ===
print("Range 1..5:")
for i in 1..6 {
    print(i)
}

// === Operator overloading ===
struct Vec2 {
    x: Double
    y: Double

    define __add(self, other: Vec2) -> Vec2 {
        return Vec2(self.x + other.x, self.y + other.y)
    }
}

v1 := Vec2(1.0, 2.0)
v2 := Vec2(3.0, 4.0)
v3 := v1 + v2
print("Vec2 add x:", v3.x)
print("Vec2 add y:", v3.y)

// === Tuple destructuring in for ===
pairs := [(1, "one"), (2, "two"), (3, "three")]
for (n, s) in pairs {
    print(n, s)
}

// === Spread operator ===
define sum_all(...nums) {
    total := 0
    for x in nums {
        total = total + x
    }
    return total
}

args := [10, 20, 30]
print("Spread sum:", sum_all(...args))

// === Nonlocal / closure mutation ===
counter := 0
nonlocal counter

---
Small increment function
---
increment := fn() {
    counter = counter + 1
}

increment()
increment()
increment()
print("Counter after 3 increments:", counter)
