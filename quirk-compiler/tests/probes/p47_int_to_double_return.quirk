// p47 â€” Int â†’ Double widening on function return (v3.0.3,
// surfaced by tools/fuzz.py @ seed=99).
//
// Cause: Sema's `isCompatibleTypes` accepts Int where Double is
// declared (per the widening rule used at parameter sites), but
// Codegen's return-statement coercion didn't have a matching
// `i32 â†’ double` path â€” it emitted `ret i32 %x` against a `double`
// function signature and LLVM's verifier crashed with "Function
// return type does not match operand type". Fix: added explicit
// SIToFP coercion in the return-emit branch (and the FPToSI inverse
// for Double â†’ Int).

define as_double(n: Int) -> Double { return n }
// Explicit narrow via `as` â€” exercises the FPToSI return-coercion
// path. Sema rejects the implicit form `-> Int { return d }` (a
// Doubleâ†’Int implicit narrow), which is intentional; the codegen
// path is still wired so explicit `(d as Int)` round-trips.
define as_int(d: Double) -> Int { return (d as Int) }

define main() -> void {
    if as_double(42) != 42.0 { print("FAIL: Intâ†’Double widen"); return }
    if as_int(3.7)   != 3    { print("FAIL: Doubleâ†’Int narrow"); return }
    print("PASS: Intâ†”Double coercion on return")
}
