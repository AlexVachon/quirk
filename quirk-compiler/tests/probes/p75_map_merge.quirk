// p75 — Map + Map merge + Map.put_all (v3.16.0).
//
// Natural follow-up to v3.15.0's list concat. Same shape: a
// new `__add` on Map and a mutating `put_all`. Right side
// wins on key collision so `{a: 1} + {a: 2}` is `{a: 2}` —
// matches Python's `{**m1, **m2}` precedence.
//
// Codegen path is the existing v3.15.0 per-struct dispatch
// (`structMethodNodes[Map][__add]`). No new dispatch
// machinery needed — pure runtime + Sema typing.

m1 := Map()
m1.put("a", "1")
m1.put("b", "2")

m2 := Map()
m2.put("b", "OVERRIDE")
m2.put("c", "3")

m3 := m1 + m2
print(m3.length())          // = 3
print(m3.get("a"))          // = 1
print(m3.get("b"))          // = OVERRIDE  (right side wins)
print(m3.get("c"))          // = 3

// Originals untouched
print(m1.length())          // = 2
print(m2.length())          // = 2

// put_all mutates the receiver in place
m1.put_all(m2)
print(m1.length())          // = 3
print(m1.get("b"))          // = OVERRIDE

// Empty operand handling
empty := Map()
m4 := empty + m2
print(m4.length())          // = 2

m5 := m2 + empty
print(m5.length())          // = 2
