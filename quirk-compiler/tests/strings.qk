struct CustomString : String {}

define main() {
    num := 12345
    base_str := " this is my string. A String contains characters. "

    print(base_str.upper())
    print(base_str.title())
    print(base_str.lower())
    print(base_str.capitalize())
    print(base_str.sentence_case())

    url := "https://example.com/search?q=hello world!"

    print(url.encode())
    print(base_str.count("i"))
    print(base_str.endswith("characters."))
    print(base_str.find("contains"))

    print("Language: {}, Version: {}".format("Quirk", 1))
    print("Language: {lang}, Version: {version%.2f}".format(lang: "Quirk", version: 1.54623))
    print("Hello {user}!".format_map(["user"], ["Alex"]))
    print("This is value of num ${num}")

    print(base_str.index("String"))

    print(base_str.trim())
    print(base_str.replace("String", "STRING"))
    print(base_str.startswith("potato"))
    print(base_str.substring(5, 10))
    print("|".join([1, 2, 3]))
    print("12".is_digit())
    print("12".is_alpha())

    print(base_str.remove("l"))
    print("-".repeat(10))
    print("stressed".reverse())

    // ID Formatting
    id := "42"
    print("ID: " + id.zfill(5))      // Output: ID: 00042

    // Table Alignment
    col1 := "Name".ljust(10, " ")
    col2 := "Price".rjust(8, " ")
    print(col1 + "|" + col2)         // Output: Name      |   Price
    
    val1 := "Apple".ljust(10, ".")
    val2 := "$1.50".rjust(8, ".")
    print(val1 + "|" + val2)         // Output: Apple.....|...$1.50

    // Readable checks
    if "Team".contains("ea") {
        print("Found it!")
    }

    s_num := "123"
    s_pi := "3.14159"
    
    // Explicitly converting strings to numbers
    total := s_num.to_int() + 10     // 133
    area := s_pi.to_float() * 2.0    // 6.28...
    print("true".to_bool().str()) // convert string -> boolean -> string
    
    print("Parsed: ${total}, ${area}")
    
    // 2. Fuzzy Matching
    word := "kitten"
    typo := "sitting"
    dist := word.distance(typo)
    
    print("Edits needed to turn $word into ${typo}: ${dist}") // Output: 3

    // 3. Line Processing
    config := "name=Quirk\nversion=1.0\r\nstatus=active"
    lines := config.lines()
    
    // Using your new 'format_list' implicitly via $lines
    print("Config lines: ${lines}")

    c_string := CustomString()
    print(type(c_string))

}