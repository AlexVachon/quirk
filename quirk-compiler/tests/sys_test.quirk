use io
use sys

define main() {
    print("1. Writing to a file...")

    with io.File("test_output.txt", "w") as f {
        f.write("Hello from Quirk!\n")
        f.write("This file was generated using the new io.file module.\n")
    }

    print("2. Reading it back...")
    with io.File("test_output.txt", "r") as in_f {
        content := in_f.read()
        print("--- FILE CONTENTS ---")
        print(content)
        print("---------------------")
    }

    print("3. Testing Standard Streams...")
    stderr := sys.stderr()
    stderr.write(">>> This is a direct write to the C stderr stream!\n")
}
