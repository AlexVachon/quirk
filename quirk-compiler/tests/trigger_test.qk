struct Player {
    name: String
    health: Int

    define __init(self, name: String) -> void {
        self.name = name
        self.health = 100
        
        trigger self.health(current, previous) {
            if current < previous {
                print("${self.name} took ${previous - current} damage! (Health: ${current})")
            } elif current > previous {
                print("${self.name} was healed for ${current - previous} HP! (Health: ${current})")
            }
        }
    }

    define take_damage(self, amount: Int) -> void {
        self.health -= amount
    }
}

define main() -> void {
    p := Player("Alex")
    
    // This will trigger the damage text
    p.take_damage(40)
    
    // This will trigger the healing text
    p.health += 20 
}