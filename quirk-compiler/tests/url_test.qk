use url
use test
from test use { TestCase }
use console

define main() -> void {
    // ───── quote / unquote round-trips ─────
    t1 := TestCase("quote leaves unreserved chars", fn() {
        test.assert_eq(url.quote("ABCxyz0-9_.~"), "ABCxyz0-9_.~")
    })
    t2 := TestCase("quote escapes space", fn() {
        test.assert_eq(url.quote("a b"), "a%20b")
    })
    t3 := TestCase("quote escapes punctuation", fn() {
        test.assert_eq(url.quote("a&b=c"), "a%26b%3Dc")
    })
    t4 := TestCase("unquote inverts quote", fn() {
        s := "Hello, world! /a?b=c#d"
        test.assert_eq(url.unquote(url.quote(s)), s)
    })
    t5 := TestCase("unquote handles raw % at end", fn() {
        // Trailing "%" with no two hex digits should pass through.
        test.assert_eq(url.unquote("100%"), "100%")
    })
    t6 := TestCase("unquote_form maps + to space", fn() {
        test.assert_eq(url.unquote_form("a+b%20c"), "a b c")
    })

    // ───── parse: full URL ─────
    t7 := TestCase("parse full URL with all components", fn() {
        u := url.parse("https://api.example.com:8443/v1/users?id=42#bio")
        test.assert_eq(u.scheme, "https")
        test.assert_eq(u.host, "api.example.com")
        test.assert_eq(u.port, 8443)
        test.assert_eq(u.path, "/v1/users")
        test.assert_eq(u.query, "id=42")
        test.assert_eq(u.fragment, "bio")
    })
    t8 := TestCase("parse URL without port", fn() {
        u := url.parse("http://example.com/path")
        test.assert_eq(u.host, "example.com")
        test.assert_eq(u.port, 0)
        test.assert_eq(u.path, "/path")
    })
    t9 := TestCase("parse URL without path", fn() {
        u := url.parse("https://example.com")
        test.assert_eq(u.host, "example.com")
        test.assert_eq(u.path, "")
    })
    t10 := TestCase("parse URL with query but no fragment", fn() {
        u := url.parse("http://x.com/a?b=c")
        test.assert_eq(u.query, "b=c")
        test.assert_eq(u.fragment, "")
    })
    t11 := TestCase("parse URL with fragment but no query", fn() {
        u := url.parse("http://x.com/a#top")
        test.assert_eq(u.query, "")
        test.assert_eq(u.fragment, "top")
    })
    t12 := TestCase("parse URL with multiple ? in fragment is ok", fn() {
        u := url.parse("http://x.com/a?q=1#sec?nested")
        test.assert_eq(u.query, "q=1")
        test.assert_eq(u.fragment, "sec?nested")
    })

    // ───── recomposition ─────
    t13 := TestCase("to_string round-trips a full URL", fn() {
        s := "https://api.example.com:8443/v1/users?id=42#bio"
        test.assert_eq(url.parse(s).to_string(), s)
    })
    t14 := TestCase("to_string round-trips a minimal URL", fn() {
        s := "http://example.com/x"
        test.assert_eq(url.parse(s).to_string(), s)
    })

    // ───── parse_query ─────
    t15 := TestCase("parse_query decodes percent-escapes", fn() {
        q := url.parse_query("name=Alice%20Smith&age=30")
        test.assert_eq(q.get("name"), "Alice Smith")
        test.assert_eq(q.get("age"), "30")
    })
    t16 := TestCase("parse_query handles bare key (no =)", fn() {
        q := url.parse_query("flag&n=1")
        test.assert_eq(q.get("flag"), "")
        test.assert_eq(q.get("n"), "1")
    })
    t17 := TestCase("parse_query strips leading ?", fn() {
        q := url.parse_query("?a=1")
        test.assert_eq(q.get("a"), "1")
    })

    // ───── build_query ─────
    t18 := TestCase("build_query encodes values", fn() {
        m := Map()
        m.put("q", "hello world")
        test.assert_eq(url.build_query(m), "q=hello%20world")
    })

    fails := test.run_all([
        t1, t2, t3, t4, t5, t6,
        t7, t8, t9, t10, t11, t12,
        t13, t14, t15, t16, t17, t18
    ])

    if fails == 0 {
        console.bold("url: all checks passed.")
    } else {
        console.red("url: ${fails} failed.")
    }
}
