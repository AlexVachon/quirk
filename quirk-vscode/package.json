{
  "name": "quirk",
  "displayName": "Quirk",
  "description": "Language support for Quirk",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "quirk",
        "aliases": ["Quirk", "quirk"],
        "extensions": [".qk"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/icon.svg",
          "dark": "./icons/icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "quirk",
        "scopeName": "source.quirk",
        "path": "./syntaxes/quirk.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "quirk",
        "path": "./snippets.json"
      }
    ],
    "commands": [
      {
        "command": "quirk.runFile",
        "title": "Quirk: Run File",
        "icon": "$(play)"
      },
      {
        "command": "quirk.selectInterpreter",
        "title": "Quirk: Select Interpreter"
      }
    ],
    "keybindings": [
      {
        "command": "quirk.runFile",
        "key": "ctrl+f5",
        "mac": "cmd+f5",
        "when": "editorLangId == quirk"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "quirk.runFile",
          "when": "editorLangId == quirk",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Quirk",
      "properties": {
        "quirk.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the quirk compiler binary. Leave empty to auto-detect from QUIRK_HOME or PATH."
        },
        "quirk.quirkHome": {
          "type": "string",
          "default": "",
          "description": "Path to QUIRK_HOME (directory containing bin/ and libs/). Leave empty to use the QUIRK_HOME environment variable."
        }
      }
    },
    "configurationDefaults": {
      "[quirk]": {
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "off"
        },
        "editor.suggestOnTriggerCharacters": true,
        "editor.acceptSuggestionOnEnter": "on",
        "editor.wordBasedSuggestions": "currentDocument"
      }
    },
    "problemMatchers": [
      {
        "name": "quirk",
        "owner": "quirk",
        "fileLocation": ["absolute"],
        "pattern": [
          {
            "regexp": "^\\[ERROR\\]\\s+(.*)$",
            "message": 1
          },
          {
            "regexp": "^ --> (.+):(\\d+):(\\d+)\\s*$",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ],
        "severity": "error"
      }
    ],
    "taskDefinitions": [
      {
        "type": "quirk",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "description": "The .qk file to compile and run."
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.x"
  }
}