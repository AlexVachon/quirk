{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quirk",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#definitions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "imports": {
      "patterns": [
        {
          "match": "\\b(from)\\s+([a-zA-Z0-9_./]+)\\s+(use)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.quirk"
            },
            "2": {
              "name": "entity.name.namespace.quirk"
            },
            "3": {
              "name": "keyword.control.import.quirk"
            }
          }
        },
        {
          "match": "\\b(use)\\s+([a-zA-Z0-9_./]+)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.quirk"
            },
            "2": {
              "name": "entity.name.namespace.quirk"
            }
          }
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": {
              "name": "storage.type.struct.quirk"
            },
            "2": {
              "name": "entity.name.type.struct.quirk"
            }
          }
        },
        {
          "match": "\\b(define|init)\\s+([a-zA-Z_]\\w*)?",
          "captures": {
            "1": {
              "name": "storage.type.function.quirk"
            },
            "2": {
              "name": "entity.name.function.definition.quirk"
            }
          }
        },
        {
          "match": "\\b(extern)\\b",
          "name": "storage.modifier.quirk"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.quirk",
          "match": "\\b(if|else|elif|while|for|in|return|break|continue|with|as)\\b"
        },
        {
          "name": "keyword.other.quirk",
          "match": "\\b(del)\\b"
        },
        {
          "name": "constant.language.quirk",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.this.quirk",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.quirk",
          "match": "\\b(void|Any)\\b"
        },
        {
          "name": "support.type.object.quirk",
          "match": "\\b(Char|List|String|Map|Int|Double|Bool|File)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.quirk",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.quirk",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.quirk",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.quirk",
          "match": "\\\\."
        },
        {
          "name": "meta.embedded.line.quirk",
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.begin.quirk"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.end.quirk"
            }
          },
          "patterns": [
            {
              "include": "$self"
            }
          ]
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.call.quirk"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.quirk",
          "match": "(:=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.quirk",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.quirk",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.quirk",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "storage.type.function.arrow.quirk",
          "match": "->"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.quirk",
          "begin": "^\\s*---\\s*$",
          "end": "^\\s*---\\s*$"
        },
        {
          "name": "comment.line.double-slash.quirk",
          "match": "//.*$"
        }
      ]
    }
  },
  "scopeName": "source.quirk"
}