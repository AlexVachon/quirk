{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quirk",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#decorators" },
    { "include": "#definitions" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#exceptions" },
    { "include": "#types" },
    { "include": "#magic-methods" },
    { "include": "#enum-access" },
    { "include": "#method-calls" },
    { "include": "#functions" },
    { "include": "#keyword-arguments" },
    { "include": "#operators" },
    { "include": "#properties" },
    { "include": "#variables" }
  ],
  "repository": {
    "decorators": {
      "patterns": [
        {
          "comment": "@decorator lines applied to a `define`. The `@` is scoped as punctuation (themes render it in a muted/gray tone) so the focal point is the decorator name. Matches Python's default highlighting convention in VS Code Dark+, Monokai, and One Dark. Any `(args)` after the name is left for normal expression parsing.",
          "match": "^\\s*(@)([a-zA-Z_]\\w*(?:\\.[a-zA-Z_]\\w*)*)",
          "captures": {
            "1": { "name": "punctuation.definition.decorator.quirk" },
            "2": { "name": "entity.name.function.decorator.quirk" }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "\\b(from)\\s+([a-zA-Z0-9_./]+)\\s+(use)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.quirk" },
            "2": { "name": "entity.name.namespace.quirk" },
            "3": { "name": "keyword.control.import.quirk" }
          }
        },
        {
          "match": "\\b(from)\\s+([a-zA-Z0-9_./]+)\\s+(as)\\s+([a-zA-Z_]\\w*)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.quirk" },
            "2": { "name": "entity.name.namespace.quirk" },
            "3": { "name": "keyword.control.import.quirk" },
            "4": { "name": "entity.name.namespace.alias.quirk" }
          }
        },
        {
          "match": "\\b(use)\\s+([a-zA-Z0-9_./]+)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.quirk" },
            "2": { "name": "entity.name.namespace.quirk" }
          }
        }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "match": "\\b(struct)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "storage.type.struct.quirk" },
            "2": { "name": "entity.name.type.struct.quirk" }
          }
        },
        {
          "match": "\\b(enum)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "storage.type.enum.quirk" },
            "2": { "name": "entity.name.type.enum.quirk" }
          }
        },
        {
          "match": "\\b(define|init)\\s+([a-zA-Z_]\\w*)?",
          "captures": {
            "1": { "name": "storage.type.function.quirk" },
            "2": { "name": "entity.name.function.definition.quirk" }
          }
        },
        {
          "match": "\\b(type)\\s+([a-zA-Z_]\\w*)\\s*(=)",
          "captures": {
            "1": { "name": "keyword.other.quirk" },
            "2": { "name": "entity.name.type.alias.quirk" },
            "3": { "name": "keyword.operator.assignment.quirk" }
          }
        },
        {
          "match": "\\b(interface)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "storage.type.interface.quirk" },
            "2": { "name": "entity.name.type.interface.quirk" }
          }
        },
        {
          "match": "\\b(struct|define|init)\\s+([a-zA-Z_]\\w*)\\s*(\\[)([^\\]]*)(\\])",
          "captures": {
            "1": { "name": "storage.type.quirk" },
            "2": { "name": "entity.name.function.definition.quirk" },
            "3": { "name": "punctuation.definition.typeparams.begin.quirk" },
            "4": { "name": "entity.name.type.parameter.quirk" },
            "5": { "name": "punctuation.definition.typeparams.end.quirk" }
          }
        },
        {
          "match": "\\b(extern)\\b",
          "name": "storage.modifier.quirk"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.quirk",
          "match": "\\b(if|else|elif|while|for|in|return|break|continue|with|as|try|catch|throw|finally|from|match|case|where|is|not|and|or|nonlocal|global)\\b"
        },
        {
          "name": "keyword.other.wildcard.quirk",
          "match": "(?<=\\bcase\\s+)_\\b"
        },
        {
          "name": "keyword.other.lambda.quirk",
          "match": "\\bfn\\b"
        },
        {
          "name": "keyword.other.quirk",
          "match": "\\b(del|const|ref|type)\\b"
        },
        {
          "name": "constant.language.quirk",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.this.quirk",
          "match": "\\b(self|super)\\b"
        }
      ]
    },
    "exceptions": {
      "patterns": [
        {
          "name": "support.class.exception.quirk",
          "match": "\\b(Exception|TypeError|ValueError|IndexError|KeyError|IOError|FileNotFoundError|RuntimeError|NotImplementedError|ZeroDivisionError|AssertionError|NullError|SocketError|WhereConditionError)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.quirk",
          "match": "\\b(void|Any)\\b"
        },
        {
          "name": "support.type.object.quirk",
          "match": "\\b(Char|List|String|Map|Int|Double|Bool|File|Callable|Tuple|Set|Queue|Self)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.quirk",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.quirk",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.quirk",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-content" }
          ]
        },
        {
          "name": "string.quoted.single.quirk",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "include": "#string-content" }
          ]
        }
      ]
    },
    "string-content": {
      "patterns": [
        {
          "name": "constant.character.escape.quirk",
          "match": "\\\\."
        },
        {
          "name": "meta.embedded.line.quirk",
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.quirk" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.quirk" }
          },
          "contentName": "source.quirk",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "match": "(\\$)([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "punctuation.definition.template-expression.quirk" },
            "2": { "name": "variable.other.readwrite.quirk" }
          }
        }
      ]
    },
    "enum-access": {
      "patterns": [
        {
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.)((?:[A-Z][a-zA-Z0-9_]*))\\b(?!\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.type.enum.quirk" },
            "2": { "name": "punctuation.separator.enum.quirk" },
            "3": { "name": "variable.other.enummember.quirk" }
          }
        }
      ]
    },
    "magic-methods": {
      "patterns": [
        {
          "match": "\\b(__init|__del|__str|__repr|__bool|__len|__get|__set|__iter|__has_next|__next|__add|__sub|__mul|__div|__eq|__ne|__lt|__le|__gt|__ge|__enter|__exit|__name|__parent|__class)\\b",
          "name": "support.function.magic.quirk"
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "match": "(\\.)([a-zA-Z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "punctuation.separator.method.quirk" },
            "2": { "name": "entity.name.function.method.quirk" }
          }
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.call.quirk"
            }
          }
        }
      ]
    },
    "keyword-arguments": {
      "patterns": [
        {
          "comment": "Named/keyword argument: func(name = value) — ident directly before = (not :=, ==, =>)",
          "match": "(?<![.\\[])\\b([a-zA-Z_]\\w*)\\s*(=)(?![=>])",
          "captures": {
            "1": { "name": "variable.parameter.quirk" },
            "2": { "name": "keyword.operator.assignment.quirk" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.quirk",
          "match": "(:=|\\+=|-=|\\*=|/=|%=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.quirk",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.quirk",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.quirk",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "comment": "Spread/variadic — must precede the range operator below; TextMate is first-match-wins so `...args` was being eaten as `..` + `.args` and the parameter name rendered as garbage.",
          "name": "keyword.operator.spread.quirk",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.quirk",
          "match": "\\.\\."
        },
        {
          "name": "storage.type.function.arrow.quirk",
          "match": "->"
        },
        {
          "name": "keyword.operator.lambda.quirk",
          "match": "=>"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.quirk",
          "match": "^\\s*---.*?---\\s*$"
        },
        {
          "name": "comment.block.documentation.quirk",
          "begin": "^\\s*---\\s*$",
          "end": "^\\s*---\\s*$"
        },
        {
          "name": "comment.line.double-slash.quirk",
          "match": "//.*$"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "match": "(\\.)([a-zA-Z_]\\w*)\\b",
          "captures": {
            "1": { "name": "punctuation.separator.property.quirk" },
            "2": { "name": "variable.other.property.quirk" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\b",
          "name": "variable.other.readwrite.quirk"
        }
      ]
    }
  },
  "scopeName": "source.quirk"
}