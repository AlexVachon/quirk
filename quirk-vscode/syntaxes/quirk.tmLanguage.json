{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Quirk",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.quirk",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.quirk",
          "match": "\\b(if|else|elif|while|for|in|return|break|continue)\\b"
        },
        {
          "name": "keyword.other.quirk",
          "match": "\\b(define|struct|extern|use|init|del)\\b"
        },
        {
          "name": "constant.language.quirk",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.this.quirk",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.quirk",
          "match": "\\b(int|double|float|bool|string|cstring|void|any|list|List|String|Map)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.quirk",
          "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.quirk",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.quirk",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.quirk",
          "match": "\\\\."
        },
        {
          "name": "variable.interpolation.quirk",
          "match": "\\$\\{[^}]+\\}|\\$[a-zA-Z_]\\w*"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_]\\w*)\\s*\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.quirk"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.quirk"
}